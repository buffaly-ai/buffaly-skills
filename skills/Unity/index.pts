[SemanticProgram.InfinitivePhrase("to capture a unity scene screenshot")]
prototype ToCaptureUnityScene : UnitySkillAction
{
	Description = @"outputPath - absolute or relative .png path. maxWidth - max width (0 for full). maxHeight - max height (0 for full).
Captures a desktop screenshot to verify the Unity scene visually.";

	function Execute(string outputPath, int maxWidth, int maxHeight) : string
	{
		return "Screenshot capture is handled by the ToCaptureDesktopScreenshotFile action. Call it with outputPath=" + outputPath + " maxWidth=" + ToUnityIntText(maxWidth) + " maxHeight=" + ToUnityIntText(maxHeight) + ". For batch-mode Unity hosts, use ToGetUnitySceneState for JSON scene inspection instead.";
	}
}

[SemanticProgram.InfinitivePhrase("to launch a unity host")]
prototype ToLaunchUnityHost : UnitySkillAction
{
	Description = @"exePath - path to UnityHost.exe. args - command-line arguments.
Launches the Unity host application.";

	function Execute(string exePath, string args) : string
	{
		return SystemOperations.RunCommandLineWithTimeout(exePath, args, 10);
	}
}

[SemanticProgram.InfinitivePhrase("to run a unity demo")]
[SemanticProgram.InfinitivePhrase("to run end-to-end unity skill test")]
prototype ToRunUnityDemo : UnitySkillAction
{
	Description = @"host - hostname or IP. port - TCP port. stagingHint - pass 'staging' to use staging helper path.
Runs a full demo: connect, spawn cube, spawn sphere, get scene state, build tower, create grid, build house.
Returns all results.";

	function Execute(string host, int port, string stagingHint) : string
	{
		string helperPath = ToUnityResolveHelperPath(stagingHint);
		string portArg = "-Port " + ToUnityIntText(port);
		string hostArg = "-HostName " + host;
		string baseArgs = hostArg + " " + portArg + " -Mode Single -CommandType ";
		string batchArgs = hostArg + " " + portArg + " -Mode Batch -Pattern ";

		string results = "";
		results = results + "=== Connect (GetSceneState) ===" + "\n" + ToUnityRunClient(helperPath, baseArgs + "GetSceneState") + "\n\n";
		results = results + "=== Spawn Cube ===" + "\n" + ToUnityRunClient(helperPath, baseArgs + "Spawn -ObjectType Cube -X 0 -Y 5 -Z 0") + "\n\n";
		results = results + "=== Spawn Sphere ===" + "\n" + ToUnityRunClient(helperPath, baseArgs + "Spawn -ObjectType Sphere -X 3 -Y 2 -Z 0") + "\n\n";
		results = results + "=== Build Tower (4 cubes) ===" + "\n" + ToUnityRunClient(helperPath, batchArgs + "Tower -Count 4 -X 10 -Z 0") + "\n\n";
		results = results + "=== Create Grid (3x3 spheres) ===" + "\n" + ToUnityRunClient(helperPath, batchArgs + "Grid -ObjectType Sphere -Rows 3 -Cols 3 -StartX -10 -StartY 0.5 -StartZ 10 -Spacing 2") + "\n\n";
		results = results + "=== Build House ===" + "\n" + ToUnityRunClient(helperPath, batchArgs + "House -X 15 -Z 0 -Width 4 -Height 3") + "\n\n";
		results = results + "=== Final Scene State ===" + "\n" + ToUnityRunClient(helperPath, baseArgs + "GetSceneState");

		return results;
	}
}
