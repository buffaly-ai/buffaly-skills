prototype UnitySkillAction : OpsAction
{
	Description = @"Base action type for Unity interaction skill tools.";
}

[SemanticEntity("unity interaction skill, unity skill")]
prototype UnityInteractionSkill : SkillEntity, CoreEntity
{
	Description = "Native skill for controlling a Unity host application via TCP JSON protocol. Supports primitive commands and high-level composite actions.";
	ActionRoot = UnitySkillAction;
}

function ToUnityHelperPath() : string
{
	return @"C:\inetpub\wwwroot\matt.buffaly.local\content\projects\OpsAgent\Skills\Unity\unity-host-client.ps1";
}

function ToUnityHelperPathStaging() : string
{
	return @"C:\inetpub\wwwroot\staging.buffaly.local3\content\projects\OpsAgent\Skills\Unity\unity-host-client.ps1";
}

function ToUnityResolveHelperPath(string stagingHint) : string
{
	if (StringUtil.IsEmpty(stagingHint))
	{
		return ToUnityHelperPath();
	}
	return ToUnityHelperPathStaging();
}

function ToUnityRunClient(string helperPath, string args) : string
{
	return SystemOperations.RunCommandLineWithTimeout(@"C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe", "-ExecutionPolicy Bypass -NoProfile -File " + helperPath + " " + args, 30);
}

function ToUnityIntText(int value) : string
{
	return JsonUtil.ToStringExt(value).ToString();
}

[SemanticProgram.InfinitivePhrase("to connect to a unity host")]
[SemanticProgram.InfinitivePhrase("to check unity host connection")]
prototype ToConnectToUnityHost : UnitySkillAction
{
	Description = @"host - hostname or IP. port - TCP port. stagingHint - pass 'staging' to use staging helper path.
Sends a GetSceneState command to verify the Unity host is running and responsive.
Returns the scene state JSON or an error message.";

	function Execute(string host, int port, string stagingHint) : string
	{
		string helperPath = ToUnityResolveHelperPath(stagingHint);
		string args = "-HostName " + host + " -Port " + ToUnityIntText(port) + " -Mode Single -CommandType GetSceneState";
		return ToUnityRunClient(helperPath, args);
	}
}

[SemanticProgram.InfinitivePhrase("to spawn an object in unity")]
[SemanticProgram.InfinitivePhrase("to create a unity primitive")]
prototype ToSpawnUnityObject : UnitySkillAction
{
	Description = @"host - hostname or IP. port - TCP port. type - primitive type: Cube, Sphere, Capsule, Cylinder, or Plane.
x, y, z - spawn position coordinates. stagingHint - pass 'staging' to use staging helper path.
Returns JSON with objectId, type, and position.";

	function Execute(string host, int port, string type, string x, string y, string z, string stagingHint) : string
	{
		string helperPath = ToUnityResolveHelperPath(stagingHint);
		string args = "-HostName " + host + " -Port " + ToUnityIntText(port) + " -Mode Single -CommandType Spawn -ObjectType " + type + " -X " + x + " -Y " + y + " -Z " + z;
		return ToUnityRunClient(helperPath, args);
	}
}

