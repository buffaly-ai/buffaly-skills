prototype ToSpawnUnityRow : UnitySkillAction
{
	Description = @"host - hostname or IP. port - TCP port. type - primitive type.
count - number of objects. startX, y, z - starting position. spacing - distance between objects.
stagingHint - pass 'staging' to use staging helper path.
Spawns a row of objects and returns all results.";

