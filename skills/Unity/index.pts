		string args = "-HostName " + host + " -Port " + ToUnityIntText(port) + " -Mode Batch -Pattern Row -ObjectType " + type + " -Count " + ToUnityIntText(count) + " -StartX " + startX + " -StartY " + y + " -StartZ " + z + " -Spacing " + spacing;
