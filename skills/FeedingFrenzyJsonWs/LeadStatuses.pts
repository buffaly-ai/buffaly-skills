prototype LeadStatuses_GetLeadStatus : FeedingFrenzyJsonWsSkillAction
{
	function Execute(FeedingFrenzyJsonWsService service, int LeadStatusID) : string
	{
		if (service == null) return "Error: FeedingFrenzyJsonWsService binding is required.";
		JsonObject args = new JsonObject();
		args["LeadStatusID"] = LeadStatusID;
		return service.CallBusinessRoute("lead-statuses/get-lead-status", args);
	}
}

prototype LeadStatuses_GetLeadStatuses : FeedingFrenzyJsonWsSkillAction
{
	function Execute(FeedingFrenzyJsonWsService service) : string
	{
		if (service == null) return "Error: FeedingFrenzyJsonWsService binding is required.";
		return service.CallBusinessRoute("lead-statuses/get-lead-statuses", new JsonObject());
	}
}

prototype LeadStatuses_GetLeadStatusByStatusName : FeedingFrenzyJsonWsSkillAction
{
	function Execute(FeedingFrenzyJsonWsService service, string StatusName) : string
	{
		if (service == null) return "Error: FeedingFrenzyJsonWsService binding is required.";
		JsonObject args = new JsonObject();
		args["StatusName"] = StatusName;
		return service.CallBusinessRoute("lead-statuses/get-lead-status-by-status-name", args);
	}
}
