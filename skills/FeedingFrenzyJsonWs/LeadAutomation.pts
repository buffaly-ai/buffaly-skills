prototype LeadAutomation_GetLeadsBySearch : FeedingFrenzyJsonWsSkillAction
{
	Description = @"JsonWs wrapper over FeedingFrenzy.Admin.Business.LeadAutomation.GetLeadsBySearch(Search). Returns raw response JSON string.";

	function Execute(FeedingFrenzyJsonWsService service, string Search) : string
	{
		if (service == null) return "Error: FeedingFrenzyJsonWsService binding is required.";
		JsonObject args = new JsonObject();
		args["Search"] = Search;
		return service.CallBusinessRoute("lead-automation/get-leads-by-search", args);
	}
}

