prototype Leads_GetPotentialDuplicates : FeedingFrenzyJsonWsSkillAction
{
	Description = @"JsonWs wrapper over FeedingFrenzy.Admin.Business.Leads.GetPotentialDuplicates(rowLead), adapted to accept leadID and resolve the row through the published GetLead route before calling the duplicate route. Returns raw response JSON string.";

	function Execute(FeedingFrenzyJsonWsService service, int LeadID) : string
	{
		if (service == null) return "Error: FeedingFrenzyJsonWsService binding is required.";
		JsonObject getLeadArgs = new JsonObject();
		getLeadArgs["LeadID"] = LeadID;
		string leadResponse = service.CallBusinessRoute("leads/get-lead", getLeadArgs);
		JsonObject leadRoot = new JsonObject(leadResponse);
		JsonObject rowLead = leadRoot.GetJsonObjectOrDefault("Result");
		if (rowLead == null)
			rowLead = leadRoot.GetJsonObjectOrDefault("Data");
		if (rowLead == null)
			rowLead = leadRoot;
		JsonObject args = new JsonObject();
		args["rowLead"] = rowLead;
		return service.CallBusinessRoute("leads/get-potential-duplicates", args);
	}
}
