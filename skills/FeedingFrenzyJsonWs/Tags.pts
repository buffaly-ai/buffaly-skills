prototype Tags_GetTag : FeedingFrenzyJsonWsSkillAction
{
	function Execute(FeedingFrenzyJsonWsService service, int TagID) : string
	{
		if (service == null) return "Error: FeedingFrenzyJsonWsService binding is required.";
		JsonObject args = new JsonObject();
		args["TagID"] = TagID;
		return service.CallBusinessRoute("tags/get-tag", args);
	}
}

prototype Tags_GetTags : FeedingFrenzyJsonWsSkillAction
{
	function Execute(FeedingFrenzyJsonWsService service) : string
	{
		if (service == null) return "Error: FeedingFrenzyJsonWsService binding is required.";
		return service.CallBusinessRoute("tags/get-tags", new JsonObject());
	}
}

