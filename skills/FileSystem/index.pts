prototype FileSystemSkillAction : OpsAction
{
	Description = @"Base action type for FileSystem skill tools.";
}

[SemanticEntity("file system skill")]
prototype FileSystemSkill : SkillEntity
{
	Description = "File and directory read/search/open operations for local workspace inspection.";
	ActionRoot = FileSystemSkillAction;
}

function ToNormalizeDirectoryPath(string directoryPath) : string
{
	if (StringUtil.IsEmpty(directoryPath))
	{
		return "";
	}

	return directoryPath.Trim();
}

function ToNormalizeFilePattern(string pattern) : string
{
	if (StringUtil.IsEmpty(pattern))
	{
		return "*.*";
	}

	return pattern.Trim();
}

function ToResolveFilePath(string directoryPath, string filePath) : string
{
	if (StringUtil.IsEmpty(filePath))
	{
		return "";
	}

	string normalizedDirectoryPath = ToNormalizeDirectoryPath(directoryPath);
	if (Path.IsPathRooted(filePath))
	{
		return filePath;
	}
	if (StringUtil.IsEmpty(normalizedDirectoryPath))
	{
		return "";
	}

	return Path.Combine(normalizedDirectoryPath, filePath);
}

function ToEscapePowerShellSingleQuoted(string value) : string
{
	if (value == null)
	{
		return "";
	}

	return value.Replace("'", "''");
}

[SemanticProgram.InfinitivePhrase("to launch or open a file")]
prototype ToLaunchOrOpenFile : FileSystemSkillAction
{
	Description = @"filePath - file path or URL to open.";

	function Execute(string filePath) : string
	{
		// Launch a local file or URL using the default shell handler.
		return SystemOperations.LaunchFile(filePath);
	}
}

[SemanticProgram.InfinitivePhrase("to list files in a directory")]
[SemanticProgram.InfinitivePhrase("to search for files in a directory")]
prototype ToListFilesInDirectory : FileSystemSkillAction
{
	Description = @"directoryPath - root folder to search. pattern - wildcard file pattern (defaults to *.*).";

	function Execute(string directoryPath, string pattern) : string
	{
		// List files in a directory using the FileSystemTools file search helper.
		string normalizedDirectoryPath = ToNormalizeDirectoryPath(directoryPath);
		string normalizedPattern = ToNormalizeFilePattern(pattern);
		return FileSystemTools.SearchFiles(normalizedDirectoryPath, normalizedPattern);
	}
}

[SemanticProgram.InfinitivePhrase("to read a text file")]
[SemanticProgram.InfinitivePhrase("to read a file from a directory")]
prototype ToReadTextFile : FileSystemSkillAction, CodingContext
{
	Description = @"directoryPath - optional base directory for relative paths. filePath - relative or absolute file path. StringRef-first for large payload chaining; use ToReadTextFileRaw when immediate materialized text is required.";

	function Execute(string directoryPath, string filePath) : StringRef
	{
		// Read file contents through FileSystemTools.ReadFile for consistent formatting and truncation.
		if (StringUtil.IsEmpty(filePath))
		{
			return "Error: filePath is required.";
		}

		string normalizedDirectoryPath = ToNormalizeDirectoryPath(directoryPath);
		if (StringUtil.IsEmpty(normalizedDirectoryPath))
		{
			if (Path.IsPathRooted(filePath))
			{
				normalizedDirectoryPath = Path.GetDirectoryName(filePath);
			}
			else
			{
				return "Error: directoryPath is required for relative file paths.";
			}
		}

		return FileSystemTools.ReadFile(normalizedDirectoryPath, filePath);
	}
}

[SemanticProgram.InfinitivePhrase("to read raw text file data")]
[SemanticProgram.InfinitivePhrase("to read a file from a directory as raw text")]
prototype ToReadTextFileRaw : FileSystemSkillAction, CodingContext
{
	Description = @"directoryPath - optional base directory for relative paths. filePath - relative or absolute file path. Use when immediate raw text is required for display or inspection; materializes and returns raw text string immediately. Files larger than 10 KB are rejected — use ToSearchTextInFile to find specific text or ToGetFileBlock to read a line range instead.";

	function Execute(string directoryPath, string filePath) : string
	{
		// Read file contents through FileSystemTools.ReadFile and return raw materialized text.
		if (StringUtil.IsEmpty(filePath))
		{
			return "Error: filePath is required.";
		}

		string normalizedDirectoryPath = ToNormalizeDirectoryPath(directoryPath);
		if (StringUtil.IsEmpty(normalizedDirectoryPath))
		{
			if (Path.IsPathRooted(filePath))
			{
				normalizedDirectoryPath = Path.GetDirectoryName(filePath);
			}
			else
			{
				return "Error: directoryPath is required for relative file paths.";
			}
		}

		// Check file size before reading — large files should use targeted tools instead.
		string sizeGuidance = FileSystemTools.GetFileSizeGuidance(normalizedDirectoryPath, filePath);
		if (!StringUtil.IsEmpty(sizeGuidance))
		{
			return sizeGuidance;
		}

		return FileSystemTools.ReadFile(normalizedDirectoryPath, filePath);
	}
}

[SemanticProgram.InfinitivePhrase("to search for text in a directory")]
[SemanticProgram.InfinitivePhrase("to search text across files in a directory")]
prototype ToSearchTextInDirectory : FileSystemSkillAction
{
	Description = @"directoryPath - root folder to search. text - literal text to match.";

	function Execute(string directoryPath, string text) : string
	{
		// Search text in supported source file types under the target directory.
		string normalizedDirectoryPath = ToNormalizeDirectoryPath(directoryPath);
		return FileSystemTools.SearchText(normalizedDirectoryPath, text);
	}
}

[SemanticProgram.InfinitivePhrase("to search for text in a directory with code context")]
[SemanticProgram.InfinitivePhrase("to search text with code in a directory")]
prototype ToSearchTextInDirectoryWithCode : FileSystemSkillAction
{
	Description = @"directoryPath - root folder to search. text - literal text to match.";

	function Execute(string directoryPath, string text) : string
	{
