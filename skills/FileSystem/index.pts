		string normalizedDirectoryPath = ToNormalizeDirectoryPath(directoryPath);
		return FileSystemTools.SearchTextWithCode(normalizedDirectoryPath, text);
	}
}

[SemanticProgram.InfinitivePhrase("to get a block of lines from a file")]
[SemanticProgram.InfinitivePhrase("to read a line range from a file")]
prototype ToGetFileBlock : FileSystemSkillAction, CodingContext
{
	Description = @"directoryPath - optional base directory for relative paths. filePath - relative or absolute file path. startLine - 1-based line index. lineCount - number of lines.";

	function Execute(string directoryPath, string filePath, int startLine, int lineCount) : string
	{
		// Return a line range from a file via FileSystemTools.GetFileBlock.
		if (StringUtil.IsEmpty(filePath))
		{
			return "Error: filePath is required.";
		}
		if (lineCount <= 0)
		{
			return "Error: lineCount must be greater than zero.";
		}

		string normalizedDirectoryPath = ToNormalizeDirectoryPath(directoryPath);
		if (StringUtil.IsEmpty(normalizedDirectoryPath))
		{
			if (Path.IsPathRooted(filePath))
			{
				normalizedDirectoryPath = Path.GetDirectoryName(filePath);
			}
			else
			{
				return "Error: directoryPath is required for relative file paths.";
			}
		}

		return FileSystemTools.GetFileBlock(normalizedDirectoryPath, filePath, startLine, lineCount);
	}
}


[SemanticProgram.InfinitivePhrase("to search for text in a file")]
[SemanticProgram.InfinitivePhrase("to find text within a file")]
prototype ToSearchTextInFile : FileSystemSkillAction
{
	Description = @"directoryPath - optional base directory for relative file paths. filePath - relative or absolute path. text - literal text to match.";

	function Execute(string directoryPath, string filePath, string text) : string
	{
		// Search a single file with line-context output using Select-String.
		if (StringUtil.IsEmpty(filePath))
		{
			return "Error: filePath is required.";
		}
		if (StringUtil.IsEmpty(text))
		{
			return "Error: text is required.";
		}

		string resolvedFilePath = ToResolveFilePath(directoryPath, filePath);
		if (StringUtil.IsEmpty(resolvedFilePath))
		{
			return "Error: directoryPath is required for relative file paths.";
		}

		string escapedFilePath = ToEscapePowerShellSingleQuoted(resolvedFilePath);
		string escapedText = ToEscapePowerShellSingleQuoted(text);
		string script =
			"$filePath = '" + escapedFilePath + "'; " +
			"$text = '" + escapedText + "'; " +
			"if (-not (Test-Path -LiteralPath $filePath)) { throw ('File not found: ' + $filePath) }; " +
			"$results = Select-String -LiteralPath $filePath -Pattern $text -SimpleMatch -CaseSensitive:$false -Context 2,2; " +
			"if ($results.Count -eq 0) { return 'No matches found in file: ' + $filePath }; " +
			"$results | ForEach-Object { '-- line ' + $_.LineNumber + ' --'; $_.Context.PreContext; $_.Line; $_.Context.PostContext; '' };";

		return SystemOperations.RunPowerShell(script);
	}
}

[SemanticProgram.InfinitivePhrase("to search text with ripgrep in a directory")]
[SemanticProgram.InfinitivePhrase("to search files in a directory with rg")]
[SemanticProgram.InfinitivePhrase("to find text using ripgrep in a folder")]
prototype ToSearchTextInDirectoryWithRipgrep : FileSystemSkillAction, CodingContext
{
	Description = @"directoryPath - root folder to search.
text - literal text to match.
Uses rg (ripgrep) for fast recursive literal search and returns formatted file/line results. Requires ripgrep to be installed and available on PATH. Returns 'Error: ...' for missing inputs, missing directory, or missing rg.
If RG is missing, offer to install it for the user.";

	function Execute(string directoryPath, string text) : string
	{
		string normalizedDirectoryPath = ToNormalizeDirectoryPath(directoryPath);
		return RipGrepTools.SearchText(normalizedDirectoryPath, text, false);
	}
}

[SemanticProgram.InfinitivePhrase("to replace a text file")]
[SemanticProgram.InfinitivePhrase("to replace an entire file with text")]
prototype ToReplaceTextFile : FileSystemSkillAction
{
	Description = @"directoryPath - optional base directory for relative file paths. filePath - relative or absolute file path. content - full file content to write.";

	function Execute(string directoryPath, string filePath, string content) : string
	{
		if (StringUtil.IsEmpty(filePath))
		{
			return "Error: filePath is required.";
		}

		string normalizedDirectoryPath = ToNormalizeDirectoryPath(directoryPath);
		if (StringUtil.IsEmpty(normalizedDirectoryPath))
		{
			if (Path.IsPathRooted(filePath))
			{
				normalizedDirectoryPath = Path.GetDirectoryName(filePath);
			}
			else
			{
				return "Error: directoryPath is required for relative file paths.";
			}
		}

		return FileSystemTools.ReplaceTextFile(normalizedDirectoryPath, filePath, content);
	}
}

