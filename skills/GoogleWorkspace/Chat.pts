function ToNormalizeGoogleChatSpace(string space) : string
{
	if (StringUtil.IsEmpty(space))
		return "";

	if (space.StartsWith("spaces/"))
		return space;

	return "spaces/" + space;
}

function ToEscapeForSingleQuotedPowerShell(string value) : string
{
	if (value == null)
		return "";

	return value.Replace("'", "''");
}

function ToNormalizeGoogleWorkspaceChatScopePreset(string scopePreset, bool forWrite) : string
{
	if (StringUtil.IsEmpty(scopePreset))
	{
		if (forWrite)
			return "workspace.write";
		return "workspace.read";
	}

	string lowered = scopePreset.ToLower();

	// NOTE (Buffaly): chat scope remap temporarily disabled (kept below as comments).
	// Reason: coercing chat.* to workspace.* prevented Chat scopes from showing on OAuth consent.
	// Not 100% certain old behavior is never required, so preserving for future rollback/audit.
	// if (lowered.StartsWith("chat"))
	// {
	// 	if (forWrite)
	// 		return "workspace.write";
	// 	return "workspace.read";
	// }

	return scopePreset;
}

function ToFilterGoogleWorkspaceChatSpacesFacadeJson(string facadeJson, bool joinedOnly, string spaceType) : string
{
	if (StringUtil.IsEmpty(facadeJson))
		return facadeJson;

	string joinedOnlyText = "false";
	if (joinedOnly)
		joinedOnlyText = "true";

	string safeFacadeJson = ToEscapeForSingleQuotedPowerShell(facadeJson);
	string safeSpaceType = ToEscapeForSingleQuotedPowerShell(spaceType);
	string safeJoinedOnly = ToEscapeForSingleQuotedPowerShell(joinedOnlyText);

	string script = "$root = ConvertFrom-Json -InputObject '" + safeFacadeJson + "'; " +
		"if ($root -ne $null -and $root.ok -eq $true -and $root.data -ne $null -and $root.data.spaces -ne $null) { " +
		"  $spaces = @($root.data.spaces); " +
		"  if ('" + safeSpaceType + "' -ne '') { $spaces = @($spaces | Where-Object { $_.spaceType -eq '" + safeSpaceType + "' -or $_.type -eq '" + safeSpaceType + "' }) }; " +
		"  if ('" + safeJoinedOnly + "' -eq 'true') { $spaces = @($spaces | Where-Object { ($_.membershipState -eq $null) -or ($_.membershipState -eq 'JOINED') -or ($_.membership -eq 'JOINED') }) }; " +
		"  $root.data.spaces = $spaces; " +
		"  $root.data.count = @($spaces).Count; " +
		"}; " +
		"$root | ConvertTo-Json -Depth 50";

	return SystemOperations.RunPowerShell(script);
}

[SemanticProgram.InfinitivePhrase("to list google workspace chat spaces from account")]
[SemanticProgram.InfinitivePhrase("to list google chat spaces using google workspace account")]
prototype ToListGoogleWorkspaceChatSpacesByAccount : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to workspace.read when empty. Chat aliases like chat.read/chat.write are normalized to workspace presets. pageSize - 1..1000. pageToken optional. joinedOnly - true to keep joined spaces when membership metadata is present (best effort). spaceType optional filter such as SPACE, GROUP_CHAT, or DIRECT_MESSAGE. Returns Chat API JSON page.";

	function Execute(string accountKey, string scopePreset, int pageSize, string pageToken, bool joinedOnly, string spaceType) : string
	{
		return GoogleWorkspaceServiceHost.ListSpacesAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			ToNormalizeGoogleWorkspaceChatScopePreset(scopePreset, false),
			pageSize,
			pageToken,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to list google workspace chat messages page from account")]
prototype ToListGoogleWorkspaceChatMessagesPageByAccount : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to workspace.read when empty. Chat aliases like chat.read/chat.write are normalized to workspace presets. space - Google Chat space id or spaces/{id}. pageSize - 1..1000. pageToken optional. Returns Chat API JSON page.";

	function Execute(string accountKey, string scopePreset, string space, int pageSize, string pageToken) : string
	{
		return GoogleWorkspaceServiceHost.ListMessagesPageAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			ToNormalizeGoogleWorkspaceChatScopePreset(scopePreset, false),
			ToNormalizeGoogleChatSpace(space),
			pageSize,
			pageToken,
			false,
			new CancellationToken(false));
	}
}



[SemanticProgram.InfinitivePhrase("to send a google workspace chat message from account")]
[SemanticProgram.InfinitivePhrase("to send a google chat message from account")]
prototype ToSendGoogleWorkspaceChatMessageByAccount : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to workspace.write when empty. Chat aliases like chat.read/chat.write are normalized to workspace presets. space - Google Chat space id or spaces/{id}. messageText - text payload. Returns Chat API JSON.";

	function Execute(string accountKey, string scopePreset, string space, string messageText) : string
	{
		return GoogleWorkspaceServiceHost.SendMessageAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			ToNormalizeGoogleWorkspaceChatScopePreset(scopePreset, true),
			ToNormalizeGoogleChatSpace(space),
			messageText,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to list google workspace chat messages from account")]
[SemanticProgram.InfinitivePhrase("to receive google chat messages from account")]
prototype ToListGoogleWorkspaceChatMessagesByAccount : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to workspace.read when empty. Chat aliases like chat.read/chat.write are normalized to workspace presets. space - Google Chat space id or spaces/{id}. pageSize - 1..1000. Returns Chat API JSON page.";

	function Execute(string accountKey, string scopePreset, string space, int pageSize) : string
	{
		return ToListGoogleWorkspaceChatMessagesPageByAccount.Execute(accountKey, scopePreset, space, pageSize, "");
	}
}


