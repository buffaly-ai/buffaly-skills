[SemanticProgram.InfinitivePhrase("to run browser script")]
[SemanticProgram.InfinitivePhrase("to run JavaScript in the browser")]
[SemanticProgram.InfinitivePhrase("to evaluate JavaScript in a browser session")]
prototype ToRunBrowserScript : BrowserSessionSkillAction
{
	Description = @"Runs inline JavaScript in the active browser page using BrowserSessionTools.RunBrowserScript. script - JavaScript function/source. argsJson - JSON argument payload. mutationPolicy - audit label: readOnly or allowMutation.";

	function Execute(string subAgentId, string script, string argsJson = "{}", int timeoutMs = 15000, string mutationPolicy = "readOnly") : string
	{
		return BrowserSessionTools.RunBrowserScript(_opsAgent, subAgentId, script, argsJson, timeoutMs, mutationPolicy);
	}
}

[SemanticProgram.InfinitivePhrase("to capture browser screenshot")]
[SemanticProgram.InfinitivePhrase("to take browser screenshot")]
prototype ToCaptureBrowserScreenshot : BrowserSessionSkillAction
{
	Description = @"Thin wrapper over BrowserTools.BrowserScreenshotTool(_opsAgent, subAgentId, relativePath).";

	function Execute(string subAgentId, string relativePath) : string
	{
		return BrowserTools.BrowserScreenshotTool(_opsAgent, subAgentId, relativePath);
	}
}

[SemanticProgram.InfinitivePhrase("to get browser console events")]
[SemanticProgram.InfinitivePhrase("to read browser console diagnostics")]
prototype ToGetBrowserConsoleEvents : BrowserSessionSkillAction
{
	Description = @"Thin wrapper over BrowserTools.BrowserConsoleEventsTool(_opsAgent, subAgentId, maxCount, clearAfterRead).";

	function Execute(string subAgentId, int maxCount = 100, bool clearAfterRead = false) : string
	{
		return BrowserTools.BrowserConsoleEventsTool(_opsAgent, subAgentId, maxCount, clearAfterRead);
	}
}

[SemanticProgram.InfinitivePhrase("to fill a browser selector with a secret")]
[SemanticProgram.InfinitivePhrase("to type a secret into a browser password field")]
prototype ToFillBrowserSelectorWithSecret : BrowserSessionSkillAction
{
	Description = @"Fills a browser selector with a StringRef secret without returning or logging the secret. secretValue - StringRef returned by ToGetUserSecret and materialized only at this typed boundary. Returns redacted JSON only.";

	function Execute(string subAgentId, string selector, StringRef secretValue, int timeoutMs = 15000) : string
	{
		return BrowserSessionTools.FillBrowserSelectorWithSecret(_opsAgent, subAgentId, selector, secretValue, timeoutMs);
	}
}
