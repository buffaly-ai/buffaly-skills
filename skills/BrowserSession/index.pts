prototype ToWaitForBrowserSelectorState : BrowserSessionSkillAction
{
	Description = @"Thin wrapper over BrowserTools.BrowserWaitForSelectorStateTool(_opsAgent, subAgentId, selector, state, timeoutMs).";

	function Execute(string subAgentId, string selector, string state, int timeoutMs = 15000) : string
	{
