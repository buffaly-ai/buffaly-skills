[SemanticProgram.InfinitivePhrase("to get browser selector attribute")]
prototype ToGetBrowserSelectorAttribute : BrowserSessionSkillAction
{
	Description = @"Thin wrapper over BrowserTools.BrowserGetSelectorAttributeTool(_opsAgent, subAgentId, selector, attributeName, timeoutMs).";

	function Execute(string subAgentId, string selector, string attributeName, int timeoutMs = 15000) : string
	{
		return BrowserTools.BrowserGetSelectorAttributeTool(_opsAgent, subAgentId, selector, attributeName, timeoutMs);
