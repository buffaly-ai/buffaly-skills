[SemanticProgram.InfinitivePhrase("to list fairpath patient statuses via jsonws")]
[SemanticProgram.InfinitivePhrase("to get fairpath patient statuses via jsonws")]
prototype PatientStatuses_GetPatientStatuses : FairPathJsonWsSkillAction
{
	Description = @"JsonWs wrapper over the conventional FairPath.Business.PatientStatuses.GetPatientStatuss() route. Returns raw response JSON string.";
	InfinitivePhrase = "to list fairpath patient statuses via jsonws";

	function Execute(FairPathJsonWsService service) : string
	{
		if (service == null) return "Error: FairPathJsonWsService binding is required.";
		return service.CallBusinessRoute("patient-statuses/get-patient-statuses", new JsonObject());
	}
}
