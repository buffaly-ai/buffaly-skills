prototype Organizations_GetOrganizationByOrganizationName : FairPathJsonWsSkillAction
{
	Description = @"JsonWs wrapper over FairPath.Business.Organizations.GetOrganizationByOrganizationName(OrganizationName). Returns raw response JSON string.";

	function Execute(FairPathJsonWsService service, string OrganizationName) : string
	{
		if (service == null) return "Error: FairPathJsonWsService binding is required.";
		if (StringUtil.IsEmpty(OrganizationName)) return "Error: OrganizationName is required.";
		JsonObject args = new JsonObject();
		args["OrganizationName"] = OrganizationName;
		return service.CallBusinessRoute("organizations/get-organization-by-organization-name", args);
	}
}

