		string command = "if not exist " + ToFFmpegQuoted(tempDirectory) + " mkdir " + ToFFmpegQuoted(tempDirectory) + " & " + ToFFmpegQuoted(exe) + " -hide_banner -y -i " + ToFFmpegQuoted(sourceVideoPath) + " -vf " + ToFFmpegQuoted(filter) + " -c:v libx264 -preset veryfast -pix_fmt yuv420p -c:a aac " + ToFFmpegQuoted(tempFile) + " & copy /Y " + ToFFmpegQuoted(tempFile) + " " + ToFFmpegQuoted(artifactFile);
		string result = SystemOperations.RunCommandLineWithTimeout(@"C:\Windows\System32\cmd.exe", "/c " + ToFFmpegQuoted(command), 120);
		string probeResult = SystemOperations.RunCommandLineWithTimeout(probe, "-v error -show_entries format=duration,size -show_streams -of json " + ToFFmpegQuoted(artifactFile), 30);
		return "Overlay video artifact:\n" + ToFFmpegArtifactRef(sessionDirectory, outputFileName) + "\n\nffmpeg output:\n" + result + "\n\nffprobe output:\n" + probeResult;
	}
}
[SemanticProgram.InfinitivePhrase("to extract an audio artifact from video with ffmpeg")]
[SemanticProgram.InfinitivePhrase("to separate the audio track from a video artifact")]
prototype ToExtractFFmpegAudioArtifact : FFmpegSkillAction
{
	Description = @"sourceMediaPath - video/media source as a local path, session artifact path, semantic file ref path, or approved https URL.
outputFileName - target audio artifact name. Use .m4a for the default AAC audio/mp4 output.
tempDirectory/sessionDirectory - working directory and session root/artifact root. Output is staged under artifacts/audio.
ffmpegPath/ffprobePath - optional tool paths. Defaults to C:\ffmpeg\bin.
Extracts the first source audio stream to AAC m4a, validates with ffprobe before and after extraction, and never mutates the source media.";

	function Execute(string sourceMediaPath, string outputFileName, string tempDirectory, string sessionDirectory, string ffmpegPath, string ffprobePath) : string
	{
		string exe = ToFFmpegDefaultExe(ffmpegPath);
		string probe = ToFFmpegDefaultProbeExe(ffprobePath);
		string audioDirectory = sessionDirectory + @"\artifacts\audio";
		string tempFile = tempDirectory + @"\" + outputFileName;
		string artifactFile = audioDirectory + @"\" + outputFileName;
		string sourceProbeArgs = "-v error -show_entries format=duration,size -show_streams -of json " + ToFFmpegQuoted(sourceMediaPath);
		string sourceProbeResult = SystemOperations.RunCommandLineWithTimeout(probe, sourceProbeArgs, 30);
		string prepareCommand = "mkdir " + ToFFmpegQuoted(tempDirectory) + " 2>nul & mkdir " + ToFFmpegQuoted(audioDirectory) + " 2>nul & del " + ToFFmpegQuoted(tempFile) + " 2>nul & del " + ToFFmpegQuoted(artifactFile) + " 2>nul";
		string prepareResult = SystemOperations.RunCommandLineWithTimeout(@"C:\Windows\System32\cmd.exe", "/c " + prepareCommand, 30);
		string extractArgs = "-hide_banner -y -i " + ToFFmpegQuoted(sourceMediaPath) + " -vn -map 0:a:0 -c:a aac -b:a 128k -movflags +faststart " + ToFFmpegQuoted(tempFile);
		string extractResult = SystemOperations.RunCommandLineWithTimeout(exe, extractArgs, 120);
		string copyCommand = "copy /Y " + ToFFmpegQuoted(tempFile) + " " + ToFFmpegQuoted(artifactFile);
		string copyResult = SystemOperations.RunCommandLineWithTimeout(@"C:\Windows\System32\cmd.exe", "/c " + copyCommand, 30);
		string validationResult = ToFFmpegVerifiedProbe(probe, artifactFile);

		return "Extracted audio artifact:\n" + ToFFmpegArtifactRef(audioDirectory, outputFileName) + "\n\nsource media:\n" + sourceMediaPath + "\n\nsource ffprobe output:\n" + sourceProbeResult + "\n\nprepare output:\n" + prepareResult + "\n\nextract output:\n" + extractResult + "\n\ncopy output:\n" + copyResult + "\n\nvalidation output:\n" + validationResult;
	}
}
