[SemanticProgram.InfinitivePhrase("to get OpenAI usage and costs")]
[SemanticProgram.InfinitivePhrase("to inspect OpenAI organization usage")]
prototype ToGetOpenAIUsageAndCosts : OpenAIAdminSkillAction
{
	Description = @"Thin wrapper over OpenAiAdminAgentTools.GetUsageAndCosts(startDate, endDate).
startDate and endDate are inclusive UTC dates in yyyy-MM-dd format.
Returns deterministic JSON with all usage dimensions and authoritative native OpenAI cost rows. No ProtoScript-side validation or reshaping.";

	function Execute(string startDate, string endDate) : string
	{
		return OpenAiAdminAgentTools.GetUsageAndCosts(startDate, endDate);
	}
}

