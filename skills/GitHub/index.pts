import Buffaly.Agent.Tools.Process Buffaly.Agent.Tools.Process.GitHubSkillFacade GitHubSkillFacade;

prototype GitHubSkillAction : OpsAction
{
	Description = @"Base action type for GitHub and git repository handoff tools.";
}

[SemanticEntity("github skill")]
prototype GitHubSkill : SkillEntity
{
	Description = "Thin ProtoScript handoff for GitHub organization, repository, issue, commit comment, and local git operations.";
	ActionRoot = GitHubSkillAction;
}

[SemanticProgram.InfinitivePhrase("to get github auth status")]
prototype ToGetGitHubAuthStatus : GitHubSkillAction
{
	Description = @"Returns the current GitHub authentication status.";

	function Execute() : string
	{
		return GitHubSkillFacade.GetGitHubAuthStatus();
	}
}

[SemanticProgram.InfinitivePhrase("to list github repositories for an organization")]
prototype ToListGitHubReposForOrg : GitHubSkillAction
{
	Description = @"orgName - GitHub organization name. Returns repositories available for the organization.";

	function Execute(string orgName) : string
	{
		return GitHubSkillFacade.ListGitHubReposForOrg(orgName);
	}
}

