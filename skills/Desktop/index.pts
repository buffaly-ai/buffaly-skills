[SemanticProgram.InfinitivePhrase("to click desktop window image coordinate")]
[SemanticProgram.InfinitivePhrase("to click scaled desktop window screenshot point")]
prototype ToClickDesktopWindowImage : DesktopSkillAction
{
	Description = @"processName - process name such as notepad.
windowTitleContains - optional title substring.
windowHandle - native window handle returned by ToResolveDesktopWindow and the capture artifact.
x - image-relative X coordinate from the captured screenshot artifact.
y - image-relative Y coordinate from the captured screenshot artifact.
nativeWindowWidth - NativeWindowWidth from the captured screenshot artifact.
nativeWindowHeight - NativeWindowHeight from the captured screenshot artifact.
imageWidth - ImageWidth from the captured screenshot artifact.
imageHeight - ImageHeight from the captured screenshot artifact.
button - mouse button: left, right, or middle.
Do not add screen offsets. The driver revalidates the process/title/handle, verifies current bounds still match the capture, foregrounds the window, and computes native screen coordinates internally.";

	function Execute(string processName, string windowTitleContains, string windowHandle, int x, int y, int nativeWindowWidth, int nativeWindowHeight, int imageWidth, int imageHeight, string button) : DesktopWindowActionResult
	{
		return DesktopAutomation.ClickDesktopWindowImageHandleText(processName, windowTitleContains, windowHandle, x, y, nativeWindowWidth, nativeWindowHeight, imageWidth, imageHeight, button);
	}
}

