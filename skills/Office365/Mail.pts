[SemanticProgram.InfinitivePhrase("to search office 365 mail messages")]
prototype ToSearchOffice365Messages : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to mail.read when empty. query - mail query string. maxResults - 1..500. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string query, int maxResults) : string
	{
		if (StringUtil.IsEmpty(scopePreset))
			scopePreset = "mail.read";

		// Return facade JSON without reshaping.
		return Office365ServiceHost.SearchMessagesAsync(			Office365Service.NormalizeOffice365AccountKey(accountKey),
			NormalizeOffice365OperationScopePreset(scopePreset),
			query,
			maxResults,
			false,
			new CancellationToken(false));
	}
}

