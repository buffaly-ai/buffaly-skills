[SemanticProgram.InfinitivePhrase("to send an office 365 email")]
[SemanticProgram.InfinitivePhrase("to send an office 365 email")]
prototype ToSendOffice365Email : Office365SkillAction
{
	Description = @"accountKey, from, to, subject, htmlBody required. scopePreset defaults to mail.send when empty. cc/bcc/replyTo/extraHeadersJson optional. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string from, string to, string subject, string htmlBody, string cc, string bcc, string replyTo, string extraHeadersJson) : string
	{
		if (StringUtil.IsEmpty(scopePreset))
			scopePreset = "mail.send";

