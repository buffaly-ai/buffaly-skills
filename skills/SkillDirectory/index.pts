reference Buffaly.Agent.SkillManagement;
import Buffaly.Agent.SkillManagement Buffaly.Agent.SkillManagement.SkillDirectoryService SkillDirectoryService;
import Buffaly.Agent.SkillManagement Buffaly.Agent.SkillManagement.SearchRemoteSkillsRequestContract SearchRemoteSkillsRequestContract;
import Buffaly.Agent.SkillManagement Buffaly.Agent.SkillManagement.GetRemoteSkillRequestContract GetRemoteSkillRequestContract;
import Buffaly.Agent.SkillManagement Buffaly.Agent.SkillManagement.PreviewRemoteSkillInstallRequestContract PreviewRemoteSkillInstallRequestContract;
import Buffaly.Agent.SkillManagement Buffaly.Agent.SkillManagement.InstallRemoteSkillRequestContract InstallRemoteSkillRequestContract;

prototype SkillDirectorySkillAction : OpsAction
{
	Description = @"Base action type for official Buffaly Skill Directory tools.";
}

[SemanticEntity("skill directory skill")]
prototype SkillDirectorySkill : SkillEntity
{
	Description = "Search, inspect, preview, and explicitly install official remote Buffaly skills.";
	ActionRoot = SkillDirectorySkillAction;
}

[SemanticProgram.InfinitivePhrase("to search the Buffaly Skill Directory")]
[SemanticProgram.InfinitivePhrase("to find installable Buffaly skills")]
[SemanticProgram.InfinitivePhrase("to list remote Buffaly skills")]
prototype ToSearchBuffalySkillDirectory : SkillDirectorySkillAction
{
	Description = @"searchText - optional text to match against official remote skills. Use an empty string to list all official skills.";

	function Execute(string searchText) : string
	{
		SearchRemoteSkillsRequestContract request = new SearchRemoteSkillsRequestContract();
		request.SearchText = searchText;
		return JsonUtil.ToFriendlyJSON(new JsonValue(SkillDirectoryService.SearchRemoteSkills(request))).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to get a Buffaly Skill Directory entry")]
[SemanticProgram.InfinitivePhrase("to inspect a remote Buffaly skill")]
prototype ToGetBuffalySkillDirectoryEntry : SkillDirectorySkillAction
{
	Description = @"skillName - exact SkillName from the official Skill Directory entry.";

	function Execute(string skillName) : string
	{
		GetRemoteSkillRequestContract request = new GetRemoteSkillRequestContract();
		request.SkillName = skillName;
		return JsonUtil.ToFriendlyJSON(new JsonValue(SkillDirectoryService.GetRemoteSkill(request))).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to preview installing a Buffaly skill")]
[SemanticProgram.InfinitivePhrase("to check installing a remote Buffaly skill")]
[SemanticProgram.InfinitivePhrase("to dry run Buffaly skill install")]
prototype ToPreviewBuffalySkillDirectoryInstall : SkillDirectorySkillAction
{
	Description = @"skillName - exact remote SkillName. replaceExisting - true only when intentionally replacing an existing local skill folder. This does not install or run anything.";

	function Execute(string skillName, bool replaceExisting) : string
	{
		PreviewRemoteSkillInstallRequestContract request = new PreviewRemoteSkillInstallRequestContract();
		request.SkillName = skillName;
		request.ReplaceExisting = replaceExisting;
		return JsonUtil.ToFriendlyJSON(new JsonValue(SkillDirectoryService.PreviewRemoteSkillInstall(request))).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to install a Buffaly skill from the Skill Directory")]
[SemanticProgram.InfinitivePhrase("to install a remote Buffaly skill")]
prototype ToInstallBuffalySkillFromDirectory : SkillDirectorySkillAction
{
	Description = @"skillName - exact remote SkillName. replaceExisting - true only when intentionally replacing an existing local skill folder. enableAfterInstall - true to add the installed skill to Skills/index.pts after download. Installation writes supported package files but does not execute the skill.";

	function Execute(string skillName, bool replaceExisting, bool enableAfterInstall) : string
	{
		InstallRemoteSkillRequestContract request = new InstallRemoteSkillRequestContract();
		request.SkillName = skillName;
		request.ReplaceExisting = replaceExisting;
		request.EnableAfterInstall = enableAfterInstall;
		return JsonUtil.ToFriendlyJSON(new JsonValue(SkillDirectoryService.InstallRemoteSkill(request))).ToString();
	}
}
