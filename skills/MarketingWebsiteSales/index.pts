[SemanticProgram.InfinitivePhrase("to compare two images with a model")]
[SemanticProgram.InfinitivePhrase("to compare website screenshots with a prompt")]
[SemanticProgram.InfinitivePhrase("to compare a reference image and working image")]
prototype ToCompareImagesViaBuffalyRuntime : MarketingWebsiteSalesSkillAction
{
	Description = @"Compare a reference image and working image through the Buffaly runtime provider catalog.
referenceImageUrlOrPath - required image URL or runtime-accepted artifact path for the target/original image.
workingImageUrlOrPath - required image URL or runtime-accepted artifact path for the candidate/new image.
prompt - required comparison instructions.
systemPrompt - optional system prompt.
provider - optional provider token; empty uses runtime default.
model - optional model override; empty uses runtime default.
reasoningLevel - optional canonical reasoning token.
Returns the selected model's comparison response.";

	function Execute(
		string referenceImageUrlOrPath,
		string workingImageUrlOrPath,
		string prompt,
		string systemPrompt = "",
		string provider = "",
		string model = "",
		string reasoningLevel = ""
	) : string
	{
		if (String.IsNullOrWhiteSpace(referenceImageUrlOrPath))
		{
			return "{\"Status\":\"failed\",\"Error\":\"referenceImageUrlOrPath is required.\"}";
		}

		if (String.IsNullOrWhiteSpace(workingImageUrlOrPath))
		{
			return "{\"Status\":\"failed\",\"Error\":\"workingImageUrlOrPath is required.\"}";
		}

		if (String.IsNullOrWhiteSpace(prompt))
		{
			return "{\"Status\":\"failed\",\"Error\":\"prompt is required.\"}";
		}

		string inputPartsJson = ImageComparisonProtoScriptFacade.BuildInputPartsJson(
			referenceImageUrlOrPath,
			workingImageUrlOrPath);

		return ToAskModelViaBuffalyRuntime.Execute(
			prompt,
			systemPrompt,
			provider,
			model,
			reasoningLevel,
			inputPartsJson);
	}
}




