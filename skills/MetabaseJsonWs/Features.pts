prototype MetabaseFeatures_InsertFeature : MetabaseJsonWsSkillAction
{
	Description = @"JsonWs wrapper over RooTrax.VDB.Features.InsertFeature(...).";
	function Execute(MetabaseJsonWsService service, string FeatureName, string Version, bool IsEnabled, string SettingsAssembly, string SettingsClass, string Settings, string Data) : string
	{
		if (service == null) return "Error: MetabaseJsonWsService binding is required.";
		JsonObject args = new JsonObject();
		args["FeatureName"] = FeatureName; args["Version"] = Version; args["IsEnabled"] = IsEnabled; args["SettingsAssembly"] = SettingsAssembly; args["SettingsClass"] = SettingsClass; args["Settings"] = StringUtil.IsEmpty(Settings) ? "{}" : Settings; args["Data"] = StringUtil.IsEmpty(Data) ? "{}" : Data;
		return service.CallMetabaseJsonWs("RooTrax.VDB.Features.ashx", "InsertFeature", args);
	}
}

[SemanticProgram.InfinitivePhrase("to materialize a roottrax metabase object through jsonws")]
[SemanticProgram.InfinitivePhrase("to implement a roottrax metabase object into project database through jsonws")]
prototype MetabaseFeatures_ImplementObjectIntoProjectDatabase : MetabaseJsonWsSkillAction
{
	Description = @"JsonWs wrapper over RooTrax.VDB.Features.ImplementObjectIntoProjectDatabase(ObjectID, ProjectID).";
	function Execute(MetabaseJsonWsService service, int ObjectID, int ProjectID) : string
	{
		if (service == null) return "Error: MetabaseJsonWsService binding is required.";
		if (ObjectID <= 0) return "Error: ObjectID must be > 0.";
		if (ProjectID <= 0) return "Error: ProjectID must be > 0.";
		JsonObject args = new JsonObject(); args["ObjectID"] = ObjectID; args["ProjectID"] = ProjectID;
		return service.CallMetabaseJsonWs("RooTrax.VDB.Features.ashx", "ImplementObjectIntoProjectDatabase", args);
	}
}

