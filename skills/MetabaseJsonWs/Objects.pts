[SemanticProgram.InfinitivePhrase("to insert a roottrax metabase object through jsonws")]
prototype MetabaseObjects_InsertObject : MetabaseJsonWsSkillAction
{
	Description = @"JsonWs wrapper over RooTrax.VDB.Objects.InsertObject(ObjectName, ObjectsName, FriendlyObjectName, FriendlyObjectsName, ApplicationID, Data).";
	function Execute(MetabaseJsonWsService service, string ObjectName, string ObjectsName, string FriendlyObjectName, string FriendlyObjectsName, int ApplicationID, string Data) : string
	{
		if (service == null) return "Error: MetabaseJsonWsService binding is required.";
		if (StringUtil.IsEmpty(ObjectName)) return "Error: ObjectName is required.";
		JsonObject args = new JsonObject();
		args["ObjectName"] = ObjectName; args["ObjectsName"] = ObjectsName; args["FriendlyObjectName"] = FriendlyObjectName; args["FriendlyObjectsName"] = FriendlyObjectsName; args["ApplicationID"] = ApplicationID; args["Data"] = StringUtil.IsEmpty(Data) ? "{}" : Data;
		return service.CallMetabaseJsonWs("RooTrax.VDB.Objects.ashx", "InsertObject", args);
	}
}

