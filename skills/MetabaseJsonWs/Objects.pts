[SemanticProgram.InfinitivePhrase("to get roottrax metabase objects through jsonws")]
prototype MetabaseObjects_GetAll : MetabaseJsonWsSkillAction
{
	Description = @"JsonWs wrapper over RooTrax.VDB.Objects.GetAll().";
	function Execute(MetabaseJsonWsService service) : string
	{
		if (service == null) return "Error: MetabaseJsonWsService binding is required.";
		return service.CallMetabaseJsonWs("RooTrax.VDB.Objects.ashx", "GetAll", new JsonObject());
	}
}

