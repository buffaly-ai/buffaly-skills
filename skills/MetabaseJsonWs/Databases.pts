[SemanticProgram.InfinitivePhrase("to insert roottrax metabase database metadata through jsonws")]
prototype MetabaseDatabases_InsertDatabase : MetabaseJsonWsSkillAction
{
	Description = @"JsonWs wrapper over RooTrax.VDB.Databases.InsertDatabase(...).";
	function Execute(MetabaseJsonWsService service, string DatabaseName, string DatabaseHandle, string ConnectionHandleReadWrite, string ConnectionHandleReadOnly, string ConnectionHandleAdmin, string Data) : string
	{
		if (service == null) return "Error: MetabaseJsonWsService binding is required.";
		JsonObject args = new JsonObject();
		args["DatabaseName"] = DatabaseName; args["DatabaseHandle"] = DatabaseHandle; args["ConnectionHandleReadWrite"] = ConnectionHandleReadWrite; args["ConnectionHandleReadOnly"] = ConnectionHandleReadOnly; args["ConnectionHandleAdmin"] = ConnectionHandleAdmin; args["Data"] = StringUtil.IsEmpty(Data) ? "{}" : Data;
		return service.CallMetabaseJsonWs("RooTrax.VDB.Databases.ashx", "InsertDatabase", args);
	}
}

