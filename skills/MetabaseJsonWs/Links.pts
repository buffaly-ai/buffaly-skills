[SemanticProgram.InfinitivePhrase("to insert roottrax metabase project feature link through jsonws")]
prototype MetabaseProjectFeatures_InsertProjectFeature : MetabaseJsonWsSkillAction
{
	Description = @"JsonWs wrapper over RooTrax.VDB.ProjectFeatures.InsertProjectFeature(ProjectID, FeatureID, Data).";
	function Execute(MetabaseJsonWsService service, int ProjectID, int FeatureID, string Data) : string
	{
		if (service == null) return "Error: MetabaseJsonWsService binding is required.";
		JsonObject args = new JsonObject(); args["ProjectID"] = ProjectID; args["FeatureID"] = FeatureID; args["Data"] = StringUtil.IsEmpty(Data) ? "{}" : Data;
		return service.CallMetabaseJsonWs("RooTrax.VDB.ProjectFeatures.ashx", "InsertProjectFeature", args);
	}
}

