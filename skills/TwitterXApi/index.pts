reference System.Net.Http System.Net.Http;
reference XApiClient.Core XApiClient.Core;

include "PromptActions.pts";

import XApiClient.Core XApiClient.Core.XClient XClient;
import XApiClient.Core XApiClient.Core.Authentication.XCredentials XCredentials;
import System.Net.Http System.Net.Http.HttpClient HttpClient;
import BasicUtilities BasicUtilities.JsonObject JsonObject;
import BasicUtilities BasicUtilities.JsonArray JsonArray;
import Buffaly.Agent.Tools.Secrets Buffaly.Agent.Tools.Secrets.TwitterXApiSecretsFeature TwitterXApiSecretsFeature;
import mscorlib System.Threading.CancellationToken CancellationToken;
import mscorlib System.IO.File File;

prototype TwitterXApiSkillAction : OpsAction
{
	Description = @"Base action type for Twitter/X API skill tools.";
}

[SemanticEntity("twitter x api skill")]
[SemanticEntity("x api skill")]
prototype TwitterXApiSkill : SkillEntity
{
	Description = "Twitter/X API actions for search, profile, timeline, mentions, and posting.";
	ActionRoot = TwitterXApiSkillAction;
}

function ToNormalizeXMaxResults(int maxResults) : int
{
	if (maxResults < 1)
	{
		return 10;
	}
	if (maxResults > 100)
	{
		return 100;
	}
	return maxResults;
}

function ToNormalizePaginationToken(string paginationToken) : string
{
	if (paginationToken == null)
	{
		return "";
	}
	return paginationToken;
}

function ToCreateXCredentialsForSearch() : XCredentials
{
	XCredentials credentials = new XCredentials();
	credentials.ClientId = TwitterXApiSecretsFeature.Feature.ClientId;
	credentials.ClientSecret = TwitterXApiSecretsFeature.Feature.ClientSecret;
	credentials.BearerToken = TwitterXApiSecretsFeature.Feature.BearerToken;
	credentials.AccessToken = TwitterXApiSecretsFeature.Feature.AccessToken;
	credentials.RefreshToken = TwitterXApiSecretsFeature.Feature.RefreshToken;
	credentials.Scopes = TwitterXApiSecretsFeature.Feature.Scopes;
	return credentials;
}

function ToCreateXCredentialsForUserContext() : XCredentials
{
	XCredentials credentials = new XCredentials();
	credentials.ClientId = TwitterXApiSecretsFeature.Feature.ClientId;
	credentials.ClientSecret = TwitterXApiSecretsFeature.Feature.ClientSecret;
	credentials.BearerToken = TwitterXApiSecretsFeature.Feature.BearerToken;
	credentials.AccessToken = TwitterXApiSecretsFeature.Feature.AccessToken;
	credentials.RefreshToken = TwitterXApiSecretsFeature.Feature.RefreshToken;
	credentials.Scopes = TwitterXApiSecretsFeature.Feature.Scopes;
	return credentials;
}

function ToTryReadXUserId(string jsonText) : string
{
	// Parse GetMe payload shape and return data.id when present.
	try
	{
		JsonObject root = new JsonObject(jsonText);
		JsonObject data = root.GetJsonObjectOrDefault("data");
		return data.GetStringOrNull("id") ?? "";
	}
	catch
	{
		return "";
	}
}

function ToGetCurrentXUserId(XClient xApiClient) : string
{
	string meRawJson = xApiClient.GetMeAsync(new CancellationToken(false)).RawJson;
	if (StringUtil.IsEmpty(meRawJson))
	{
		return "";
	}

	string userId = ToTryReadXUserId(meRawJson);
	if (!StringUtil.IsEmpty(userId))
		return userId;

	// Some runtimes pass JSON as a quoted/escaped JSON string; normalize and parse a second time.
	string normalizedJson = meRawJson.Replace("\\\"", "\"");
	normalizedJson = normalizedJson.Replace("\"{", "{");
	normalizedJson = normalizedJson.Replace("}\"", "}");

	userId = ToTryReadXUserId(normalizedJson);
	if (!StringUtil.IsEmpty(userId))
		return userId;

	return "";
}

[SemanticProgram.InfinitivePhrase("to debug x get me parsing")]
prototype ToDebugXGetMeParsing : TwitterXApiSkillAction
{
	Description = @"Returns raw GetMe JSON and parsed user-id attempts for parser diagnostics.";

	function Execute() : string
	{
		XCredentials credentials = ToCreateXCredentialsForUserContext();
		HttpClient xHttpClient = new HttpClient();
		XClient xApiClient = new XClient(xHttpClient, credentials, null);

		string meRawJson = xApiClient.GetMeAsync(new CancellationToken(false)).RawJson;
		string idFromRawObject = ToTryReadXUserId(meRawJson);

		string normalizedJson = meRawJson.Replace("\\\"", "\"");
		normalizedJson = normalizedJson.Replace("\"{", "{");
		normalizedJson = normalizedJson.Replace("}\"", "}");
		string idFromNormalizedObject = ToTryReadXUserId(normalizedJson);

		return
			"idFromRawObject: " + idFromRawObject + "\n" +
			"idFromNormalizedObject: " + idFromNormalizedObject + "\n" +
			"rawJson:\n" + meRawJson + "\n" +
			"normalizedJson:\n" + normalizedJson;
	}
}

[SemanticProgram.InfinitivePhrase("to search recent posts on x")]
[SemanticProgram.InfinitivePhrase("to search twitter recent posts")]
prototype ToSearchXRecentPosts : TwitterXApiSkillAction
{
	Description = @"query - X recent search query.
	maxResults - result count between 1 and 100.
	paginationToken - pass empty for first page, or the token from a prior response for next page.";

	function Execute(string query, int maxResults, string paginationToken) : string
	{
		if (StringUtil.IsEmpty(query))
		{
			return "Error: query is required.";
		}
		maxResults = ToNormalizeXMaxResults(maxResults);
		paginationToken = ToNormalizePaginationToken(paginationToken);

		// Search can run with bearer token auth.
		XCredentials credentials = ToCreateXCredentialsForSearch();

		HttpClient xHttpClient = new HttpClient();
		XClient xApiClient = new XClient(xHttpClient, credentials, null);

		string response = xApiClient.SearchRecentAsync(query, maxResults, paginationToken, new CancellationToken(false)).RawJson;
		return response;
	}
}

[SemanticProgram.InfinitivePhrase("to get my x profile")]
[SemanticProgram.InfinitivePhrase("to get my twitter profile")]
prototype ToGetXMe : TwitterXApiSkillAction
{
	Description = @"Returns the authenticated X account profile JSON.";

	function Execute() : string
	{
		// User profile requires OAuth user-context credentials.
		XCredentials credentials = ToCreateXCredentialsForUserContext();

		HttpClient xHttpClient = new HttpClient();
		XClient xApiClient = new XClient(xHttpClient, credentials, null);

		string response = xApiClient.GetMeAsync(new CancellationToken(false)).RawJson;
		return response;
	}
}

[SemanticProgram.InfinitivePhrase("to get x home timeline")]
[SemanticProgram.InfinitivePhrase("to get twitter home timeline")]
prototype ToGetXHomeTimeline : TwitterXApiSkillAction
{
	Description = @"maxResults - result count between 1 and 100.
	paginationToken - pass empty for first page, or the token from a prior response for next page.";

	function Execute(int maxResults, string paginationToken) : string
	{
		maxResults = ToNormalizeXMaxResults(maxResults);
		paginationToken = ToNormalizePaginationToken(paginationToken);

		// Timelines require OAuth user-context credentials.
		XCredentials credentials = ToCreateXCredentialsForUserContext();

		HttpClient xHttpClient = new HttpClient();
		XClient xApiClient = new XClient(xHttpClient, credentials, null);
		string userId = ToGetCurrentXUserId(xApiClient);
		if (StringUtil.IsEmpty(userId))
		{
			return "Error: unable to resolve current X user id from GetMe.";
		}

		string response = xApiClient.GetHomeTimelineAsync(userId, maxResults, paginationToken, new CancellationToken(false)).RawJson;
		return response;
	}
}

