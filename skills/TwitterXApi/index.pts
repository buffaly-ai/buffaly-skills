[SemanticProgram.InfinitivePhrase("to post a tweet on x")]
[SemanticProgram.InfinitivePhrase("to post on twitter")]
prototype ToPostXTweet : TwitterXApiSkillAction
{
	Description = @"text - tweet content to post.";

	function Execute(string text) : string
	{
		if (StringUtil.IsEmpty(text))
		{
			return "Error: text is required.";
		}

		// Posting requires OAuth user-context credentials.
		XCredentials credentials = ToCreateXCredentialsForUserContext();

		HttpClient xHttpClient = new HttpClient();
		XClient xApiClient = new XClient(xHttpClient, credentials, null);

		string response = xApiClient.PostTweetAsync(text, new CancellationToken(false)).RawJson;
		return response;
	}
}
[SemanticProgram.InfinitivePhrase("to post a tweet with media on x")]
[SemanticProgram.InfinitivePhrase("to post on twitter with media")]
prototype ToPostXTweetWithMedia : TwitterXApiSkillAction
{
	Description = @"text - tweet content to post.
	mediaFilePath - local file path for one image/video media attachment.";

	function Execute(string text, string mediaFilePath) : string
	{
		if (StringUtil.IsEmpty(text))
		{
			return "Error: text is required.";
		}

		if (StringUtil.IsEmpty(mediaFilePath))
		{
			return "Error: mediaFilePath is required.";
		}

		if (!File.Exists(mediaFilePath))
		{
			return "Error: media file does not exist: " + mediaFilePath;
		}

		// Posting requires OAuth user-context credentials.
		XCredentials credentials = ToCreateXCredentialsForUserContext();

		HttpClient xHttpClient = new HttpClient();
		XClient xApiClient = new XClient(xHttpClient, credentials, null);

		string response = xApiClient.PostTweetWithMediaFileRawJsonAsync(text, mediaFilePath, new CancellationToken(false));
		return response;
	}
}



[SemanticProgram.InfinitivePhrase("to post a twitter thread")]
[SemanticProgram.InfinitivePhrase("to post an x thread")]
prototype ToPostXThread : TwitterXApiSkillAction
{
	Description = @"threadJson - JSON array of tweet texts. Posts the first tweet, then posts each later item as a reply to the prior tweet.";

	function Execute(string threadJson) : string
	{
		if (StringUtil.IsEmpty(threadJson))
		{
			return "Error: threadJson is required.";
		}

		JsonArray tweets = new JsonArray(threadJson);
		if (tweets.Count == 0)
		{
			return "Error: threadJson must contain at least one tweet text.";
		}

		XCredentials credentials = ToCreateXCredentialsForUserContext();
		HttpClient xHttpClient = new HttpClient();
		XClient xApiClient = new XClient(xHttpClient, credentials, null);

		string previousTweetId = "";
		JsonArray results = new JsonArray();
		for (int i = 0; i < tweets.Count; i++)
		{
			string tweetText = tweets.GetString(i);
			if (StringUtil.IsEmpty(tweetText))
			{
				return "Error: tweet text at index " + i + " is required.";
			}

			string rawJson = "";
			if (StringUtil.IsEmpty(previousTweetId))
			{
				rawJson = xApiClient.PostTweetRawJsonAsync(tweetText, new CancellationToken(false));
			}
			else
			{
				rawJson = xApiClient.PostTweetReplyRawJsonAsync(tweetText, previousTweetId, new CancellationToken(false));
			}

			JsonObject response = new JsonObject(rawJson);
			JsonObject data = response.GetJsonObjectOrDefault("data");
			previousTweetId = data.GetStringOrNull("id") ?? "";
			if (StringUtil.IsEmpty(previousTweetId))
			{
				return "Error: X post response at index " + i + " did not include data.id. Raw response: " + rawJson;
			}

			results.Add(response);
		}

		return results.ToString();
	}
}

