[SemanticProgram.InfinitivePhrase("to export the basic csv walkthrough current view")]
[SemanticProgram.InfinitivePhrase("export current view")]
prototype ToExportBasicCsvWalkthroughCurrentView : HelpAgentActionRoot
{
	Description = @"Export the validated Ready appointments view for the Basic CSV walkthrough after the user confirms export. Uses shared CsvDataSource and TabularData helpers.";

	function Execute() : string
	{
		if (_opsAgent == null)
		{
			throw "_opsAgent runtime is not available.";
		}

		string sessionDirectory = _opsAgent.GetCurrentSessionDirectory();
		if (StringUtil.IsEmpty(sessionDirectory))
		{
			throw "Current session directory is not available.";
		}

		string artifactRelativeDirectory = "artifacts/exports/basic-csv";
		string outputDirectory = Path.Combine(sessionDirectory, artifactRelativeDirectory);
		string outputPath = Path.Combine(outputDirectory, "ready-appointments.csv");
		DataTable table = BasicCsvWalkthroughGrid.LoadSampleTable();
		DataTable filtered = TabularDataFunctions.FilterRows(table, @"[{""Column"":""Status"",""Operator"":""Equals"",""Value"":""Ready""}]");
		DataTable sorted = TabularDataFunctions.SortRows(filtered, @"[{""Column"":""AppointmentDate"",""Direction"":""Ascending""}]");
		TabularDataFunctions.SaveCsvFile(sorted, outputPath);
		return "Exported ready-appointments.csv to " + artifactRelativeDirectory + "/ready-appointments.csv with " + sorted.Rows.Count + " rows.";
	}
}

prototype BasicCsvWalkthroughGrid : SemanticEntityBase
{
	Description = @"Thin Basic CSV walkthrough helpers composed from CsvDataSourceFunctions and TabularDataFunctions. Tabular methods return native DataTable references rather than preview JSON.";

	function LoadSampleTable() : DataTable
	{
		return CsvDataSourceFunctions.LoadCsvFile(BasicCsvWalkthroughGrid.GetSampleCsvPath());
	}

	function GetSampleCsvPath() : string
	{
		string sessionDirectory = _opsAgent.GetCurrentSessionDirectory();
		if (StringUtil.IsEmpty(sessionDirectory))
		{
			throw "Current session directory is not available.";
		}

		return Path.Combine(Path.Combine(Path.Combine(Path.Combine(Path.Combine(Path.Combine(Path.Combine(sessionDirectory, ".."), ".."), ".."), "app"), "agent-web"), "wwwroot"), "samples/data/sample-patient-appointments.csv");
	}

	function ReadyAppointments() : DataTable
	{
		DataTable filtered = TabularDataFunctions.FilterRows(BasicCsvWalkthroughGrid.LoadSampleTable(), @"[{""Column"":""Status"",""Operator"":""Equals"",""Value"":""Ready""}]");
		DataTable sorted = TabularDataFunctions.SortRows(filtered, @"[{""Column"":""AppointmentDate"",""Direction"":""Ascending""}]");
		return sorted;
	}

	function HighPriorityAppointments() : DataTable
	{
		DataTable filtered = TabularDataFunctions.FilterRows(BasicCsvWalkthroughGrid.LoadSampleTable(), @"[{""Column"":""Priority"",""Operator"":""Equals"",""Value"":""High""}]");
		DataTable sorted = TabularDataFunctions.SortRows(filtered, @"[{""Column"":""AppointmentDate"",""Direction"":""Ascending""}]");
		return sorted;
	}

	function CardiologyBalanceDueAppointments() : DataTable
	{
		DataTable filtered = TabularDataFunctions.FilterRows(BasicCsvWalkthroughGrid.LoadSampleTable(), @"[{""Column"":""Department"",""Operator"":""Equals"",""Value"":""Cardiology""},{""Column"":""BalanceDue"",""Operator"":""GreaterThan"",""Value"":""0.01""}]");
		DataTable sorted = TabularDataFunctions.SortRows(filtered, @"[{""Column"":""BalanceDue"",""Direction"":""Descending""}]");
		return sorted;
	}

	function Next30DaysNotCancelledAppointments() : DataTable
	{
		DataTable filtered = TabularDataFunctions.FilterRows(BasicCsvWalkthroughGrid.LoadSampleTable(), @"[{""Column"":""AppointmentDate"",""Operator"":""GreaterThanOrEqual"",""Value"":""2026-06-01""},{""Column"":""AppointmentDate"",""Operator"":""LessThanOrEqual"",""Value"":""2026-06-30""},{""Column"":""Status"",""Operator"":""NotEquals"",""Value"":""Cancelled""}]");
		DataTable sorted = TabularDataFunctions.SortRows(filtered, @"[{""Column"":""AppointmentDate"",""Direction"":""Ascending""}]");
		return sorted;
	}

	function MedicareOver250Appointments() : DataTable
	{
		DataTable filtered = TabularDataFunctions.FilterRows(BasicCsvWalkthroughGrid.LoadSampleTable(), @"[{""Column"":""InsuranceType"",""Operator"":""Equals"",""Value"":""Medicare""},{""Column"":""EstimatedCost"",""Operator"":""GreaterThanOrEqual"",""Value"":""250""}]");
		DataTable sorted = TabularDataFunctions.SortRows(filtered, @"[{""Column"":""EstimatedCost"",""Direction"":""Descending""}]");
		return sorted;
	}

	function AppointmentsByClinic() : DataTable
	{
		return TabularDataFunctions.GroupCount(BasicCsvWalkthroughGrid.LoadSampleTable(), @"[""Clinic""]");
	}

	function ReadyAppointmentsByClinic() : DataTable
	{
		return TabularDataFunctions.GroupCount(BasicCsvWalkthroughGrid.ReadyAppointments(), @"[""Clinic""]");
	}
}
prototype HelpAgentSkill : SkillEntity, CoreEntity
{
	EntityName = "Buffaly Help Agent skill";
	Description = "Documentation assistance and approved guided walkthrough root for the Buffaly Help Agent.";
	ActionRoot = HelpAgentActionRoot;
}
