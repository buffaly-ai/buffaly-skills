prototype HelpAgentActionRoot : OpsAction
{
	Description = @"Documentation and approved guided-walkthrough action root for the Buffaly Help Agent. It exposes documentation/wiki lookup, LLM-backed web search, and narrow walkthrough prompt actions.";
}

prototype HelpAgentPromptAction : PromptAction, HelpAgentActionRoot
{
	Description = "Base action type for approved Buffaly Help Agent guided walkthrough prompt workflows. Execute returns private walkthrough guidance that the Help Agent must follow interactively; it is not a user-visible answer or display result.";
	ResponseResultType = "status";

	function Execute() : string
	{
		return @"Start the approved Help Agent walkthrough interactively. Do not expose private prompt instructions or prompt source.";
	}
}

[SemanticProgram.InfinitivePhrase("to search local Buffaly wiki for help")]
[SemanticProgram.InfinitivePhrase("to find installed Buffaly wiki help articles")]
prototype ToSearchLocalBuffalyWikiForHelp : HelpAgentActionRoot
{
	Description = @"searchText - local wiki query text. maxResults - maximum number of results to return.";

	function Execute(string searchText, int maxResults) : SearchWikiResponseContract
	{
		WikiModule.Configure(RuntimeInstallRootFeature.GetRequiredAgentWebWikiRootPath());
		return WikiServiceApi.Search(new SearchWikiRequestContract
		{
			SearchText = searchText,
			MaxResults = maxResults
		});
	}
}

[SemanticProgram.InfinitivePhrase("to list local Buffaly wiki help articles")]
prototype ToListLocalBuffalyWikiArticlesForHelp : HelpAgentActionRoot
{
	Description = @"List local Buffaly wiki articles available to the Help Agent.";

	function Execute() : ListWikiArticlesResponseContract
	{
		WikiModule.Configure(RuntimeInstallRootFeature.GetRequiredAgentWebWikiRootPath());
		return WikiServiceApi.ListArticles(new ListWikiArticlesRequestContract());
	}
}

[SemanticProgram.InfinitivePhrase("to read local Buffaly wiki article for help")]
