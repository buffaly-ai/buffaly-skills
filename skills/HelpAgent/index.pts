[SemanticProgram.InfinitivePhrase("to save the Write Professional Emails prompt skill from the Help Agent walkthrough")]
[SemanticProgram.InfinitivePhrase("to create the WriteProfessionalEmails prompt skill")]
prototype ToSaveWriteProfessionalEmailsPromptSkillFromWalkthrough : HelpAgentActionRoot
{
	Description = @"Create or update the default WriteProfessionalEmails Prompt Skill from the approved Help Agent walkthrough. This narrow save action writes only the tutorial prompt skill artifacts under Nodes/Personal/PromptSkills.";

	function Execute() : string
	{
		if (_opsAgent != null)
			return CoreOntologyTools.UpsertPromptActionArtifactsInCurrentProject(
				_opsAgent,
				@"Nodes/Personal/PromptSkills/PromptActions.pts",
				@"[SemanticProgram.InfinitivePhrase(""to write a professional email"")]
[SemanticProgram.InfinitivePhrase(""to draft a professional email"")]
[SemanticProgram.InfinitivePhrase(""to write a polished email about this"")]
prototype WriteProfessionalEmails : PromptAction
{
	SkillKind = ""prompt"";
	SkillVersion = ""1.0.0"";
	PromptPath = @""Nodes/Personal/PromptSkills/Prompts/WriteProfessionalEmails.prompt.md"";
	Description = ""Write clear, concise, professional emails from a topic, audience, tone, and key facts."";
}",
				@"Nodes/Personal/PromptSkills/Prompts/WriteProfessionalEmails.prompt.md",
				@"# Write Professional Emails

Write clear, concise, professional emails.

When the user asks for an email, use or ask for:

- who the email is for
- what the email is about
- the desired tone
- any key facts to include

Rules:

- preserve the user's facts
- do not invent details
- return a subject line and email body
- ask one focused question if important details are missing
");

		return "Error: _opsAgent runtime is not available.";
	}
}

