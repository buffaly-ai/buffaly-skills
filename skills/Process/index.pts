import Buffaly.Agent.Runtime.Abstractions Buffaly.Agent.Runtime.Abstractions.LiveToolInputCollectionRequestContract LiveToolInputCollectionRequestContract;
import Buffaly.Agent.Runtime.Abstractions Buffaly.Agent.Runtime.Abstractions.LiveToolInputCollectionResultContract LiveToolInputCollectionResultContract;
import Buffaly.Agent.Runtime.Abstractions Buffaly.Agent.Runtime.Abstractions.RuntimeUiEventOutputContract RuntimeUiEventOutputContract;
import Buffaly.Agent.Tools.Process Buffaly.Agent.Tools.Process.ProcessToolDisplayOptions ProcessToolDisplayOptions;
prototype ProcessSkillAction : OpsAction
{
	Description = @"Base action type for process/system command execution tools.";
}

[SemanticEntity("process skill")]
prototype ProcessSkill : SkillEntity
{
	Description = "Command-line and PowerShell execution tools backed by Buffaly.Agent.Tools.Process SystemOperations.";
	ActionRoot = ProcessSkillAction;
}

function ToProcessSkillIsDisallowedBuffalySessionHttpPowerShellScript(string script) : bool
{
	if (StringUtil.IsEmpty(script))
		return false;
	return false;
}

function ToProcessSkillBuildPowerShellStreamLabel(string workingDirectory) : string
{
	if (StringUtil.IsEmpty(workingDirectory))
	{
		return "PowerShell";
	}

	return "PowerShell - " + workingDirectory;
}

function ToProcessSkillBuildCommandStreamLabel(string command) : string
{
	if (StringUtil.IsEmpty(command))
	{
		return "Command";
	}

	return "Command - " + command;
}

function ToProcessSkillLooksLikeShellSyntax(string commandLineArguments) : bool
{
	if (StringUtil.IsEmpty(commandLineArguments))
		return false;

	if (commandLineArguments.Contains("|"))
		return true;
	if (commandLineArguments.Contains("&&"))
		return true;
	if (commandLineArguments.Contains(";"))
		return true;
	if (commandLineArguments.Contains(">"))
		return true;
	if (commandLineArguments.Contains("<"))
		return true;
	if (commandLineArguments.Contains("`"))
		return true;
	if (commandLineArguments.Contains("$("))
		return true;

	return false;
}

function ToProcessSkillDirectCommandShellSyntaxDiagnostic(string toolName) : string
{
	return "Error: " + toolName + " runs an executable directly and does not interpret shell syntax. Use ToExecuteUnixShellOperationWithTimeout on macOS/Linux for Bash syntax, ToExecuteWindowsCommandShellOperationWithTimeout on Windows for cmd.exe syntax, or ToExecuteProcessWithArgumentsAndEnvironment for shell-free argv execution.";
}

[SemanticProgram.InfinitivePhrase("to execute a command line operation and return the output")]
prototype ToExecuteCommandLineOperation : ProcessSkillAction
{
	Description = @"command - full path to the executable
commandLineArguments - arguments to pass to the command. This is direct executable execution, not a shell; do not pass pipes, redirects, command chaining, or shell built-ins here. Use ToExecuteUnixShellOperationWithTimeout on macOS/Linux, ToExecuteWindowsCommandShellOperationWithTimeout on Windows, or ToExecuteProcessWithArgumentsAndEnvironment for shell-free argv execution. Uses a default timeout of 30 seconds. Returns command + arguments + output for diagnostics.";

	function Execute(string command, string commandLineArguments) : string
	{
		if (ToProcessSkillLooksLikeShellSyntax(commandLineArguments))
		{
			return ToProcessSkillDirectCommandShellSyntaxDiagnostic("ToExecuteCommandLineOperation");
		}

		// Run the command line operation with a safe default timeout and return its output.
		return SystemOperations.RunCommandLineWithTimeout(command, commandLineArguments, 30);
	}
}

[SemanticProgram.InfinitivePhrase("to execute a command line operation with a timeout and return the output")]
prototype ToExecuteCommandLineOperationWithTimeout : ProcessSkillAction
{
	Description = @"command - full path to the executable
commandLineArguments - arguments to pass to the command
timeoutSeconds - maximum runtime in seconds (defaults to 30 when <= 0). This is direct executable execution, not a shell; do not pass pipes, redirects, command chaining, or shell built-ins here. Use ToExecuteUnixShellOperationWithTimeout on macOS/Linux, ToExecuteWindowsCommandShellOperationWithTimeout on Windows, or ToExecuteProcessWithArgumentsAndEnvironment for shell-free argv execution. Returns command + arguments + output for diagnostics.";

	function Execute(string command, string commandLineArguments, int timeoutSeconds) : string
	{
		if (ToProcessSkillLooksLikeShellSyntax(commandLineArguments))
		{
			return ToProcessSkillDirectCommandShellSyntaxDiagnostic("ToExecuteCommandLineOperationWithTimeout");
		}

		// Run the command line operation with caller-provided timeout and return its output.
		if (timeoutSeconds <= 0)
		{
			timeoutSeconds = 30;
		}

		return SystemOperations.RunCommandLineWithTimeout(command, commandLineArguments, timeoutSeconds, _opsAgent, "", ToProcessSkillBuildCommandStreamLabel(command));
	}
}

[SemanticProgram.InfinitivePhrase("to execute a PowerShell script and return the output")]
prototype ToExecutePowerShellOperation : ProcessSkillAction
{
	Description = @"script - PowerShell script to execute (default timeout: 60 seconds). For longer-running commands, use ToExecutePowerShellOperationWithTimeout. Do not use this tool to call BuffalyAgentService evaluate endpoints; use typed session tools instead.";

	function Execute(string script) : string
	{
		if (ToProcessSkillIsDisallowedBuffalySessionHttpPowerShellScript(script))
		{
			return "Error: Direct PowerShell HTTP calls to BuffalyAgentService evaluate endpoints are disabled. Use typed session tools (for example ToCreateBuffalySession / SessionTools) with canonical input shape.";
		}

		// Run the PowerShell script, mirror stdout/stderr to the active browser session, and return its final output.
		return SystemOperations.RunPowerShellStreamingToRuntimeUi(script, "", 60, _opsAgent, "", ToProcessSkillBuildPowerShellStreamLabel(""));
	}
}

