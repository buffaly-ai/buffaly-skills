[SemanticProgram.InfinitivePhrase("to emit a runtime UI event to the browser websocket")]
prototype ToEmitRuntimeUiEvent : ProcessSkillAction
{
	Description = @"eventType - typed runtime UI event name to emit
payloadJson - JSON object payload to send to the active browser session websocket. Returns the generated event id.";

	function Execute(string eventType, string payloadJson) : string
	{
		// Send one typed runtime UI event through the active agent websocket bridge.
		return _opsAgent.EmitRuntimeUiEvent(eventType, payloadJson);
	}
}

[SemanticProgram.InfinitivePhrase("to execute a PowerShell script and stream console output to the browser websocket")]
prototype ToExecuteStreamingPowerShellOperationWithTimeout : ProcessSkillAction
{
	Description = @"script - PowerShell script to execute
workingDirectory - working directory to apply before script execution
timeoutSeconds - maximum runtime in seconds (defaults to 60 when <= 0)
streamId - optional stable console stream id; generated when empty
commandLabel - optional display label for the visible console stream. Streams stdout/stderr to the active browser session as console-output runtime UI events while returning final captured output.";

	function Execute(string script, string workingDirectory, int timeoutSeconds, string streamId, string commandLabel) : string
	{
		if (ToProcessSkillIsDisallowedBuffalySessionHttpPowerShellScript(script))
		{
			return "Error: Direct PowerShell HTTP calls to BuffalyAgentService evaluate endpoints are disabled. Use typed session tools (for example ToCreateBuffalySession / SessionTools) with canonical input shape.";
		}

		if (timeoutSeconds <= 0)
		{
			timeoutSeconds = 60;
		}

		return SystemOperations.RunPowerShellStreamingToRuntimeUi(script, workingDirectory, timeoutSeconds, _opsAgent, streamId, commandLabel);
	}
}

[SemanticProgram.InfinitivePhrase("to run GitHub auth login with the tool window opened for the login code")]
prototype ToRunGitHubAuthLoginWithVisibleOutput : ProcessSkillAction
{
	Description = @"Runs gh auth login with the tool window explicitly opened so the user can see the browser/device login instructions immediately.
timeoutSeconds - maximum runtime in seconds (defaults to 180 when <= 0). Uses an isolated GH_CONFIG_DIR when ghConfigDirectory is provided; otherwise uses the current GitHub CLI config.";

	function Execute(int timeoutSeconds, string ghConfigDirectory) : string
	{
		if (timeoutSeconds <= 0)
		{
			timeoutSeconds = 180;
		}

		string script = "gh auth login";
		if (!StringUtil.IsEmpty(ghConfigDirectory))
		{
			script = "$env:GH_CONFIG_DIR = '" + ghConfigDirectory.Replace("'", "''") + "'\n" + script;
		}

		ProcessToolDisplayOptions displayOptions = new ProcessToolDisplayOptions
		{
			CommandLabel = "gh auth login",
			ForceOpenToolWindow = true,
			DisplayMode = "focused-popup",
			DisplayTitle = "GitHub authentication",
			DisplayMessage = "Watch this output for the GitHub login code."
		};

		return SystemOperations.RunPowerShellStreamingToRuntimeUi(script, "", timeoutSeconds, _opsAgent, displayOptions);
	}
}
[SemanticProgram.InfinitivePhrase("to run a live tool input round trip test")]
prototype ToRunLiveToolInputRoundTripTest : ProcessSkillAction
{
	Description = @"Prompts the active browser tool card for one line of input, waits inside the active ProtoScript invocation for the submitted value, then emits follow-up runtime UI output and returns the received value. This proves the Phase 4 UI-to-ProtoScript round trip.";

	function Execute(string prompt, int timeoutSeconds) : string
	{
		if (StringUtil.IsEmpty(prompt))
		{
			prompt = "Type a value and submit it back to ProtoScript.";
		}

		if (timeoutSeconds <= 0)
		{
			timeoutSeconds = 120;
		}

		_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
		{
			EventType = "tool-channel-output",
			Stream = "stdout",
			Text = "Starting live input round trip from ProtoScript.\n",
			Command = "Live tool input round trip"
		});

		LiveToolInputCollectionResultContract inputResult = _opsAgent.CollectLiveToolInput(new LiveToolInputCollectionRequestContract
		{
			InputKind = "line",
			Prompt = prompt,
			Required = true,
			IsSensitive = false,
			TimeoutSeconds = timeoutSeconds
		});

		if (StringUtil.IsEmpty(inputResult.Value))
		{
			_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
			{
				EventType = "tool-channel-output",
				Stream = "stderr",
				Text = "Input collection ended with status: " + inputResult.Status + "\n",
				Command = "Live tool input round trip"
			});

			return "Input round trip failed with status: " + inputResult.Status;
		}

		string value = inputResult.Value;

		_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
		{
			EventType = "tool-channel-output",
			Stream = "stdout",
			Text = "ProtoScript resumed with input: " + value + "\n",
			Command = "Live tool input round trip"
		});

		_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
		{
			EventType = "tool-channel-output",
			Stream = "stdout",
			Text = "Input length: " + value.Length.ToString() + "\n",
			Command = "Live tool input round trip"
		});

		return "Round trip complete. ProtoScript received: " + value;
	}
}

[SemanticProgram.InfinitivePhrase("to run a multi step live tool input coordination test")]
prototype ToRunMultiStepLiveToolInputCoordinationTest : ProcessSkillAction
{
	Description = @"Runs a multi-step live tool input coordination test. The active tool card asks for several browser-provided inputs, emits output after each submitted value, then returns a summary. Use this to validate repeated UI-to-ProtoScript input collection and output streaming in one tool invocation.";

	function Execute(int timeoutSeconds) : string
	{
		if (timeoutSeconds <= 0)
		{
			timeoutSeconds = 180;
		}

		_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
		{
			EventType = "tool-channel-output",
			Stream = "stdout",
			Text = "Starting multi-step live input coordination test.\n",
			Command = "Multi-step live input coordination test"
		});

		LiveToolInputCollectionResultContract nameResult = _opsAgent.CollectLiveToolInput(new LiveToolInputCollectionRequestContract
		{
			InputKind = "line",
			Prompt = "Step 1/3: enter your name or initials.",
			Required = true,
			IsSensitive = false,
			TimeoutSeconds = timeoutSeconds
		});

		if (StringUtil.IsEmpty(nameResult.Value))
		{
			_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
			{
				EventType = "tool-channel-output",
				Stream = "stderr",
				Text = "Step 1 did not receive input. Status: " + nameResult.Status + "\n",
				Command = "Multi-step live input coordination test"
			});

			return "Multi-step test stopped at step 1 with status: " + nameResult.Status;
		}

		string name = nameResult.Value;
		_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
		{
			EventType = "tool-channel-output",
			Stream = "stdout",
			Text = "Step 1 accepted. Hello, " + name + ".\n",
			Command = "Multi-step live input coordination test"
		});

		LiveToolInputCollectionResultContract projectResult = _opsAgent.CollectLiveToolInput(new LiveToolInputCollectionRequestContract
		{
			InputKind = "line",
			Prompt = "Step 2/3: enter a short project or task name.",
			Required = true,
			IsSensitive = false,
			TimeoutSeconds = timeoutSeconds
		});

		if (StringUtil.IsEmpty(projectResult.Value))
		{
			_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
			{
				EventType = "tool-channel-output",
				Stream = "stderr",
				Text = "Step 2 did not receive input. Status: " + projectResult.Status + "\n",
				Command = "Multi-step live input coordination test"
			});

			return "Multi-step test stopped at step 2 with status: " + projectResult.Status;
		}

		string project = projectResult.Value;
		_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
		{
			EventType = "tool-channel-output",
			Stream = "stdout",
			Text = "Step 2 accepted. Project/task: " + project + ".\n",
			Command = "Multi-step live input coordination test"
		});

		LiveToolInputCollectionResultContract confirmationResult = _opsAgent.CollectLiveToolInput(new LiveToolInputCollectionRequestContract
		{
			InputKind = "line",
			Prompt = "Step 3/3: type CONFIRM to finish the coordination test.",
			Required = true,
			IsSensitive = false,
			TimeoutSeconds = timeoutSeconds
		});

		if (StringUtil.IsEmpty(confirmationResult.Value))
		{
			_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
			{
				EventType = "tool-channel-output",
				Stream = "stderr",
				Text = "Step 3 did not receive input. Status: " + confirmationResult.Status + "\n",
				Command = "Multi-step live input coordination test"
			});

			return "Multi-step test stopped at step 3 with status: " + confirmationResult.Status;
		}

		string confirmation = confirmationResult.Value;
		_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
		{
			EventType = "tool-channel-output",
			Stream = "stdout",
			Text = "Step 3 accepted. Confirmation value: " + confirmation + ".\n",
			Command = "Multi-step live input coordination test"
		});

		string summary = "Multi-step live input coordination complete. Name=" + name + "; Project=" + project + "; Confirmation=" + confirmation + ".";
		_opsAgent.EmitRuntimeUiOutput(new RuntimeUiEventOutputContract
		{
			EventType = "tool-channel-output",
			Stream = "stdout",
			Text = summary + "\n",
			Command = "Multi-step live input coordination test"
		});

		return summary;
	}
}


