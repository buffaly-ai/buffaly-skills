import Buffaly.Agent.Host Buffaly.Agent.Host.BuffalyArtifacts BuffalyArtifacts;
import Buffaly.Agent.Host Buffaly.Agent.Host.BuffalyAgentService BuffalyAgentService;
import Buffaly.Agent.Tools.Sessions Buffaly.Agent.Tools.Sessions.OnlineSessionMemoryCriticTools OnlineSessionMemoryCriticTools;
import BasicUtilities BasicUtilities.JsonUtil JsonUtil;

prototype OnlineSessionMemoryCriticActionRoot : OpsAction
{
	Description = @"Actions available to the hidden online session memory critic.";
}

prototype OnlineSessionMemoryCriticEntityRoot : SemanticEntityBase
{
}

prototype OnlineSessionMemoryCriticSkillAction : OpsAction
{
	Description = @"Online session memory critic setup actions available to the source session.";
}

[SemanticEntity("online session memory critic skill")]
prototype OnlineSessionMemoryCriticSkill : SkillEntity, CoreEntity
{
	Description = @"Manually reviews one selected source turn and writes high-confidence session-local ontology back into the source session.";
	ActionRoot = OnlineSessionMemoryCriticSkillAction;
}

[SemanticProgram.InfinitivePhrase("to review one turn with the online session memory critic")]
prototype ToAttachConfiguredOnlineSessionMemoryCritic : OnlineSessionMemoryCriticSkillAction
{
	Description = @"Queues exactly one selected completed source turn for review. Ensures or reuses the deterministic critic child and registers it for future turn.completed events.";

	function Execute(string turnKey, string provider, string modelName, string reasoningLevel) : string
	{
		return OnlineSessionMemoryCriticTools.RunConfiguredTurnForCurrentSession(_opsAgent, turnKey, provider, modelName, reasoningLevel);
	}
}

[SemanticProgram.InfinitivePhrase("to attach an online memory critic to another session")]
[SemanticProgram.InfinitivePhrase("to review a source session turn with the online memory critic")]
prototype ToAttachOnlineSessionMemoryCriticToSession : OnlineSessionMemoryCriticSkillAction
{
	Description = @"sourceSessionKey - exact existing source session. turnKey - exact completed source turn to review. Ensures or reuses the deterministic critic child, configures its provider/model, registers future turn.completed delivery, and queues the selected turn without writing an instruction into the source session.";

	function Execute(string sourceSessionKey, string turnKey, string provider, string modelName, string reasoningLevel) : string
	{
		return OnlineSessionMemoryCriticTools.RunConfiguredTurnForSession(sourceSessionKey, turnKey, provider, modelName, reasoningLevel);
	}
}

[SemanticProgram.InfinitivePhrase("to dispatch an online memory critic session event")]
prototype ToDispatchOnlineSessionMemoryCriticEvent : OnlineSessionMemoryCriticActionRoot
{
	Description = @"Renders one delivered turn.completed callback through the existing exact-turn online memory critic instruction.";

	function Execute(string callbackJson) : string
	{
		return OnlineSessionMemoryCriticTools.RenderCriticInstructionFromCallback(callbackJson);
	}
}

[SemanticProgram.InfinitivePhrase("to write session local memory to the source session")]
prototype ToWriteSessionLocalMemoryToSourceSession : OnlineSessionMemoryCriticActionRoot
{
	Description = @"sourceSessionKey - source session that should receive memory. prototypeDefinition - raw ProtoScript containing exactly one prototype definition. Delegates validation and persistence to the source session's existing NLMemory action.";

	function Execute(string sourceSessionKey, string prototypeDefinition) : string
	{
		return OnlineSessionMemoryCriticTools.WriteSessionLocalMemoryToSourceSession(_opsAgent, sourceSessionKey, prototypeDefinition);
	}
}

[SemanticProgram.InfinitivePhrase("to read the observed source session plan")]
prototype ToReadObservedSourcePlan : OnlineSessionMemoryCriticActionRoot
{
	Description = @"sourceSessionKey - observed source session. Returns its Plan.md text.";

	function Execute(string sourceSessionKey) : string
	{
		return JsonUtil.ToStringExt(BuffalyArtifacts.GetSessionArtifactText(sourceSessionKey, "Plan.md")).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to read the observed source session scratch")]
prototype ToReadObservedSourceScratch : OnlineSessionMemoryCriticActionRoot
{
	Description = @"sourceSessionKey - observed source session. Returns its Scratch.md text.";

	function Execute(string sourceSessionKey) : string
	{
		return JsonUtil.ToStringExt(BuffalyArtifacts.GetSessionArtifactText(sourceSessionKey, "Scratch.md")).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to list observed source session tasks")]
prototype ToListObservedSourceTasks : OnlineSessionMemoryCriticActionRoot
{
	Description = @"sourceSessionKey - observed source session. Returns its root-level task artifact names.";

	function Execute(string sourceSessionKey) : string
	{
		return JsonUtil.ToStringExt(BuffalyArtifacts.GetSessionTaskArtifactNames(sourceSessionKey)).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to list observed source session local memories")]
prototype ToListObservedSourceSessionLocalMemories : OnlineSessionMemoryCriticActionRoot
{
	Description = @"sourceSessionKey - observed source session. Returns its current NLMemory runtime-memory dump.";

	function Execute(string sourceSessionKey) : string
	{
		return BuffalyAgentService.RunProtoScriptMethod(sourceSessionKey, "buffaly-agent", "ToDumpRuntimeMemories", "Execute", "{}");
	}
}

[SemanticProgram.InfinitivePhrase("to search source ontology entities for online memory critic")]
prototype ToOnlineMemoryCriticSearchSourceEntities : OnlineSessionMemoryCriticActionRoot
{
	Description = @"Searches the source session's full ontology and session-local semantic bindings.";

	function Execute(string sourceSessionKey, string semanticQuery, int maxResults = 10, bool includeParentType = true) : string
	{
		return OnlineSessionMemoryCriticTools.SearchSourceEntities(sourceSessionKey, semanticQuery, maxResults, includeParentType);
	}
}

[SemanticProgram.InfinitivePhrase("to inspect a source prototype for online memory critic")]
prototype ToOnlineMemoryCriticGetSourcePrototypeDetails : OnlineSessionMemoryCriticActionRoot
{
	Description = @"Inspects one exact prototype in the source session runtime.";

	function Execute(string sourceSessionKey, string prototype) : string
	{
		return OnlineSessionMemoryCriticTools.GetSourcePrototypeDetails(sourceSessionKey, prototype);
	}
}

[SemanticProgram.InfinitivePhrase("to inspect source prototype property schema for online memory critic")]
prototype ToOnlineMemoryCriticGetSourcePrototypePropertySchema : OnlineSessionMemoryCriticActionRoot
{
	Description = @"Returns all resolved property declarations and types for one source-session prototype, including inherited and unassigned properties.";

	function Execute(string sourceSessionKey, string prototype) : string
	{
		return OnlineSessionMemoryCriticTools.GetSourcePrototypePropertySchema(sourceSessionKey, prototype);
	}
}
