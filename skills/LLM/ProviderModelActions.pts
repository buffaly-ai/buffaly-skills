[SemanticProgram.InfinitivePhrase("to list text to speech voices")]
[SemanticProgram.InfinitivePhrase("to list provider text to speech models and voices")]
prototype ToListTextToSpeechVoices : LlmProviderActionBase
{
	Description = @"List provider-backed text-to-speech providers, models, and voices from the active Buffaly runtime catalog without calling external provider APIs.
provider - optional provider token such as openai, gemini, or xai.
model - optional model token to filter voices.";

	function Execute(string provider = "", string model = "") : string
	{
		return _opsAgent.GetTextToSpeechCatalog(provider, model);
	}
}

[SemanticProgram.InfinitivePhrase("to generate text to speech audio")]
[SemanticProgram.InfinitivePhrase("to create a text to speech audio artifact")]
prototype ToGenerateTextToSpeechAudio : LlmProviderActionBase
{
	Description = @"Generate a provider-backed text-to-speech MP3 artifact under the current session artifacts/audio directory.
text - required text to synthesize.
outputFileName - optional file name; output is always written under artifacts/audio and forced to .mp3.
provider - optional provider token; empty uses the active/default TTS provider.
model - optional provider model; empty uses the provider default.
voice - optional voice; empty uses the provider/model default.
instructions - optional provider-specific speech instructions.";

	function Execute(string text, string outputFileName = "", string provider = "", string model = "", string voice = "", string instructions = "") : string
	{
		return _opsAgent.GenerateTextToSpeechAudio(text, outputFileName, provider, model, voice, instructions);
	}
}

[SemanticProgram.InfinitivePhrase("to generate text to speech voice samples")]
[SemanticProgram.InfinitivePhrase("to create text to speech samples for voices")]
prototype ToGenerateTextToSpeechVoiceSamples : LlmProviderActionBase
{
	Description = @"Generate one provider-backed text-to-speech MP3 artifact per requested voice under the current session artifacts/audio directory.
text - required text to synthesize.
provider - optional provider token; empty uses the active/default TTS provider.
model - optional provider model; empty uses the provider default.
voicesCsv - optional comma-separated voice list; empty uses all supported voices for the provider/model.";

	function Execute(string text, string provider = "", string model = "", string voicesCsv = "") : string
	{
		return _opsAgent.GenerateTextToSpeechVoiceSamples(text, provider, model, voicesCsv);
	}
}
