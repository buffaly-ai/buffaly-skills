prototype LlmProviderActionBase : LlmSkillAction
{
	Description = "Base action for provider-routed LLM operations.";
}

prototype GrokActionBase : LlmProviderActionBase
{
	Description = "Base action for xAI provider operations.";
	String Provider = "xai";
}

prototype GeminiActionBase : LlmProviderActionBase
{
	Description = "Base action for Gemini provider operations.";
	String Provider = "gemini";
}

[SemanticProgram.InfinitivePhrase("to ask a model through the buffaly runtime")]
[SemanticProgram.InfinitivePhrase("to ask an llm with runtime provider routing")]
[SemanticProgram.InfinitivePhrase("to ask a model with text image or video input")]
prototype ToAskModelViaBuffalyRuntime : LlmProviderActionBase
{
	Description = @"Preferred LLM action for text completion and multimodal understanding. Delegates to the active Buffaly runtime provider catalog.
prompt - optional primary text instruction.
systemPrompt - optional system instruction.
provider - optional provider token such as openai, xai, gemini, or anthropic.
model - optional model override validated by the runtime catalog.
reasoningLevel - optional canonical reasoning token.
inputPartsJson - optional JSON array of PascalCase content parts: Type text/image_url/video_url with Text/ImageUrl/VideoUrl/MimeType fields.
Does not support image or video generation.";

	function Execute(string prompt, string systemPrompt = "", string provider = "", string model = "", string reasoningLevel = "", string inputPartsJson = "[]") : string
	{
		if (_opsAgent == null)
		{
			return "{\"Status\":\"failed\",\"Error\":\"Active Buffaly runtime host is unavailable.\",\"Provider\":\"\",\"Model\":\"\",\"ReasoningLevel\":\"\",\"Text\":\"\",\"UsageMetrics\":[]}";
		}

		return _opsAgent.AskModelViaRuntime(prompt, systemPrompt, provider, model, reasoningLevel, inputPartsJson);
	}
}

[SemanticProgram.InfinitivePhrase("to ask xai grok a question with specific model")]
prototype ToAskGrokQuestionWithModel : GrokActionBase
{
	Description = "Legacy text wrapper. Prefer ToAskModelViaBuffalyRuntime for new calls.";
	function Execute(string question, string model) : string
	{
		if (_opsAgent == null)
		{
			return "{\"Status\":\"failed\",\"Error\":\"Active Buffaly runtime host is unavailable.\",\"Provider\":\"xai\",\"Model\":\"\",\"ReasoningLevel\":\"\",\"Text\":\"\",\"UsageMetrics\":[]}";
		}

		return _opsAgent.AskModelViaRuntime(question, "", "xai", model, "", "[]");
	}
}

