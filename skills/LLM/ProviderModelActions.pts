		if (_opsAgent == null)
		{
			return "{\"Status\":\"failed\",\"Error\":\"Active Buffaly runtime host is unavailable.\",\"Provider\":\"xai\",\"Model\":\"\",\"ReasoningLevel\":\"\",\"Text\":\"\",\"UsageMetrics\":[]}";
		}

		return _opsAgent.AskModelViaRuntime(question, "", "xai", "", "", "[]");
	}
}

[SemanticProgram.InfinitivePhrase("deprecated unavailable grok heavy text ask")]
prototype ToAskGrokQuestionHeavy : ToAskGrokQuestion
{
	Description = "Deprecated heavy-model wrapper. Use ToAskModelViaBuffalyRuntime with explicit provider/model/reasoning values.";
	function Execute(string question) : string
	{
		return "{\"Status\":\"failed\",\"Error\":\"Deprecated heavy Grok wrapper is unavailable in v1. Use ToAskModelViaBuffalyRuntime with an explicit catalog-backed model and reasoningLevel.\",\"Provider\":\"xai\",\"Model\":\"\",\"ReasoningLevel\":\"\",\"Text\":\"\",\"UsageMetrics\":[]}";
	}
}

