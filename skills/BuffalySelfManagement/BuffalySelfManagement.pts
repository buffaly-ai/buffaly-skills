[SemanticProgram.InfinitivePhrase("to return a protoscript preview grid result")]
[SemanticProgram.InfinitivePhrase("to show a protoscript method result as a grid")]
[SemanticProgram.InfinitivePhrase("to create a protoscript preview grid response")]
[SemanticProgram.InfinitivePhrase("to render sample protoscript preview grid")]
prototype ToReturnProtoScriptPreviewGridResult : BuffalySelfManagementSkillAction
{
	IsPromptAction = false;
	ResponseFormat = "text";
	ResponseResultType = "ProtoScriptPreviewGrid";
	Description = @"Return a structured Buffaly result envelope for rendering a ProtoScript-backed preview grid. sessionKey - target session key for the live ProtoScript runtime. prototypeName - ProtoScript prototype to call. args - JsonObject of named method parameters. methodName - method to call, default Preview. title - visible card title.";

	function Execute(string sessionKey, string prototypeName, JsonObject args, string methodName = "Preview", string title = "ProtoScript Preview") : JsonObject
	{
		if (sessionKey == "")
		{
			JsonObject error = new JsonObject();
			error["Message"] = "ERROR: sessionKey is required.";
			return error;
		}

		JsonObject payload = new JsonObject();
		payload["Title"] = title;
		payload["SessionKey"] = sessionKey;
		payload["PrototypeName"] = prototypeName;
		payload["MethodName"] = methodName;
		payload["Args"] = args;

		JsonObject result = new JsonObject();
		result["Message"] = "Rendering " + title + " as a ProtoScriptPreviewGrid card.";
		result["ResultPayload"] = payload;
		return result;
	}
}

prototype BuffalySamplePreviewGrid : SemanticEntityBase
{
	Description = @"Sample ProtoScript preview data producer for testing RunProtoScriptMethod-backed grid renderers. Call Preview() and parse the returned JSON string.";

	function Preview() : string
	{
		return @"{""Columns"":[{""Key"":""Name"",""Label"":""Name""},{""Key"":""Amount"",""Label"":""Amount""},{""Key"":""Status"",""Label"":""Status""}],""Rows"":[{""Name"":""Alpha Clinic"",""Amount"":125.50,""Status"":""Ready""},{""Name"":""Beta Lab"",""Amount"":89.00,""Status"":""Review""},{""Name"":""Gamma Pharmacy"",""Amount"":242.10,""Status"":""Ready""}],""Summary"":{""Title"":""Sample Preview Grid"",""RequestedMaxRows"":""3""}}";
	}
}
