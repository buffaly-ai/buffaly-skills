[SemanticProgram.InfinitivePhrase("to run a sql stored procedure as a native datatable")]
[SemanticProgram.InfinitivePhrase("to execute a stored procedure and return a datatable")]
prototype ToRunStoredProcedureAsDataTable : SqlServerSkillAction
{
	Description = @"server - SQL Server host name (for example localhost)
database - target database name
username - SQL login user name
secretKey - user-secret key that stores the SQL password
procedureName - stored procedure name
parametersJson - JSON object of stored procedure parameters. Returns a native DataTable reference.";

	function Execute(string server, string database, string username, string secretKey, string procedureName, string parametersJson) : DataTable
	{
		return SqlServerOperations.RunStoredProcedureToDataTable(server, database, username, secretKey, procedureName, parametersJson);
	}
}
[SemanticProgram.InfinitivePhrase("to ensure a local sql server database exists")]
[SemanticProgram.InfinitivePhrase("to create local sql server database if missing")]
prototype ToEnsureLocalSqlServerDatabaseExists : SqlServerSkillAction
{
	Description = @"server - SQL Server host (default localhost)
databaseName - database name to ensure exists (letters/numbers/underscore recommended)";

	function Execute(string server, string databaseName) : string
	{
		if (StringUtil.IsEmpty(server))
			server = "localhost";
		if (StringUtil.IsEmpty(databaseName))
			return "Error: databaseName is required.";
		if (StringUtil.InString(databaseName, "'"))
			return "Error: databaseName contains unsupported character: '";

		string connectionString = "Server=" + server + ";Database=master;Integrated Security=True;Encrypt=False;TrustServerCertificate=True;";
		string sql = "IF DB_ID('" + databaseName + "') IS NULL BEGIN CREATE DATABASE [" + databaseName + "] END";
		DBUtilities.ExecQuery(sql, connectionString);

		return "EnsuredSqlDatabase server=" + server + "; database=" + databaseName;
	}
}
