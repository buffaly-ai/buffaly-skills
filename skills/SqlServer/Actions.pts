prototype ToListSqlDatabases : SqlServerSkillAction
{
	Description = "to connect to local sql server and list databases\nRuns the local SQL Server listing workflow through ToAccessLocalSqlServerSkill.";

	function Execute() : string
	{
		return ToAccessLocalSqlServerSkill.Execute();
	}
}

[SemanticProgram.InfinitivePhrase("to run a read only sql query using a secret key")]
prototype ToRunReadOnlySqlQuery : SqlServerSkillAction
{
	Description = @"server - SQL Server host name (for example localhost)
database - target database name
username - SQL login user name
secretKey - user-secret key that stores the SQL password (never pass plaintext password)
query - read-only SQL query (SELECT/CTE only)
maxRows - maximum preview rows to return (default 200, max 1000).";

	function Execute(string server, string database, string username, string secretKey, string query, int maxRows) : string
	{
		return SqlServerOperations.RunReadOnlySqlQuery(server, database, username, secretKey, query, maxRows);
	}
}

