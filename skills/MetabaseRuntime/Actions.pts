		return "Created FeatureObjectID=" + id + "; FeatureID=" + featureId + "; ObjectID=" + objectId;
	}
}

[SemanticProgram.InfinitivePhrase("to update roottrax vdb project directories")]
prototype ToUpdateRootTraxVdbProjectDirectories : MetabaseRuntimeSkillAction
{
	function Execute(int projectId, string rootDirectory, string dbScriptDirectory, string jsonWsDirectory, string kScriptDirectory, string dataJson) : string
	{
		if (projectId <= 0) return "Error: projectId must be > 0.";
		if (StringUtil.IsEmpty(rootDirectory)) return "Error: rootDirectory is required.";

		ToEnsureRootTraxVdbConnection();
		ProjectsRow existing = Projects.GetProject(projectId);
		if (existing == null)
			return "Error: project not found.";

		string nextDbScript = StringUtil.IsEmpty(dbScriptDirectory) ? existing.DBScriptDirectory : dbScriptDirectory;
		string nextJsonWs = StringUtil.IsEmpty(jsonWsDirectory) ? existing.JsonWsDirectory : jsonWsDirectory;
		string nextKScript = StringUtil.IsEmpty(kScriptDirectory) ? existing.kScriptDirectory : kScriptDirectory;
		string payload = StringUtil.IsEmpty(dataJson) ? existing.Data : dataJson;

		Projects.UpdateProject(existing.ProjectID, existing.ProjectName, existing.DatabaseID, existing.BusinessLayerNamespace, existing.DBLayerNamespace, existing.UILayerNamespace, rootDirectory, nextDbScript, nextJsonWs, nextKScript, payload);
		return "Updated ProjectID=" + existing.ProjectID + "; ProjectName=" + existing.ProjectName;
	}
}

