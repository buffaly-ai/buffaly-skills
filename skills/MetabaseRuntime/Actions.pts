prototype ToEnsureRootTraxVdbFeatureObjectLink : MetabaseRuntimeSkillAction
{
	function Execute(int featureId, int objectId, string dataJson) : string
	{
		if (featureId <= 0) return "Error: featureId must be > 0.";
