	}
}

[SemanticProgram.InfinitivePhrase("to create roottrax vdb object specification from llm")]
prototype ToCreateRootTraxVdbObjectSpecificationFromLLM : MetabaseRuntimeSkillAction
{
	function Execute(string objectDescription) : string
	{
		if (StringUtil.IsEmpty(objectDescription))
			return "Error: objectDescription is required.";
		if (_opsAgent == null)
			return "Error: _opsAgent runtime is not available.";

		string projectDirectory = _opsAgent.GetCurrentProjectDirectory();
		if (StringUtil.IsEmpty(projectDirectory))
			return "Error: current project directory is unavailable.";

		string promptPath = Path.Combine(projectDirectory, "Skills", "Metabase", "Prompts", "NLtoObjectSpec.md");
		if (!File.Exists(promptPath))
			return "Error: NLtoObjectSpec prompt file not found at " + promptPath;

		string prompt = File.ReadAllText(promptPath);
		JsonObject response = LLMs.ExecuteLLMPromptAndInput(prompt, objectDescription);
		if (response == null) return "Error: LLM returned null.";
		return response.ToJSON();
	}
}

[SemanticProgram.InfinitivePhrase("to upsert roottrax vdb object definition")]
prototype ToUpsertRootTraxVdbObjectDefinition : MetabaseRuntimeSkillAction
{
	function Execute(string definitionJson, int applicationId) : string
	{
		if (StringUtil.IsEmpty(definitionJson))
			return "Error: definitionJson is required.";

		JsonObject definition = new JsonObject(definitionJson);
		int? appId = null;
		if (applicationId > 0) appId = applicationId;

		ToEnsureRootTraxVdbConnection();
		int objectId = ObjectDefinitionLoader.UpsertObject(definition, appId);
		return "Upserted ObjectID=" + objectId;
	}
}

[SemanticProgram.InfinitivePhrase("to get local metabase object edit url")]
[SemanticProgram.InfinitivePhrase("to build local metabase object link")]
prototype ToGetLocalMetabaseObjectEditUrl : MetabaseRuntimeSkillAction
{
	function Execute(int objectId, string baseUrl) : string
	{
		if (objectId <= 0)
			return "Error: objectId must be > 0.";

		string resolvedBaseUrl = baseUrl;
		if (StringUtil.IsEmpty(resolvedBaseUrl))
			resolvedBaseUrl = "http://localhost:5197";

		if (StringUtil.EndsWith(resolvedBaseUrl, "/"))
			return resolvedBaseUrl + "object?ObjectID=" + objectId;

		return resolvedBaseUrl + "/object?ObjectID=" + objectId;
	}
}

[SemanticProgram.InfinitivePhrase("to ensure a roottrax vdb feature")]
prototype ToEnsureRootTraxVdbFeature : MetabaseRuntimeSkillAction
{
	function Execute(string featureName, string version, bool isEnabled, string settingsAssembly, string settingsClass, string settingsJson, string dataJson) : string
	{
		if (StringUtil.IsEmpty(featureName))
			return "Error: featureName is required.";

		ToEnsureRootTraxVdbConnection();
		FeaturesRow existing = Features.GetFeatureByFeatureName(featureName);
		if (existing != null)
			return "Exists FeatureID=" + existing.FeatureID + "; FeatureName=" + existing.FeatureName;

		string v = StringUtil.IsEmpty(version) ? "1.0" : version;
		string sa = StringUtil.IsEmpty(settingsAssembly) ? "n/a" : settingsAssembly;
		string sc = StringUtil.IsEmpty(settingsClass) ? "n/a" : settingsClass;
		string sj = StringUtil.IsEmpty(settingsJson) ? "{}" : settingsJson;
		string dj = StringUtil.IsEmpty(dataJson) ? "{}" : dataJson;

		int id = Features.InsertFeature(featureName, v, isEnabled, sa, sc, sj, dj);
		return "Created FeatureID=" + id + "; FeatureName=" + featureName;
	}
}

[SemanticProgram.InfinitivePhrase("to ensure roottrax vdb project feature link")]
prototype ToEnsureRootTraxVdbProjectFeatureLink : MetabaseRuntimeSkillAction
{
	function Execute(int projectId, int featureId, string dataJson) : string
	{
		if (projectId <= 0) return "Error: projectId must be > 0.";
		if (featureId <= 0) return "Error: featureId must be > 0.";

		ToEnsureRootTraxVdbConnection();
		ProjectFeaturesDataTable links = ProjectFeatures.GetProjectFeaturesByProjectID(projectId);
		foreach (ProjectFeaturesRow link in links)
		{
			if (link.FeatureID == featureId)
				return "Exists ProjectFeatureID=" + link.ProjectFeatureID + "; ProjectID=" + projectId + "; FeatureID=" + featureId;
		}

		string payload = StringUtil.IsEmpty(dataJson) ? "{}" : dataJson;
		int id = ProjectFeatures.InsertProjectFeature(projectId, featureId, payload);
		return "Created ProjectFeatureID=" + id + "; ProjectID=" + projectId + "; FeatureID=" + featureId;
	}
}

