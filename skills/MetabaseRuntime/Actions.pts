function ToEnsureRootTraxVdbConnection() : string
{
	MetabaseExecutionFacade.InitializeDatabaseAndKScript();
	return "Initialized via RooTrax.VDB.MetabaseExecutionFacade.InitializeDatabaseAndKScript";
}

[SemanticProgram.InfinitivePhrase("to ensure a roottrax vdb application")]
prototype ToEnsureRootTraxVdbApplication : MetabaseRuntimeSkillAction
{
	function Execute(string applicationName, string dataJson) : string
	{
		if (StringUtil.IsEmpty(applicationName))
			return "Error: applicationName is required.";

		ToEnsureRootTraxVdbConnection();
		ApplicationsDataTable apps = Applications.GetAll();
		foreach (ApplicationsRow app in apps)
		{
			if (StringUtil.EqualNoCase(app.ApplicationName, applicationName))
				return "Exists ApplicationID=" + app.ApplicationID + "; ApplicationName=" + app.ApplicationName;
		}

		string payload = StringUtil.IsEmpty(dataJson) ? "{}" : dataJson;
		int id = Applications.InsertApplication(applicationName, payload);
		return "Created ApplicationID=" + id + "; ApplicationName=" + applicationName;
	}
}

[SemanticProgram.InfinitivePhrase("to find a roottrax vdb object id by name")]
prototype ToFindRootTraxVdbObjectIdByName : MetabaseRuntimeSkillAction
{
	function Execute(string nameLike) : string
	{
		if (StringUtil.IsEmpty(nameLike))
			return "Error: nameLike is required.";

		ToEnsureRootTraxVdbConnection();
		ObjectsDataTable objs = Objects.GetAll();
		foreach (ObjectsRow o in objs)
		{
			if (StringUtil.InString(o.ObjectName, nameLike) || StringUtil.InString(o.ObjectsName, nameLike))
			{
				return "Found ObjectID=" + o.ObjectID + "; ObjectName=" + o.ObjectName + "; ObjectsName=" + o.ObjectsName;
			}
		}
		return "Not found: " + nameLike;
	}
}

[SemanticProgram.InfinitivePhrase("to copy a roottrax vdb object into application")]
prototype ToCopyRootTraxVdbObjectIntoApplication : MetabaseRuntimeSkillAction
{
	function Execute(int sourceObjectId, int targetApplicationId) : string
	{
		if (sourceObjectId <= 0) return "Error: sourceObjectId must be > 0.";
		if (targetApplicationId <= 0) return "Error: targetApplicationId must be > 0.";

		ToEnsureRootTraxVdbConnection();
		ObjectsRow source = Objects.GetObject(sourceObjectId);
		if (source == null) return "Error: source object not found.";

		int newObjectId = Objects.CopyObject(sourceObjectId);
		Objects.UpdateObject(newObjectId, source.ObjectName, source.ObjectsName, source.FriendlyObjectName, source.FriendlyObjectsName, targetApplicationId, source.Data);
		return "Copied NewObjectID=" + newObjectId + "; SourceObjectID=" + sourceObjectId + "; TargetApplicationID=" + targetApplicationId;
	}
}

[SemanticProgram.InfinitivePhrase("to ensure roottrax vdb database metadata")]
prototype ToEnsureRootTraxVdbDatabaseMetadata : MetabaseRuntimeSkillAction
{
	function Execute(string databaseName, string databaseHandle, string connectionHandleReadWrite, string connectionHandleReadOnly, string connectionHandleAdmin, string dataJson) : string
	{
		if (StringUtil.IsEmpty(databaseName)) return "Error: databaseName required.";
		if (StringUtil.IsEmpty(databaseHandle)) return "Error: databaseHandle required.";

		ToEnsureRootTraxVdbConnection();
		string payload = StringUtil.IsEmpty(dataJson) ? "{}" : dataJson;
		int id = VdbDatabases.InsertDatabase(databaseName, databaseHandle, connectionHandleReadWrite, connectionHandleReadOnly, connectionHandleAdmin, payload);
		return "Created DatabaseID=" + id + "; DatabaseHandle=" + databaseHandle;
	}
}

[SemanticProgram.InfinitivePhrase("to ensure a roottrax vdb project")]
prototype ToEnsureRootTraxVdbProject : MetabaseRuntimeSkillAction
{
	function Execute(string projectName, int databaseId, string businessLayerNamespace, string dbLayerNamespace, string uiLayerNamespace, string rootDirectory, string dbScriptDirectory, string jsonWsDirectory, string kScriptDirectory, string dataJson) : string
	{
		if (StringUtil.IsEmpty(projectName)) return "Error: projectName is required.";
		if (databaseId <= 0) return "Error: databaseId must be > 0.";

		ToEnsureRootTraxVdbConnection();
		ProjectsRow existing = Projects.GetProjectByProjectName(projectName);
		if (existing != null)
			return "Exists ProjectID=" + existing.ProjectID + "; ProjectName=" + existing.ProjectName;

		string payload = StringUtil.IsEmpty(dataJson) ? "{}" : dataJson;
		int id = Projects.InsertProject(projectName, databaseId, businessLayerNamespace, dbLayerNamespace, uiLayerNamespace, rootDirectory, dbScriptDirectory, jsonWsDirectory, kScriptDirectory, payload);
		return "Created ProjectID=" + id + "; ProjectName=" + projectName;
	}
}

