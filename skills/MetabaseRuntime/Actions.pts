	function Execute(int objectId, int projectId) : string
	{
		if (objectId <= 0) return "Error: objectId must be > 0.";
		if (projectId <= 0) return "Error: projectId must be > 0.";

				ToEnsureRootTraxVdbConnection();
		Features.ImplementObjectIntoProjectDatabase(objectId, projectId);
