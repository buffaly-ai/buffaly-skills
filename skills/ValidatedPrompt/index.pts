import Buffaly.Agent.Tools.ValidatedPrompt Buffaly.Agent.Tools.ValidatedPrompt.ValidatedPromptTools ValidatedPromptTools;

prototype ValidatedPromptSkillAction : OpsAction
{
	Description = @"Base action type for Validated Prompt skill tools.";
}

[SemanticEntity("validated prompt skill")]
prototype ValidatedPromptSkill : SkillEntity, CoreEntity
{
	Description = "Validated prompt runner and sample validated prompt actions.";
	ActionRoot = ValidatedPromptSkillAction;
}

[SemanticProgram.InfinitivePhrase("to run a validated prompt skill")]
[SemanticProgram.InfinitivePhrase("to execute a validated prompt action")]
prototype ToRunValidatedPromptSkill : ValidatedPromptSkillAction
{
	Description = @"validatedPromptActionName - prototype name for one ValidatedPromptAction. userInput - input for the work prompt. maxAttempts - maximum validation attempts. Leave childSessionKeyOverride empty for normal validated-prompt runs so the action's ChildSessionScope applies; a non-empty override bypasses ChildSessionScope/per-parent and uses that exact session key only for explicit diagnostics or user-requested reruns. ChildSessionScope is read from the ValidatedPromptAction and defaults to per-parent.";

	function Execute(string validatedPromptActionName, string userInput, int maxAttempts = 2, string childSessionKeyOverride = "") : string
	{
		if (_opsAgent == null)
			return "Error: _opsAgent runtime is not available.";
		string prototypeName = validatedPromptActionName.Trim();
		if (StringUtil.IsEmpty(prototypeName))
			return "Error: validatedPromptActionName is required.";

		ValidatedPromptAction validatedPromptAction = null;
		Collection validatedPromptActions = ValidatedPromptAction.GetDescendants();
		foreach (Prototype candidatePrototype in validatedPromptActions)
		{
			if (candidatePrototype.PrototypeName == prototypeName)
			{
				if (candidatePrototype typeof ValidatedPromptAction)
					validatedPromptAction = candidatePrototype;
			}
		}

		if (validatedPromptAction == null)
			return "Error: ValidatedPromptAction prototype not found: " + prototypeName;

		return ValidatedPromptTools.RunValidatedPromptSkill(
			_opsAgent,
			validatedPromptAction.PrototypeName,
			validatedPromptAction.WorkPrompt,
			validatedPromptAction.WorkPromptPath,
			validatedPromptAction.ValidationPrompt,
			validatedPromptAction.ValidationPromptPath,
			userInput,
			maxAttempts,
			childSessionKeyOverride,
			validatedPromptAction.ChildSessionScope);
	}
}

[SemanticProgram.InfinitivePhrase("to run a validated prompt skill from a session file")]
[SemanticProgram.InfinitivePhrase("to execute a validated prompt action using a staged input file")]
prototype ToRunValidatedPromptSkillFromSessionFile : ValidatedPromptSkillAction
{
	Description = @"validatedPromptActionName - prototype name for one ValidatedPromptAction. userInputRelativePath - file path under the current session directory containing the full user input. maxAttempts - maximum validation attempts. Leave childSessionKeyOverride empty for normal validated-prompt runs so the action's ChildSessionScope applies; a non-empty override bypasses ChildSessionScope/per-parent and uses that exact session key only for explicit diagnostics or user-requested reruns. ChildSessionScope is read from the ValidatedPromptAction and defaults to per-parent.";

	function Execute(string validatedPromptActionName, string userInputRelativePath, int maxAttempts = 2, string childSessionKeyOverride = "") : string
	{
		if (_opsAgent == null)
			return "Error: _opsAgent runtime is not available.";
		string prototypeName = validatedPromptActionName.Trim();
		if (StringUtil.IsEmpty(prototypeName))
			return "Error: validatedPromptActionName is required.";

		ValidatedPromptAction validatedPromptAction = null;
		Collection validatedPromptActions = ValidatedPromptAction.GetDescendants();
		foreach (Prototype candidatePrototype in validatedPromptActions)
		{
			if (candidatePrototype.PrototypeName == prototypeName)
			{
				if (candidatePrototype typeof ValidatedPromptAction)
					validatedPromptAction = candidatePrototype;
			}
		}

		if (validatedPromptAction == null)
			return "Error: ValidatedPromptAction prototype not found: " + prototypeName;

		return ValidatedPromptTools.RunValidatedPromptSkillFromSessionFile(
			_opsAgent,
			validatedPromptAction.PrototypeName,
			validatedPromptAction.WorkPrompt,
			validatedPromptAction.WorkPromptPath,
			validatedPromptAction.ValidationPrompt,
			validatedPromptAction.ValidationPromptPath,
			userInputRelativePath,
			maxAttempts,
			childSessionKeyOverride,
			validatedPromptAction.ChildSessionScope);
	}
}
[SemanticProgram.InfinitivePhrase("to inspect a validated prompt action definition")]
prototype ToInspectValidatedPromptActionDefinition : ValidatedPromptSkillAction
{
	Description = @"validatedPromptActionName - prototype name for one ValidatedPromptAction. Returns resolution details for debugging deployed validated prompt definitions.";

	function Execute(string validatedPromptActionName) : string
	{
		if (_opsAgent == null)
			return "Error: _opsAgent runtime is not available.";
		string prototypeName = validatedPromptActionName.Trim();
		if (StringUtil.IsEmpty(prototypeName))
			return "Error: validatedPromptActionName is required.";

		ValidatedPromptAction validatedPromptAction = null;
		Collection validatedPromptActions = ValidatedPromptAction.GetDescendants();
		foreach (Prototype candidatePrototype in validatedPromptActions)
		{
			if (candidatePrototype.PrototypeName == prototypeName)
			{
				if (candidatePrototype typeof ValidatedPromptAction)
					validatedPromptAction = candidatePrototype;
			}
		}

		if (validatedPromptAction == null)
			return "found=false; action=" + prototypeName;
		string workPrompt = validatedPromptAction.WorkPrompt;
		string validationPrompt = validatedPromptAction.ValidationPrompt;
		string workPromptPath = validatedPromptAction.WorkPromptPath;
		string validationPromptPath = validatedPromptAction.ValidationPromptPath;
		if (StringUtil.IsEmpty(workPrompt))
			workPrompt = _opsAgent.LoadTrustedPromptText(workPromptPath);
		if (StringUtil.IsEmpty(validationPrompt))
			validationPrompt = _opsAgent.LoadTrustedPromptText(validationPromptPath);
		return "found=true; action=" + validatedPromptAction.PrototypeName + "; workPath=" + workPromptPath + "; validationPath=" + validationPromptPath + "; workLength=" + workPrompt.Length.ToString() + "; validationLength=" + validationPrompt.Length.ToString();
	}
}
[SemanticProgram.InfinitivePhrase("to summarize text in one sentence with validation")]
[SemanticProgram.InfinitivePhrase("to summarize text in exactly one faithful sentence")]
prototype ToSummarizeTextInOneSentenceSkill : ValidatedPromptAction, ValidatedPromptSkillAction
{
	IsPromptAction = true;
	SkillKind = "validated-prompt";
	SkillVersion = "1.0.0";
	Description = "Summarize provided text in exactly one faithful sentence without adding facts.";
	WorkPromptPath = @"Skills/ValidatedPrompt/Prompts/SummarizeTextInOneSentence.work.prompt.md";
	ValidationPromptPath = @"Skills/ValidatedPrompt/Prompts/SummarizeTextInOneSentence.validation.prompt.md";
}












