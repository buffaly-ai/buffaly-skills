import Buffaly.Agent.Tools.ValidatedPrompt Buffaly.Agent.Tools.ValidatedPrompt.ValidatedPromptTools ValidatedPromptTools;

prototype ValidatedPromptSkillAction : OpsAction
{
	Description = @"Base action type for Validated Prompt skill tools.";
}

[SemanticEntity("validated prompt skill")]
prototype ValidatedPromptSkill : SkillEntity, CoreEntity
{
	Description = "Validated prompt runner and sample validated prompt actions.";
	ActionRoot = ValidatedPromptSkillAction;
}

[SemanticProgram.InfinitivePhrase("to run a validated prompt skill")]
[SemanticProgram.InfinitivePhrase("to execute a validated prompt action")]
prototype ToRunValidatedPromptSkill : ValidatedPromptSkillAction
{
	Description = @"validatedPromptActionName - prototype name for one ValidatedPromptAction. userInput - input for the work prompt. maxAttempts - maximum validation attempts. childSessionKeyOverride - optional deterministic child key override for diagnostics or reruns.";

	function Execute(string validatedPromptActionName, string userInput, int maxAttempts = 2, string childSessionKeyOverride = "") : string
	{
		if (_opsAgent == null)
			return "Error: _opsAgent runtime is not available.";
		string prototypeName = validatedPromptActionName.Trim();
		if (StringUtil.IsEmpty(prototypeName))
			return "Error: validatedPromptActionName is required.";

		ValidatedPromptAction validatedPromptAction = null;
		Collection validatedPromptActions = ValidatedPromptAction.GetDescendants();
		foreach (Prototype candidatePrototype in validatedPromptActions)
		{
			if (candidatePrototype.PrototypeName == prototypeName)
			{
				if (candidatePrototype typeof ValidatedPromptAction)
					validatedPromptAction = candidatePrototype;
			}
		}

		if (validatedPromptAction == null)
			return "Error: ValidatedPromptAction prototype not found: " + prototypeName;

		return ValidatedPromptTools.RunValidatedPromptSkill(
			_opsAgent,
			validatedPromptAction.PrototypeName,
			validatedPromptAction.WorkPrompt,
			validatedPromptAction.WorkPromptPath,
			validatedPromptAction.ValidationPrompt,
			validatedPromptAction.ValidationPromptPath,
			userInput,
			maxAttempts,
			childSessionKeyOverride);
	}
}

[SemanticProgram.InfinitivePhrase("to run a validated prompt skill from a session file")]
[SemanticProgram.InfinitivePhrase("to execute a validated prompt action using a staged input file")]
prototype ToRunValidatedPromptSkillFromSessionFile : ValidatedPromptSkillAction
{
	Description = @"validatedPromptActionName - prototype name for one ValidatedPromptAction. userInputRelativePath - file path under the current session directory containing the full user input. maxAttempts - maximum validation attempts. childSessionKeyOverride - optional deterministic child key override.";

	function Execute(string validatedPromptActionName, string userInputRelativePath, int maxAttempts = 2, string childSessionKeyOverride = "") : string
	{
		if (_opsAgent == null)
			return "Error: _opsAgent runtime is not available.";
		string prototypeName = validatedPromptActionName.Trim();
		if (StringUtil.IsEmpty(prototypeName))
			return "Error: validatedPromptActionName is required.";

		ValidatedPromptAction validatedPromptAction = null;
		Collection validatedPromptActions = ValidatedPromptAction.GetDescendants();
		foreach (Prototype candidatePrototype in validatedPromptActions)
		{
			if (candidatePrototype.PrototypeName == prototypeName)
			{
				if (candidatePrototype typeof ValidatedPromptAction)
					validatedPromptAction = candidatePrototype;
			}
		}

		if (validatedPromptAction == null)
			return "Error: ValidatedPromptAction prototype not found: " + prototypeName;

		return ValidatedPromptTools.RunValidatedPromptSkillFromSessionFile(
			_opsAgent,
			validatedPromptAction.PrototypeName,
			validatedPromptAction.WorkPrompt,
			validatedPromptAction.WorkPromptPath,
			validatedPromptAction.ValidationPrompt,
			validatedPromptAction.ValidationPromptPath,
			userInputRelativePath,
			maxAttempts,
			childSessionKeyOverride);
	}
}
