[SemanticProgram.InfinitivePhrase("to debug validated prompt string binding")]
prototype ToDebugEchoValidatedPromptStringBinding : ValidatedPromptSkillAction
{
	Description = @"Diagnostic action for direct ProtoScript method string binding. Returns the input length and leading text.";

	function Execute(string text) : string
	{
		string start = text;
		if (start.Length > 200)
			start = start.Substring(0, 200);
		return "length=" + text.Length + "\nstart=" + start;
	}
}
