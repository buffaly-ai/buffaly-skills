[SemanticProgram.InfinitivePhrase("to search SNOMED concepts by exact term or concept ID")]
[SemanticProgram.InfinitivePhrase("to find SNOMED CT concepts by exact match")]
[SemanticProgram.InfinitivePhrase("to look up a SNOMED concept by ID")]
prototype ToSearchCareCascadeSnomedConceptsExact : CareCascadeSkillAction
{
	function Execute(CareCascadeSnomedJsonWsService service, string query) : string
	{
		if (service == null)
		{
			return "Error: CareCascadeSnomedJsonWsService binding is required.";
		}
		if (StringUtil.IsEmpty(query))
		{
			return "Error: query is required.";
		}
		JsonObject args = new JsonObject();
		args["Method"] = "SearchConceptsExact";
		args["query"] = query;
		return service.CallSnomedRoute("search-concepts-exact", args);
	}
	Description = @"service - CareCascadeSnomedJsonWsService binding, normally CareCascadeSnomedJsonWsService#Published. query - SNOMED concept ID (numeric) or exact term text. Calls SearchConceptsExact and returns raw JSON array of matching SNOMED concepts with ConceptId, PreferredTerm, FullySpecifiedName, and Synonyms.";
}

[SemanticProgram.InfinitivePhrase("to search SNOMED concepts broadly by text")]
[SemanticProgram.InfinitivePhrase("to find SNOMED CT concepts by keyword search")]
[SemanticProgram.InfinitivePhrase("to search clinical concepts in SNOMED")]
[SemanticProgram.InfinitivePhrase("to look up SNOMED concepts by description")]
prototype ToSearchCareCascadeSnomedConceptsBroad : CareCascadeSkillAction
{
	function Execute(CareCascadeSnomedJsonWsService service, string query, int maxResults) : string
	{
		if (service == null)
		{
			return "Error: CareCascadeSnomedJsonWsService binding is required.";
		}
		if (StringUtil.IsEmpty(query))
		{
			return "Error: query is required.";
		}
		JsonObject args = new JsonObject();
		args["Method"] = "SearchConceptsBroad";
		args["query"] = query;
		int resolvedMaxResults = maxResults;
		if (resolvedMaxResults <= 0)
		{
			resolvedMaxResults = 50;
		}
		args["maxResults"] = resolvedMaxResults;
		return service.CallSnomedRoute("search-concepts-broad", args);
	}
	Description = @"service - CareCascadeSnomedJsonWsService binding, normally CareCascadeSnomedJsonWsService#Published. query - search text such as 'diabetes'. maxResults - maximum results to return (default 50, hard cap 100). Calls SearchConceptsBroad and returns ranked, deduplicated JSON array of SNOMED concepts.";
}

