prototype ToSyncBoundWebsiteRepository : WebPropertyEditorAgentAction
{
	Description = @"Synchronize the sealed bound website repository into the session workspace.";
	function Execute() : string { return WebPropertyEditorFacade.SyncRepository(_sessionObject); }
}

