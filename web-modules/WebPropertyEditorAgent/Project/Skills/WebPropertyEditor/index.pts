prototype ToGetBoundWebsiteTree : WebPropertyEditorAgentAction
{
	Description = @"relativeDirectory - relative directory under the bound website. maxDepth - bounded tree depth. maxResults - bounded result count.";
	function Execute(string relativeDirectory, string maxDepth, string maxResults) : string { return WebPropertyEditorFacade.GetTree(_sessionObject, relativeDirectory, maxDepth, maxResults); }
}

