	}
}

[SemanticProgram.InfinitivePhrase("to list ontology foundry prototype descendants")]
prototype ToOntologyFoundryListPrototypeFirstLevelDescendants : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"prototype - exact seed or family root. Returns direct descendants only; never recursively traverses.";

	function Execute(Prototype prototype) : Collection
	{
		return ToListPrototypeFirstLevelDescendants.Execute(prototype);
	}
}

[SemanticProgram.InfinitivePhrase("to list ontology foundry installed web modules")]
prototype ToOntologyFoundryListInstalledWebModules : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"Returns the authoritative installed web-module inventory, enabled state, and declared UI pages for family comparison.";

	function Execute() : string
	{
		return ToListInstalledCapabilityWebModules.Execute();
	}
}

[SemanticProgram.InfinitivePhrase("to list ontology foundry active level two sessions")]
prototype ToOntologyFoundryListActiveSessions : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"maxCount - bounded active runtime sessions. Harvest selects only exact keys ending in -level-two.";
	function Execute(int maxCount = 100) : List<SessionStatusResult>
	{
		return SessionTools.ListActiveSessionsTool(maxCount);
	}
}

[SemanticProgram.InfinitivePhrase("to send an ontology foundry harvest instruction to a session")]
prototype ToOntologyFoundrySendToSession : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"sessionKey - exact existing Level2 key. instruction - exact inspect-only harvest prompt. Returns queued IDs used for correlation.";
	function Execute(string sessionKey, string instruction) : QueuedInputResult
	{
		return SessionTools.SendToSessionTool(sessionKey, instruction);
	}
}

[SemanticProgram.InfinitivePhrase("to evaluate one ontology foundry level two harvest")]
prototype ToOntologyFoundryEvaluateLevel2Harvest : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"Runs one exact Level2 harvest through the typed child-session relay and returns its bounded terminal result.";

	function Execute(string sessionKey, string instruction) : string
	{
		return BuffalyAgentService.CreateChildSession(
			_opsAgent.GetSessionKeyOrEmpty(),
			sessionKey,
			instruction,
			900,
			null).Response.Message;
	}
}

[SemanticProgram.InfinitivePhrase("to get the most recent ontology foundry source turn")]
prototype ToOntologyFoundryGetMostRecentSessionTurn : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"sessionKey - exact dispatched Level2 key. Returns the latest bounded turn summary.";
	function Execute(string sessionKey) : TurnSummaryContract
	{
		return SessionTools.GetMostRecentSessionTurnTool(sessionKey);
	}
}

[SemanticProgram.InfinitivePhrase("to get recent ontology foundry source turns")]
prototype ToOntologyFoundryGetRecentSessionTurns : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"sessionKey - exact dispatched Level2 key. maxTurns - bounded fallback used only to correlate the dispatched MessageKey.";
	function Execute(string sessionKey, int maxTurns = 5) : GetSessionTurnBootstrapResponse
	{
		return SessionTools.GetRecentSessionTurnsTool(sessionKey, maxTurns);
	}
}

[SemanticProgram.InfinitivePhrase("to read a source session ontology foundry evidence graph")]
prototype ToReadOntologyFoundryEvidenceGraph : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"sourceSessionKey - exact Level1 source session that owns the living artifacts/ontology-foundry/evidence-graph.md. Missing returns an empty string.";

	function Execute(string sourceSessionKey) : string
	{
		Sessions.ValidateSessionKey(sourceSessionKey);
		string root = Path.Combine(Sessions.GetSessionsRootPath(), sourceSessionKey);
		string path = Path.Combine(root, @"artifacts\ontology-foundry\evidence-graph.md");
		if (!File.Exists(path))
		{
			return "";
		}
		return File.ReadAllText(path);
	}
}

[SemanticProgram.InfinitivePhrase("to write a source session ontology foundry evidence graph")]
prototype ToWriteOntologyFoundryEvidenceGraph : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"sourceSessionKey - exact Level1 source session that owns the living EvidenceGraph. markdown - complete replacement content for that source's fixed artifacts/ontology-foundry/evidence-graph.md.";

	function Execute(string sourceSessionKey, string markdown) : string
	{
		Sessions.ValidateSessionKey(sourceSessionKey);
		return FileSystemTools.ReplaceTextFile(
			Path.Combine(Sessions.GetSessionsRootPath(), sourceSessionKey),
			@"artifacts\ontology-foundry\evidence-graph.md",
			markdown);
	}
}
