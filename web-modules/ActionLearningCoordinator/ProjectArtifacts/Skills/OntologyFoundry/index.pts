reference Buffaly.SessionSemanticDatabase Buffaly.SessionSemanticDatabase;
import Buffaly.SessionSemanticDatabase Buffaly.SessionSemanticDatabase.SessionConversationSearchDriver SessionConversationSearchDriver;
import Buffaly.Agent.Host Buffaly.Agent.Host.SessionManagement.Sessions Sessions;

[SemanticEntity("ontology foundry action root")]
prototype OntologyFoundryActionRoot : OpsAction
{
	Description = @"Restricted action root for the Ontology Foundry agent.";
}

[SemanticEntity("ontology foundry entity root")]
prototype OntologyFoundryEntityRoot : SemanticEntityBase
{
	Description = @"Restricted entity root for the Ontology Foundry agent.";
}

prototype OntologyFoundrySkillAction : OntologyFoundryActionRoot
{
	Description = @"Base action type for Ontology Foundry tools.";
}

[SemanticProgram.InfinitivePhrase("to evaluate an ontology foundry calibration session")]
prototype ToEvaluateOntologyFoundryCalibrationSession : OpsAction
{
	Description = @"Parent-coordinator action only. sessionKey - existing attached calibration child. instruction - next bounded continuation input. Evaluates through the typed cross-worker CreateChildSession relay.";

	function Execute(string sessionKey, string instruction) : Prototype
	{
		return BuffalyAgentService.CreateChildSession(
			_opsAgent.GetSessionKeyOrEmpty(),
			sessionKey,
			instruction,
			900,
			null);
	}
}

[SemanticEntity("ontology foundry skill")]
prototype OntologyFoundrySkill : SkillEntity
{
	Description = @"Bounded historical-session evidence analysis for reviewable ontology candidates.";
	ActionRoot = OntologyFoundryActionRoot;
}

include "PromptActions.pts";

[SemanticProgram.InfinitivePhrase("to create an ontology foundry session")]
prototype ToCreateOntologyFoundrySession : OpsAction
{
	Description = @"Parent-coordinator action only. sessionKey - exact new or existing session key. Creates the runtime from the current OpsAgent project using the ontology-foundry agent profile.";

	function Execute(string sessionKey) : Prototype
	{
		return BuffalyAgentService.CreateAgentFromProject(sessionKey, "OpsAgent", "ontology-foundry");
	}
}

[SemanticProgram.InfinitivePhrase("to search ontology foundry candidate entities")]
prototype ToOntologyFoundrySearchCandidateEntities : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"semanticQuery - focused model-generated or analyst-selected entity query. maxResults - bounded result count. includeParentType - include parent type context.";

	function Execute(string semanticQuery, int maxResults = 8, bool includeParentType = true) : string
	{
		return CoreOntologyTools.SearchCandidateEntities(_opsAgent, semanticQuery, maxResults, includeParentType);
	}
}

[SemanticProgram.InfinitivePhrase("to inspect ontology foundry prototype details")]
prototype ToOntologyFoundryGetPrototypeDetails : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"prototype - exact current prototype to inspect.";

	function Execute(Prototype prototype) : string
	{
		return PrototypeLogging.ToFriendlyString(prototype).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to inspect ontology foundry prototype schema")]
prototype ToOntologyFoundryGetPrototypePropertySchema : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"prototype - exact prototype reference to inspect.";

	function Execute(string prototype) : string
	{
		return _runtime.FormatResolvedPropertySchema(_runtime.GetPrototype(prototype));
	}
}

[SemanticProgram.InfinitivePhrase("to search ontology foundry conversations semantically")]
prototype ToOntologyFoundryFindConversationsForProbe : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"query - probe text. topConversations and topFragmentsPerConversation - explicit bounded result limits.";

	function Execute(string query, int topConversations, int topFragmentsPerConversation) : string
	{
		return SessionConversationSearchDriver.FindTopConversationsForQuery(query, topConversations, topFragmentsPerConversation);
	}
}

[SemanticProgram.InfinitivePhrase("to search ontology foundry conversations exactly")]
prototype ToOntologyFoundryFindExactConversationsForProbe : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"query - exact text probe. topConversations and topFragmentsPerConversation - explicit bounded result limits.";

	function Execute(string query, int topConversations, int topFragmentsPerConversation) : string
	{
		return SessionConversationSearchDriver.FindExactConversationsForQuery(query, topConversations, topFragmentsPerConversation);
	}
}

