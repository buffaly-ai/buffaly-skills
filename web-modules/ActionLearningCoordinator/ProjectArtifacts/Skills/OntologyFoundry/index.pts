prototype ToOntologyFoundrySearchSessionMessages : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"search - focused surface-form or hard-identity probe. maxRows - bounded user-message results.";

	function Execute(string search, int maxRows = 25) : string
