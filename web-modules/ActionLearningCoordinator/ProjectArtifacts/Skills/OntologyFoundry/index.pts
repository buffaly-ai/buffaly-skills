}

[SemanticProgram.InfinitivePhrase("to search ontology foundry source final assistant messages")]
prototype ToOntologyFoundrySearchSessionFinalAssistantMessages : OntologyFoundrySkillAction, OntologyFoundryActionRoot
{
	Description = @"search - focused outcome-language probe. maxRows - bounded final-assistant results.";

	function Execute(string search, int maxRows = 25) : string
