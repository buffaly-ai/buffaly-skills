}

[SemanticProgram.InfinitivePhrase("to generalize related physical objects into ontology")]
[SemanticProgram.InfinitivePhrase("to discover and organize physical peers in ontology")]
[SemanticProgram.InfinitivePhrase("to run ontology foundry generalization")]
