prototype OntologyFoundryPromptAction : OntologyFoundryActionRoot
{
	Description = @"Base prompt action type for Ontology Foundry workflows.";
	Bool IsPromptAction = true;
	String PromptPath = new String();
	String SkillVersion = new String();

	function Execute() : string
	{
		String promptText = _opsAgent.LoadTrustedPromptText(PromptPath);
		return "## Prompt Skill Instructions\nFollow this procedure to produce the requested result. This action returns guidance, not the result.\nPrompt source: " + PromptPath + "\n\n" + promptText;
	}
}

[SemanticProgram.InfinitivePhrase("to run ontology foundry evidence graph learning")]
[SemanticProgram.InfinitivePhrase("to generate ontology candidates from session evidence")]
prototype ToRunOntologyFoundryEvidenceGraphSkill : OntologyFoundryPromptAction, OntologyFoundryActionRoot
{
	IsPromptAction = true;
	SkillVersion = "2.0.0";
	PromptPath = @"Skills/OntologyFoundry/Prompts/EvidenceGraph-LearnFromEntitySearch.prompt.md";
	Description = @"Runs bounded candidate learning from persisted historical entity-search episodes plus current ontology and conversation evidence, revising one evidence-graph.md artifact and stopping before ontology writes.";
}

[SemanticProgram.InfinitivePhrase("to expand an ontology entity from session evidence")]
[SemanticProgram.InfinitivePhrase("to run ontology foundry entity expansion")]
[SemanticProgram.InfinitivePhrase("to expand and enhance an ontology entity")]
