prototype ToGetActionLearningWorkspaceDefinition : ActionLearningCoordinatorSkillAction, SessionWorkWorkspaceDefinitionProvider
{
	function Execute() : string
	{
		return @"{""SchemaVersion"":1,""WorkspaceId"":""action-learning"",""DisplayName"":""Action Learning"",""Description"":""Evidence-bound reusable action candidates by source session."",""WorkerAgentName"":""action-learning"",""WorkerSessionSuffix"":""-action-learning"",""ArtifactPath"":""artifacts/action-learning/action-candidates.md"",""AttachAction"":""ToAttachActionLearningWorker"",""PreviewTitle"":""Discovered reusable actions"",""PreviewDescription"":""Bounded candidate preview from the living source artifact.""}";
