[SemanticProgram.InfinitivePhrase("to attach an ontology foundry worker to a source session")]
prototype ToAttachOntologyFoundryWorker : OntologyFoundryCoordinatorSkillAction
{
	function Execute(string sourceSessionKey, string workerSessionKey) : string
	{
		CreateAgentInitializationContract initialization = new CreateAgentInitializationContract();
		initialization.ParentSessionKey = sourceSessionKey;
		BuffalyAgentService.CreateAgentFromProject(workerSessionKey, @"OpsAgent", @"ontology-foundry", initialization);
		JsonObject receipt = new JsonObject(ToAddSessionWorkEntry.Execute(sourceSessionKey));
		JsonObject ledger = receipt.GetJsonObjectOrFail(@"Ledger", @"Session work attachment receipt Ledger is required.");
		JsonArray entries = ledger.GetJsonArrayOrFail(@"Entries", @"Session work ledger Entries is required.");
		foreach (JsonValue value in entries)
		{
			JsonObject entry = value.ToJsonObjectOrFail(@"Session work ledger entries must be objects.");
			if (entry.GetStringOrFail(@"SourceSessionKey", @"Session work entry SourceSessionKey is required.") == sourceSessionKey)
			{
				entry[@"WorkerSessionKey"] = workerSessionKey;
				entry[@"WorkerAgentName"] = @"ontology-foundry";
				entry[@"ProcessorSkill"] = @"OntologyFoundrySkill";
				entry[@"OperationState"] = @"Attached";
			}
		}
		ledger[@"Entries"] = entries;
		FileSystemTools.ReplaceTextFile(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json", ledger.ToJSON());
		JsonObject attached = new JsonObject();
		attached[@"Outcome"] = @"Attached";
		attached[@"SourceSessionKey"] = sourceSessionKey;
		attached[@"WorkerSessionKey"] = workerSessionKey;
		attached[@"Ledger"] = ledger;
		return attached.ToJSON();
	}
}

[SemanticProgram.InfinitivePhrase("to run an ontology foundry worker operation")]
prototype ToRunOntologyFoundryWorkerOperation : OntologyFoundryCoordinatorSkillAction
{
	function Execute(string sourceSessionKey, string actionPrototypeName, string inputValue = @"") : string
	{
		Sessions.ValidateSessionKey(sourceSessionKey);
		JsonObject ledger = new JsonObject(ToGetSessionWorkLedger.Execute());
		JsonArray entries = ledger.GetJsonArrayOrFail(@"Entries", @"Session work ledger Entries is required.");
		string workerSessionKey = @"";
		foreach (JsonValue value in entries)
		{
			JsonObject entry = value.ToJsonObjectOrFail(@"Session work ledger entries must be objects.");
			if (entry.GetStringOrFail(@"SourceSessionKey", @"Session work entry SourceSessionKey is required.") == sourceSessionKey)
			{
				workerSessionKey = entry.GetStringOrFail(@"WorkerSessionKey", @"An attached Ontology Foundry worker is required.");
			}
		}
		if (String.IsNullOrWhiteSpace(workerSessionKey))
		{
			throw new InvalidOperationException(@"No attached Ontology Foundry worker was found for source session " + sourceSessionKey);
		}
		SessionInfo source = BuffalySessionsService.GetRecentSessions(1, 0, sourceSessionKey)[0];
		if (source.SessionKey != sourceSessionKey)
		{
			throw new InvalidOperationException(@"Exact source session inventory row was not found: " + sourceSessionKey);
		}
		string sourceSnapshot = @"SessionKey=" + source.SessionKey + @";UpdatedUtc=" + source.UpdatedUtc + @";LastFinalMessageUtc=" + source.LastFinalMessageUtc + @";MessageCount=" + source.MessageCount;
		string instruction = OntologyFoundryProposalProjection.BuildWorkerInstruction(actionPrototypeName, sourceSessionKey, sourceSnapshot, inputValue);
		EvaluateInputContract input = new EvaluateInputContract();
		input.Instruction = instruction;
		input.PromptContext = @"none";
		EvaluateResponse response = BuffalyAgentService.EvaluateWithInputWorkerDispatch(workerSessionKey, input);
		JsonObject result = new JsonObject();
		result[@"SourceSessionKey"] = sourceSessionKey;
		result[@"WorkerSessionKey"] = workerSessionKey;
		result[@"ActionPrototypeName"] = actionPrototypeName;
		result[@"SourceSnapshot"] = sourceSnapshot;
		result[@"Status"] = response.Status;
		result[@"IsRunning"] = response.IsRunning;
		result[@"Message"] = response.Message;
		result[@"Error"] = response.Error;
		return result.ToJSON();
	}
	Description = @"Runs one allowlisted Ontology Foundry prompt operation on the exact source-attached worker and returns its canonical dispatch or terminal status.";
}
