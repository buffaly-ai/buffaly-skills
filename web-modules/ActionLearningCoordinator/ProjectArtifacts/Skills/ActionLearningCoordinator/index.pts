[SemanticProgram.InfinitivePhrase("to get an ontology foundry source workspace")]
prototype ToGetOntologyFoundrySourceWorkspace : OntologyFoundryCoordinatorSkillAction, SessionWorkItemWorkspaceProvider
{
	function Execute(string sourceSessionKey) : string
	{
		Sessions.ValidateSessionKey(sourceSessionKey);
		string path = Path.Combine(Sessions.GetSessionsRootPath(), sourceSessionKey, @"artifacts\ontology-foundry\evidence-graph.md");
		string markdown = @"";
		if (File.Exists(path))
		{
			markdown = File.ReadAllText(path);
		}
		string proposalMarkdown = markdown;
		string proposalHeading = @"## Ranked entity resolutions";
		int proposalStart = markdown.IndexOf(proposalHeading);
		if (proposalStart >= 0)
		{
			proposalMarkdown = markdown.Substring(proposalStart);
		}
		JsonArray proposalRows = new JsonArray();
		string artifactSourceSessionKey = @"";
		int existingCount = 0;
		int newCandidateCount = 0;
		int ambiguousCount = 0;
		int rejectedCount = 0;
		bool inResolutionSection = false;
		bool inResolutionTable = false;
		if (File.Exists(path))
		{
			string[] lines = File.ReadAllLines(path);
			foreach (string rawLine in lines)
			{
				string line = rawLine.Trim();
				if (line == proposalHeading)
				{
					inResolutionSection = true;
					continue;
				}
				if (!inResolutionSection)
				{
					continue;
				}
				if (line.StartsWith(@"- SourceLevel1SessionKey:"))
				{
					artifactSourceSessionKey = line.Substring(25).Trim();
					continue;
				}
				if (line.StartsWith(@"| Source Rank | Entity | Importance | Resolution |"))
				{
					inResolutionTable = true;
					continue;
				}
				if (!inResolutionTable)
				{
					continue;
				}
				if (line.StartsWith(@"### ") || line.StartsWith(@"## "))
				{
					break;
				}
				if (!line.StartsWith(@"| ") || line.StartsWith(@"|---"))
				{
					continue;
				}
				string[] columns = line.Split(@"|");
				if (columns.Length != 10)
				{
					throw new InvalidOperationException(@"Ranked entity resolution rows must contain exactly eight columns. Source=" + sourceSessionKey + @"; Row=" + line);
				}
				JsonObject proposal = new JsonObject();
				proposal[@"Rank"] = Convert.ToInt32(columns[1].Trim());
				proposal[@"Entity"] = columns[2].Trim();
				proposal[@"Importance"] = Convert.ToInt32(columns[3].Trim());
				string resolution = columns[4].Trim();
				proposal[@"Resolution"] = resolution;
				proposal[@"PrototypeCandidates"] = columns[5].Trim();
				proposal[@"SearchEvidence"] = columns[6].Trim();
				proposal[@"DetailsEvidence"] = columns[7].Trim();
				proposal[@"Reason"] = columns[8].Trim();
				proposalRows.Add(new JsonValue(proposal));
				if (resolution == @"Existing")
				{
					existingCount = existingCount + 1;
				}
				else if (resolution == @"NewCandidate")
				{
					newCandidateCount = newCandidateCount + 1;
				}
				else if (resolution == @"Ambiguous")
				{
					ambiguousCount = ambiguousCount + 1;
				}
				else if (resolution == @"Rejected")
				{
					rejectedCount = rejectedCount + 1;
				}
				else
				{
					throw new InvalidOperationException(@"Unknown ranked entity resolution classification: " + resolution);
				}
			}
		}
		JsonObject proposalProjection = new JsonObject();
		proposalProjection[@"SchemaVersion"] = 1;
		proposalProjection[@"WorkspaceSourceSessionKey"] = sourceSessionKey;
		proposalProjection[@"ArtifactSourceSessionKey"] = artifactSourceSessionKey;
		proposalProjection[@"TotalCount"] = proposalRows.Count;
		proposalProjection[@"ExistingCount"] = existingCount;
		proposalProjection[@"NewCandidateCount"] = newCandidateCount;
		proposalProjection[@"AmbiguousCount"] = ambiguousCount;
		proposalProjection[@"RejectedCount"] = rejectedCount;
		proposalProjection[@"Rows"] = proposalRows;
		JsonObject result = new JsonObject();
		result[@"ArtifactPath"] = @"artifacts/ontology-foundry/evidence-graph.md";
		result[@"ArtifactTitle"] = @"Evidence graph";
		result[@"ArtifactMarkdown"] = markdown;
		result[@"ProposalMarkdown"] = proposalMarkdown;
		result[@"ProposalProjection"] = proposalProjection;
		result[@"WorkerActions"] = new JsonArray(@"[]");
		return result.ToJSON();
	}
}

[SemanticProgram.InfinitivePhrase("to attach an ontology foundry worker to a source session")]
prototype ToAttachOntologyFoundryWorker : OntologyFoundryCoordinatorSkillAction
{
	function Execute(string sourceSessionKey, string workerSessionKey) : string
	{
		CreateAgentInitializationContract initialization = new CreateAgentInitializationContract();
		initialization.ParentSessionKey = sourceSessionKey;
		BuffalyAgentService.CreateAgentFromProject(workerSessionKey, @"OpsAgent", @"ontology-foundry", initialization);
		JsonObject receipt = new JsonObject(ToAddSessionWorkEntry.Execute(sourceSessionKey));
		JsonObject ledger = receipt.GetJsonObjectOrFail(@"Ledger", @"Session work attachment receipt Ledger is required.");
		JsonArray entries = ledger.GetJsonArrayOrFail(@"Entries", @"Session work ledger Entries is required.");
		foreach (JsonValue value in entries)
		{
			JsonObject entry = value.ToJsonObjectOrFail(@"Session work ledger entries must be objects.");
			if (entry.GetStringOrFail(@"SourceSessionKey", @"Session work entry SourceSessionKey is required.") == sourceSessionKey)
			{
				entry[@"WorkerSessionKey"] = workerSessionKey;
				entry[@"WorkerAgentName"] = @"ontology-foundry";
				entry[@"ProcessorSkill"] = @"OntologyFoundrySkill";
				entry[@"OperationState"] = @"Attached";
			}
		}
		ledger[@"Entries"] = entries;
		FileSystemTools.ReplaceTextFile(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json", ledger.ToJSON());
		JsonObject attached = new JsonObject();
		attached[@"Outcome"] = @"Attached";
		attached[@"SourceSessionKey"] = sourceSessionKey;
		attached[@"WorkerSessionKey"] = workerSessionKey;
		attached[@"Ledger"] = ledger;
		return attached.ToJSON();
	}
}
