[SemanticProgram.InfinitivePhrase("to get an action learning source workspace")]
prototype ToGetActionLearningSourceWorkspace : ActionLearningCoordinatorSkillAction, SessionWorkItemWorkspaceProvider
{
	function Execute(string sourceSessionKey) : string
	{
		Sessions.ValidateSessionKey(sourceSessionKey);
		string path = Path.Combine(Sessions.GetSessionsRootPath(), sourceSessionKey, @"artifacts\action-learning\action-candidates.md");
		string markdown = @"";
		if (File.Exists(path))
		{
			markdown = File.ReadAllText(path);
		}
		JsonObject result = new JsonObject();
		result[@"ArtifactPath"] = @"artifacts/action-learning/action-candidates.md";
		result[@"ArtifactTitle"] = @"Action candidates";
		result[@"ArtifactMarkdown"] = markdown;
		result[@"WorkerActions"] = new JsonArray(@"[""ToDiscoverActionCandidatesWithinSessionSkill"",""ToBuildActionCandidateMetricsMatrixSkill"",""ToGroundAndExpandActionCandidateSkill"",""ToEvaluateActionLearningArtifact""]");
		return result.ToJSON();
	}
}

[SemanticProgram.InfinitivePhrase("to get the ontology foundry workspace definition")]
prototype ToGetOntologyFoundryWorkspaceDefinition : OntologyFoundryCoordinatorSkillAction, SessionWorkWorkspaceDefinitionProvider
{
	function Execute() : string
	{
		return @"{""SchemaVersion"":1,""WorkspaceId"":""ontology-foundry"",""DisplayName"":""Ontology Foundry"",""Description"":""Source-owned entity evidence, prototype resolution, and Session Entity Index proposals."",""WorkerAgentName"":""ontology-foundry"",""WorkerSessionSuffix"":""-ontology-foundry"",""ArtifactPath"":""artifacts/ontology-foundry/evidence-graph.md"",""AttachAction"":""ToAttachOntologyFoundryWorker"",""PreviewTitle"":""Entity evidence graph"",""PreviewDescription"":""Bounded evidence sections from the living source artifact.""}";
	}
}

