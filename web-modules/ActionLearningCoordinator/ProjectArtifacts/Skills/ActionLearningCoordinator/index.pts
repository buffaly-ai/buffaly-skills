reference Buffaly.Agent.Host Buffaly.Agent.Host;
import Buffaly.Agent.Host Buffaly.Agent.Host.BuffalyAgentService BuffalyAgentService;
import Buffaly.Agent.Host Buffaly.Agent.Host.CreateAgentInitializationContract CreateAgentInitializationContract;

[SemanticEntity("session work coordinator action root")]
prototype SessionWorkCoordinatorActionRoot : OpsAction
{
	Description = @"Restricted common action root for session-work coordinator agents.";
}

[SemanticEntity("action learning coordinator entity root")]
prototype ActionLearningCoordinatorEntityRoot : SemanticEntityBase
{
	Description = @"Restricted entity root for the Action Learning coordinator.";
}

[SemanticEntity("session work coordinator skill")]
prototype SessionWorkCoordinatorSkill : SkillEntity
{
	Description = @"Common coordinator capability for reading and maintaining a session-owned work ledger.";
	ActionRoot = SessionWorkCoordinatorActionRoot;
}

prototype SessionWorkCoordinatorSkillAction : SessionWorkCoordinatorActionRoot
{
	Description = @"Base action for common session-work coordinator operations.";
}

[SemanticEntity("action learning coordinator action root")]
prototype ActionLearningCoordinatorActionRoot : SessionWorkCoordinatorActionRoot
{
	Description = @"Restricted action root for the Action Learning coordinator.";
}

prototype ActionLearningCoordinatorSkillAction : ActionLearningCoordinatorActionRoot
{
	Description = @"Base action for Action Learning-specific coordinator operations.";
}

[SemanticEntity("action learning coordinator skill")]
prototype ActionLearningCoordinatorSkill : SessionWorkCoordinatorSkill
{
	Description = @"Coordinates Action Learning work while using the common session-work ledger surface.";
	ActionRoot = ActionLearningCoordinatorActionRoot;
}

[SemanticProgram.InfinitivePhrase("to get session work coordinator information")]
prototype ToGetSessionWorkCoordinatorInfo : SessionWorkCoordinatorSkillAction
{
	function Execute() : string
	{
		return @"{""SchemaVersion"":1,""CoordinatorSkill"":""ActionLearningCoordinatorSkill"",""BaseSkill"":""SessionWorkCoordinatorSkill"",""WorkerSkill"":""ActionLearningSkill"",""SessionKey"":""" + _opsAgent.GetSessionKeyOrEmpty() + @""",""AgentName"":""action-learning-coordinator"",""LedgerPath"":""artifacts/session-work/ledger.json""}";
	}
	Description = @"Returns the live coordinator identity and fixed ledger contract for the current session-owned runtime.";
}

[SemanticProgram.InfinitivePhrase("to get the session work ledger")]
prototype ToGetSessionWorkLedger : SessionWorkCoordinatorSkillAction
{
	function Execute() : string
	{
		string path = Path.Combine(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json");
		if (!File.Exists(path))
		{
			return @"{""SchemaVersion"":1,""CoordinatorSkill"":""ActionLearningCoordinatorSkill"",""Exists"":false,""Entries"":[]}";
		}
		return File.ReadAllText(path);
	}
	Description = @"Reads the fixed JSON ledger owned by the current coordinator session. Missing is explicit and does not create state.";
}

[SemanticProgram.InfinitivePhrase("to initialize the session work ledger")]
prototype ToInitializeSessionWorkLedger : SessionWorkCoordinatorSkillAction
{
	function Execute() : string
	{
		string path = Path.Combine(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json");
		if (File.Exists(path))
		{
			return File.ReadAllText(path);
		}
		string ledger = @"{""SchemaVersion"":1,""CoordinatorSkill"":""ActionLearningCoordinatorSkill"",""Exists"":true,""Entries"":[]}";
		FileSystemTools.ReplaceTextFile(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json", ledger);
		return ledger;
	}
	Description = @"Creates the current coordinator session's fixed initial ledger only when it is missing.";
}

[SemanticProgram.InfinitivePhrase("to add a session work entry")]
prototype ToAddSessionWorkEntry : SessionWorkCoordinatorSkillAction
{
	function Execute(string sourceSessionKey) : string
	{
		string path = Path.Combine(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json");
		JsonObject ledger = new JsonObject(@"{""SchemaVersion"":1,""CoordinatorSkill"":""ActionLearningCoordinatorSkill"",""Exists"":true,""Entries"":[]}");
		if (File.Exists(path))
		{
			ledger = new JsonObject(File.ReadAllText(path));
		}
		JsonArray entries = ledger.GetJsonArrayOrFail(@"Entries", @"Session work ledger Entries is required.");
		foreach (JsonValue value in entries)
		{
			JsonObject existing = value.ToJsonObjectOrFail(@"Session work ledger entries must be objects.");
			if (existing.GetStringOrFail(@"SourceSessionKey", @"Session work entry SourceSessionKey is required.") == sourceSessionKey)
			{
				JsonObject unchanged = new JsonObject();
				unchanged[@"Outcome"] = @"AlreadyExists";
				unchanged[@"SourceSessionKey"] = sourceSessionKey;
				unchanged[@"Ledger"] = ledger;
				return unchanged.ToJSON();
			}
		}
		JsonObject entry = new JsonObject();
		entry[@"SourceSessionKey"] = sourceSessionKey;
		entry[@"Enabled"] = true;
		entries.Add(new JsonValue(entry));
		ledger[@"Entries"] = entries;
		ledger[@"Exists"] = true;
		FileSystemTools.ReplaceTextFile(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json", ledger.ToJSON());
		JsonObject added = new JsonObject();
		added[@"Outcome"] = @"Added";
		added[@"SourceSessionKey"] = sourceSessionKey;
		added[@"Ledger"] = ledger;
		return added.ToJSON();
	}
	Description = @"Adds one exact source-session entry to the current coordinator ledger. Repeated adds are idempotent.";
}

[SemanticProgram.InfinitivePhrase("to remove a session work entry")]
prototype ToRemoveSessionWorkEntry : SessionWorkCoordinatorSkillAction
{
	function Execute(string sourceSessionKey) : string
	{
		string path = Path.Combine(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json");
		if (!File.Exists(path))
		{
			JsonObject absentLedger = new JsonObject(@"{""SchemaVersion"":1,""CoordinatorSkill"":""ActionLearningCoordinatorSkill"",""Exists"":false,""Entries"":[]}");
			JsonObject absent = new JsonObject();
			absent[@"Outcome"] = @"NotFound";
			absent[@"SourceSessionKey"] = sourceSessionKey;
			absent[@"Ledger"] = absentLedger;
			return absent.ToJSON();
		}
		JsonObject ledger = new JsonObject(File.ReadAllText(path));
		JsonArray entries = ledger.GetJsonArrayOrFail(@"Entries", @"Session work ledger Entries is required.");
		foreach (JsonValue value in entries)
		{
			JsonObject existing = value.ToJsonObjectOrFail(@"Session work ledger entries must be objects.");
			if (existing.GetStringOrFail(@"SourceSessionKey", @"Session work entry SourceSessionKey is required.") == sourceSessionKey)
			{
				entries.Remove(value);
				ledger[@"Entries"] = entries;
				FileSystemTools.ReplaceTextFile(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json", ledger.ToJSON());
				JsonObject removed = new JsonObject();
				removed[@"Outcome"] = @"Removed";
				removed[@"SourceSessionKey"] = sourceSessionKey;
				removed[@"Ledger"] = ledger;
				return removed.ToJSON();
			}
		}
		JsonObject missing = new JsonObject();
		missing[@"Outcome"] = @"NotFound";
		missing[@"SourceSessionKey"] = sourceSessionKey;
		missing[@"Ledger"] = ledger;
		return missing.ToJSON();
	}
	Description = @"Removes one exact source-session entry and reports NotFound without modifying the ledger when absent.";
}

[SemanticProgram.InfinitivePhrase("to attach an action learning worker to a source session")]
prototype ToAttachActionLearningWorker : ActionLearningCoordinatorSkillAction
{
	function Execute(string sourceSessionKey, string workerSessionKey) : string
	{
		CreateAgentInitializationContract initialization = new CreateAgentInitializationContract();
		initialization.ParentSessionKey = sourceSessionKey;
		BuffalyAgentService.CreateAgentFromProject(workerSessionKey, @"OpsAgent", @"action-learning", initialization);
		string path = Path.Combine(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json");
		JsonObject ledger = new JsonObject(@"{""SchemaVersion"":1,""CoordinatorSkill"":""ActionLearningCoordinatorSkill"",""Exists"":true,""Entries"":[]}");
		if (File.Exists(path))
		{
			ledger = new JsonObject(File.ReadAllText(path));
		}
		JsonArray entries = ledger.GetJsonArrayOrFail(@"Entries", @"Session work ledger Entries is required.");
		JsonArray updatedEntries = new JsonArray();
		bool found = false;
		foreach (JsonValue value in entries)
		{
			JsonObject entry = value.ToJsonObjectOrFail(@"Session work ledger entries must be objects.");
			if (entry.GetStringOrFail(@"SourceSessionKey", @"Session work entry SourceSessionKey is required.") == sourceSessionKey)
			{
				entry[@"WorkerSessionKey"] = workerSessionKey;
				entry[@"WorkerAgentName"] = @"action-learning";
				entry[@"ProcessorSkill"] = @"ActionLearningSkill";
				entry[@"OperationState"] = @"Attached";
				found = true;
			}
			updatedEntries.Add(new JsonValue(entry));
		}
		if (!found)
		{
			JsonObject entry = new JsonObject();
			entry[@"SourceSessionKey"] = sourceSessionKey;
			entry[@"Enabled"] = true;
			entry[@"WorkerSessionKey"] = workerSessionKey;
			entry[@"WorkerAgentName"] = @"action-learning";
			entry[@"ProcessorSkill"] = @"ActionLearningSkill";
			entry[@"OperationState"] = @"Attached";
			updatedEntries.Add(new JsonValue(entry));
		}
		ledger[@"Entries"] = updatedEntries;
		ledger[@"Exists"] = true;
		FileSystemTools.ReplaceTextFile(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\session-work\ledger.json", ledger.ToJSON());
		JsonObject receipt = new JsonObject();
		string outcome = @"Attached";
		if (found)
		{
			outcome = @"Updated";
		}
		receipt[@"Outcome"] = outcome;
		receipt[@"SourceSessionKey"] = sourceSessionKey;
		receipt[@"WorkerSessionKey"] = workerSessionKey;
		receipt[@"Ledger"] = ledger;
		return receipt.ToJSON();
	}
	Description = @"Creates or reuses the source-attached Action Learning worker and records its exact binding in the coordinator ledger.";
}

[SemanticProgram.InfinitivePhrase("to list action learning coordinator actions")]
prototype ToListActionLearningCoordinatorActions : ActionLearningCoordinatorSkillAction
{
	function Execute() : string
	{
		return @"{""CommonActions"":[""ToGetSessionWorkCoordinatorInfo"",""ToGetSessionWorkLedger"",""ToInitializeSessionWorkLedger"",""ToAddSessionWorkEntry"",""ToRemoveSessionWorkEntry""],""SpecializedActions"":[""ToAttachActionLearningWorker"",""ToListActionLearningCoordinatorActions""],""WorkerActions"":[""ToRefreshActionLearningSessionCandidatesSkill"",""ToDiscoverActionCandidatesWithinSessionSkill"",""ToBuildActionCandidateMetricsMatrixSkill"",""ToGroundAndExpandActionCandidateSkill"",""ToEvaluateActionLearningArtifact""]}";
	}
	Description = @"Returns the exact first-version coordinator and worker action names rendered by the dashboard.";
}
