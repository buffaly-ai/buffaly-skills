prototype ToGroundAndExpandActionCandidateSkill : ActionLearningPromptAction, ActionLearningActionRoot
{
	IsPromptAction = true;
	SkillKind = "prompt";
	SkillVersion = "2.0.0";
	PromptPath = @"Skills/ActionLearning/Prompts/ActionCandidateGroundingAndExpansion.prompt.md";
	Description = @"Runs the specialized ACGE procedure inside the restricted Action Learning agent and writes one fixed 16-section New Tool Artifact. It grounds neighbors only through canonical historical ToSearchCandidateActions calls and does not implement the candidate tool.";
}

