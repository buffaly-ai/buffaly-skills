reference Buffaly.SessionSemanticDatabase Buffaly.SessionSemanticDatabase;
import Buffaly.SessionSemanticDatabase Buffaly.SessionSemanticDatabase.SessionConversationSearchDriver SessionConversationSearchDriver;
import Buffaly.SessionSemanticDatabase Buffaly.SessionSemanticDatabase.SessionFragmentResolutionDriver SessionFragmentResolutionDriver;
import Buffaly.SessionSemanticDatabase Buffaly.SessionSemanticDatabase.ActionSearchTraceDriver ActionSearchTraceDriver;
import Buffaly.Agent.Host Buffaly.Agent.Host.SessionManagement.Sessions Sessions;
import Buffaly.Agent.Host Buffaly.Agent.Host.CreateAgentInitializationContract CreateAgentInitializationContract;

[SemanticEntity("action learning action root")]
prototype ActionLearningActionRoot : OpsAction
{
	Description = @"Restricted action root for the Action Learning agent.";
}
[SemanticEntity("action learning entity root")]
prototype ActionLearningEntityRoot : SemanticEntityBase
{
	Description = @"Restricted entity root for the Action Learning agent.";
}
prototype ActionLearningSkillAction : ActionLearningActionRoot
{
	Description = @"Base action type for bounded Action Learning evidence and artifact tools.";
}
[SemanticEntity("action learning skill")]
prototype ActionLearningSkill : SkillEntity
{
	Description = @"Discovers reusable action candidates from historical routes, prioritizes them across sessions, and grounds selected candidates in canonical evidence without implementing candidate tools.";
	ActionRoot = ActionLearningActionRoot;
}

include "PromptActions.pts";
[SemanticProgram.InfinitivePhrase("to create an action learning session")]
prototype ToCreateActionLearningSession : OpsAction
{
	function Execute(string sessionKey) : Prototype
	{
		return BuffalyAgentService.CreateAgentFromProject(sessionKey, "OpsAgent", "action-learning");
	}
	Description = @"Parent-coordinator action only. sessionKey is the exact new or existing child key. Creates the runtime from the current OpsAgent project using the action-learning profile.";
}
[SemanticProgram.InfinitivePhrase("to create a source attached action learning worker")]
prototype ToCreateSourceAttachedActionLearningWorker : OpsAction
{
	function Execute(string sourceSessionKey, string workerSessionKey) : Prototype
	{
		CreateAgentInitializationContract initialization = new CreateAgentInitializationContract();
		initialization.ParentSessionKey = sourceSessionKey;
		return BuffalyAgentService.CreateAgentFromProject(workerSessionKey, "OpsAgent", "action-learning", initialization);
	}
	Description = @"Parent-coordinator action only. Creates or reuses one deterministic action-learning worker as a child of the exact source session.";
}
[SemanticProgram.InfinitivePhrase("to continue an action learning session")]
prototype ToContinueActionLearningSession : OpsAction
{
	function Execute(string sessionKey, string instruction) : Prototype
	{
		return BuffalyAgentService.CreateChildSession(_opsAgent.GetSessionKeyOrEmpty(), sessionKey, instruction, 900, null);
	}
	Description = @"Parent-coordinator action only. Continues one attached Action Learning child through the typed cross-worker session relay.";
}
[SemanticProgram.InfinitivePhrase("to get the current action learning worker context")]
prototype ToGetActionLearningWorkerContext : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute() : string
	{
		string sessionKey = _opsAgent.GetSessionKeyOrEmpty();
		string parentSessionKey = SessionTools.GetParentSessionKeyTool(sessionKey);
		return "SessionKey=" + sessionKey + ";ParentSessionKey=" + parentSessionKey;
	}
	Description = @"Returns the current restricted Action Learning worker key and its authoritative parent session key.";
}
[SemanticProgram.InfinitivePhrase("to get recent session turns for action learning")]
prototype ToActionLearningGetRecentSessionTurns : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string sessionKey, int maxTurns = 10) : GetSessionTurnBootstrapResponse
	{
		return SessionTools.GetRecentSessionTurnsTool(sessionKey, maxTurns);
	}
	Description = @"Bounded wrapper for recent source-session turn summaries.";
}
[SemanticProgram.InfinitivePhrase("to page session turns for action learning")]
prototype ToActionLearningGetSessionTurnPage : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string sessionKey, int skipTurns, int maxTurns = 10) : GetSessionTurnPageResponse
	{
		return SessionTools.GetSessionTurnPageTool(sessionKey, skipTurns, maxTurns);
	}
	Description = @"Bounded wrapper for paging older source-session turn summaries.";
}
[SemanticProgram.InfinitivePhrase("to inspect a session turn for action learning")]
prototype ToActionLearningGetSessionTurnDetail : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string sessionKey, string turnId, int maxRows = 200) : GetTurnDetailResponse
	{
		return SessionTools.GetSessionTurnDetailTool(sessionKey, turnId, maxRows);
	}
	Description = @"Bounded wrapper for canonical source-session calls, results, chronology, and outcome.";
}
