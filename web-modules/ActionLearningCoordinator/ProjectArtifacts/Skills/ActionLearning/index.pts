[SemanticProgram.InfinitivePhrase("to write the current action learning portfolio")]
prototype ToWriteActionLearningPortfolio : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string markdown) : string
	{
		return FileSystemTools.ReplaceTextFile(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\action-learning\portfolio.md", markdown);
	}
	Description = @"Replaces the current Action Learning session's fixed artifacts/action-learning/portfolio.md file with complete Markdown.";
}
[SemanticProgram.InfinitivePhrase("to write the current new tool artifact")]
prototype ToWriteNewToolArtifact : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string markdown) : string
	{
		return FileSystemTools.ReplaceTextFile(_opsAgent.GetCurrentSessionDirectory(), @"artifacts\action-learning\new-tool-artifact.md", markdown);
	}
	Description = @"Replaces the current Action Learning session's one fixed artifacts/action-learning/new-tool-artifact.md file with complete Markdown.";
