prototype ToActionLearningSearchSessionMessages : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string search, int maxRows = 25) : string
	{
		return SessionTools.SearchSessionMessagesTool(search, maxRows);
	}
	Description = @"Bounded wrapper for exact historical user-message lookup.";
}
[SemanticProgram.InfinitivePhrase("to search final assistant messages for action learning")]
prototype ToActionLearningSearchSessionFinalAssistantMessages : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string search, int maxRows = 25) : string
	{
		return SessionTools.SearchSessionFinalAssistantMessagesTool(search, maxRows);
	}
	Description = @"Bounded wrapper for exact historical terminal-outcome lookup.";
}
[SemanticProgram.InfinitivePhrase("to search related conversations for action learning")]
prototype ToActionLearningFindHybridConversationsForQuery : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string query, int topConversations, int topFragmentsPerConversation) : string
	{
		return SessionConversationSearchDriver.FindHybridConversationsForQuery(query, topConversations, topFragmentsPerConversation);
	}
	Description = @"Bounded hybrid semantic/exact conversation search. Returned fragments are leads until canonical action-search calls verify them.";
}
[SemanticProgram.InfinitivePhrase("to resolve a session from a semantic fragment for action learning")]
prototype ToActionLearningResolveSessionFromSemanticFragment : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(int fragmentID) : string
	{
		return SessionFragmentResolutionDriver.ResolveSessionFromFragment(fragmentID);
	}
	Description = @"Resolves one semantic fragment lead to its canonical owning session.";
}
[SemanticProgram.InfinitivePhrase("to get historical action search triggers")]
prototype ToActionLearningGetActionSearchTriggers : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string sessionKey, string turnID = "", int maxTriggers = 50) : string
	{
		return ActionSearchTraceDriver.GetActionSearchTriggers(sessionKey, turnID, maxTriggers);
	}
	Description = @"Returns exact persisted ToSearchCandidateActions calls for one bounded session or turn, including canonical phrase normalization and message references.";
}
[SemanticProgram.InfinitivePhrase("to resolve a historical action search trigger fragment")]
prototype ToActionLearningResolveTriggerFragment : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string semanticQuery) : string
	{
		return ActionSearchTraceDriver.ResolveTriggerFragment(semanticQuery);
	}
	Description = @"Resolves an existing normalized historical action-search fragment and current vector state without inserting or embedding anything.";
}
[SemanticProgram.InfinitivePhrase("to find historical action search trigger neighbors")]
prototype ToActionLearningFindTriggerNeighbors : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string semanticQuery, int maxNeighbors = 10, int maxSampleCalls = 3) : string
	{
		return ActionSearchTraceDriver.FindTriggerNeighbors(semanticQuery, maxNeighbors, maxSampleCalls);
	}
	Description = @"Returns semantic neighbors only when each neighbor phrase maps back to canonical historical ToSearchCandidateActions calls; unrelated fragments are excluded.";
}
[SemanticProgram.InfinitivePhrase("to search candidate actions for action learning")]
prototype ToActionLearningSearchCandidateActions : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string semanticQuery, int maxResults = 10) : string
	{
		return ToSearchCandidateActions.Execute(semanticQuery, maxResults);
	}
	Description = @"Checks how exact observed historical trigger wording resolves against the current action catalog.";
}
[SemanticProgram.InfinitivePhrase("to inspect an action owner for action learning")]
prototype ToActionLearningGetPrototypeDetails : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string prototype) : string
	{
		return ToGetPrototypeDetails.Execute(prototype);
	}
	Description = @"Inspects one exact plausible current owner returned by action discovery.";
}
[SemanticProgram.InfinitivePhrase("to list an owner skill actions for action learning")]
prototype ToActionLearningListSkillActions : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(SkillEntity skill) : Collection
	{
		return ToListSkillActions.Execute(skill);
	}
	Description = @"Lists one exact plausible current owner's action surface while preserving the native collection of action prototypes.";
}
[SemanticProgram.InfinitivePhrase("to read a source session action learning candidate artifact")]
prototype ToReadActionLearningCandidateArtifact : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string sourceSessionKey) : string
	{
		Sessions.ValidateSessionKey(sourceSessionKey);
		string path = Path.Combine(Sessions.GetSessionsRootPath(), sourceSessionKey, @"artifacts\action-learning\action-candidates.md");
		if (!File.Exists(path))
		{
			return "";
		}
		return File.ReadAllText(path);
	}
	Description = @"Reads the exact source session's living artifacts/action-learning/action-candidates.md. Missing returns an empty string.";
}
[SemanticProgram.InfinitivePhrase("to write a source session action learning candidate artifact")]
prototype ToWriteActionLearningCandidateArtifact : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute(string sourceSessionKey, string markdown) : string
	{
		Sessions.ValidateSessionKey(sourceSessionKey);
		return FileSystemTools.ReplaceTextFile(
			Path.Combine(Sessions.GetSessionsRootPath(), sourceSessionKey),
			@"artifacts\action-learning\action-candidates.md",
			markdown);
	}
	Description = @"Replaces the exact source session's complete living artifacts/action-learning/action-candidates.md artifact.";
}
[SemanticProgram.InfinitivePhrase("to read the current new tool artifact")]
prototype ToReadNewToolArtifact : ActionLearningSkillAction, ActionLearningActionRoot
{
	function Execute() : string
	{
		string root = _opsAgent.GetCurrentSessionDirectory();
		string path = Path.Combine(root, @"artifacts\action-learning\new-tool-artifact.md");
		if (!File.Exists(path))
		{
			return "";
		}
		return File.ReadAllText(path);
	}
	Description = @"Reads the current Action Learning session's one fixed New Tool Artifact. Missing returns an empty string.";
}
