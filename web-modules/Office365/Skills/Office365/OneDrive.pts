[SemanticProgram.InfinitivePhrase("to upload a local file to office 365 onedrive")]
prototype ToUploadOffice365OneDriveFileFromDisk : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to files.readwrite when empty. parentFolderId/localFilePath/fileName/mimeType are required by schema. Pass empty fileName and/or mimeType to use runtime defaults. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string parentFolderId, string localFilePath, string fileName, string mimeType) : string
	{
		scopePreset = ToNormalizeOffice365OneDriveScopePreset(scopePreset, "files.readwrite");

		if (StringUtil.IsEmpty(localFilePath))
			return "localFilePath is required.";

		if (StringUtil.IsEmpty(fileName))
			fileName = Path.GetFileName(localFilePath);

		if (StringUtil.IsEmpty(fileName))
			return "fileName is required.";

		if (StringUtil.IsEmpty(mimeType))
			mimeType = "application/octet-stream";

		string base64Content = Convert.ToBase64String(File.ReadAllBytes(localFilePath));

		// Return facade JSON without reshaping.
		return Office365ServiceHost.UploadFileBase64Async(			Office365Service.NormalizeOffice365AccountKey(accountKey),
			NormalizeOffice365OperationScopePreset(scopePreset),
			fileName,
			base64Content,
			parentFolderId,
			mimeType,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to upload a local file to office 365 onedrive")]
prototype ToUploadOffice365OneDriveFileFromDiskQuick : Office365SkillAction
{
	Description = @"Convenience overload with minimal inputs. Uses scopePreset files.readwrite and defaults fileName/mimeType. accountKey/parentFolderId/localFilePath are required. Returns JSON.";

	function Execute(string accountKey, string parentFolderId, string localFilePath) : string
	{
		return ToUploadOffice365OneDriveFileFromDisk.Execute(accountKey, "files.readwrite", parentFolderId, localFilePath, "", "");
	}
}

