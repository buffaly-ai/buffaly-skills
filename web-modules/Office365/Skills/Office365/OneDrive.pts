[SemanticProgram.InfinitivePhrase("to grant a onedrive file permission")]
prototype ToGrantOffice365OneDriveFilePermission : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset defaults to files.readwrite. fileId/permissionType/role required. user/group requires emailAddress. domain requires domain. Optional allowFileDiscovery/sendNotificationEmail/emailMessage/transferOwnership.";

	function Execute(string accountKey, string scopePreset, string fileId, string permissionType, string role, string emailAddress, string domain, bool allowFileDiscovery, bool sendNotificationEmail, string emailMessage, bool transferOwnership) : string
	{
		scopePreset = ToNormalizeOffice365OneDriveScopePreset(scopePreset, "files.readwrite");

		bool sendAllowFileDiscovery = allowFileDiscovery;
		if (StringUtil.EqualNoCase(permissionType, "user") || StringUtil.EqualNoCase(permissionType, "group"))
			sendAllowFileDiscovery = false;

		return Office365ServiceHost.CreatePermissionAsync(			Office365Service.NormalizeOffice365AccountKey(accountKey),
			NormalizeOffice365OperationScopePreset(scopePreset),
			fileId,
			permissionType,
			role,
			emailAddress,
			domain,
			sendAllowFileDiscovery,
			sendNotificationEmail,
			emailMessage,
			transferOwnership,
			false,
			new CancellationToken(false));
	}
}



