function ToNormalizeOffice365OneDriveScopePreset(string scopePreset, string fallbackPreset) : string
{
	if (StringUtil.IsEmpty(scopePreset))
		return fallbackPreset;

	string normalized = scopePreset.Trim().ToLowerInvariant();
	if (normalized == "files.readwrite")
		return "files.readwrite";
	if (normalized == "files.readonly")
		return "files.read";

	return scopePreset;
}

[SemanticProgram.InfinitivePhrase("to search office 365 OneDrive files")]
prototype ToSearchOffice365OneDriveFiles : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to files.read when empty. query - OneDrive query. maxResults - number of rows. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string query, int maxResults) : string
	{
		scopePreset = ToNormalizeOffice365OneDriveScopePreset(scopePreset, "files.read");

		// Return facade JSON without reshaping.
		return Office365ServiceHost.SearchFilesAsync(			Office365Service.NormalizeOffice365AccountKey(accountKey),
			NormalizeOffice365OperationScopePreset(scopePreset),
			query,
			maxResults,
			false,
			new CancellationToken(false));
	}
}

