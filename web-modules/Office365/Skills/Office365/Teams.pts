function ToNormalizeOffice365TeamsSpace(string space) : string
{
	if (StringUtil.IsEmpty(space))
		return "";

	if (space.StartsWith("spaces/"))
		return space;

	return "spaces/" + space;
}

function ToEscapeForSingleQuotedPowerShell(string value) : string
{
	if (value == null)
		return "";

	return value.Replace("'", "''");
}

function ToNormalizeOffice365TeamsScopePreset(string scopePreset, bool forWrite) : string
{
	if (StringUtil.IsEmpty(scopePreset))
	{
		if (forWrite)
			return "teams.write";
		return "teams.read";
	}

	string lowered = scopePreset.ToLower();

	// NOTE (Buffaly): Teams scope remap temporarily disabled (kept below as comments).
	// Reason: coercing teams.* to workspace.* prevented Teams scopes from showing on OAuth consent.
	// Not 100% certain old behavior is never required, so preserving for future rollback/audit.
	// if (lowered.StartsWith("Teams"))
	// {
	// 	if (forWrite)
	// 		return "teams.write";
	// 	return "teams.read";
	// }

	return scopePreset;
}

function ToFilterOffice365TeamsSpacesFacadeJson(string facadeJson, bool joinedOnly, string spaceType) : string
{
	if (StringUtil.IsEmpty(facadeJson))
		return facadeJson;

	string joinedOnlyText = "false";
	if (joinedOnly)
		joinedOnlyText = "true";

	string safeFacadeJson = ToEscapeForSingleQuotedPowerShell(facadeJson);
	string safeSpaceType = ToEscapeForSingleQuotedPowerShell(spaceType);
	string safeJoinedOnly = ToEscapeForSingleQuotedPowerShell(joinedOnlyText);

	string script = "$root = ConvertFrom-Json -InputObject '" + safeFacadeJson + "'; " +
		"if ($root -ne $null -and $root.ok -eq $true -and $root.data -ne $null -and $root.data.spaces -ne $null) { " +
		"  $spaces = @($root.data.spaces); " +
		"  if ('" + safeSpaceType + "' -ne '') { $spaces = @($spaces | Where-Object { $_.spaceType -eq '" + safeSpaceType + "' -or $_.type -eq '" + safeSpaceType + "' }) }; " +
		"  if ('" + safeJoinedOnly + "' -eq 'true') { $spaces = @($spaces | Where-Object { ($_.membershipState -eq $null) -or ($_.membershipState -eq 'JOINED') -or ($_.membership -eq 'JOINED') }) }; " +
		"  $root.data.spaces = $spaces; " +
		"  $root.data.count = @($spaces).Count; " +
		"}; " +
		"$root | ConvertTo-Json -Depth 50";

	return SystemOperations.RunPowerShell(script);
}

[SemanticProgram.InfinitivePhrase("to list office 365 teams channels/spaces from account")]
[SemanticProgram.InfinitivePhrase("to list teams channels using office 365 account")]
prototype ToListOffice365TeamsSpacesByAccount : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to teams.read when empty. Teams aliases like teams.read/teams.write are normalized to workspace presets. pageSize - 1..1000. pageToken optional. joinedOnly - true to keep joined spaces when membership metadata is present (best effort). spaceType optional filter such as SPACE, GROUP_Teams, or DIRECT_MESSAGE. Returns Teams API JSON page.";

	function Execute(string accountKey, string scopePreset, int pageSize, string pageToken, bool joinedOnly, string spaceType) : string
	{
		return Office365ServiceHost.ListSpacesAsync(			Office365Service.NormalizeOffice365AccountKey(accountKey),
			ToNormalizeOffice365TeamsScopePreset(scopePreset, false),
			pageSize,
			pageToken,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to list office 365 teams messages page from account")]
prototype ToListOffice365TeamsMessagesPageByAccount : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to teams.read when empty. Teams aliases like teams.read/teams.write are normalized to workspace presets. space - Teams space id or spaces/{id}. pageSize - 1..1000. pageToken optional. Returns Teams API JSON page.";

	function Execute(string accountKey, string scopePreset, string space, int pageSize, string pageToken) : string
	{
		return Office365ServiceHost.ListMessagesPageAsync(			Office365Service.NormalizeOffice365AccountKey(accountKey),
			ToNormalizeOffice365TeamsScopePreset(scopePreset, false),
			ToNormalizeOffice365TeamsSpace(space),
			pageSize,
			pageToken,
			false,
			new CancellationToken(false));
	}
}



[SemanticProgram.InfinitivePhrase("to send an office 365 teams message from account")]
[SemanticProgram.InfinitivePhrase("to send a teams message from account")]
prototype ToSendOffice365TeamsMessageByAccount : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to teams.write when empty. Teams aliases like teams.read/teams.write are normalized to workspace presets. space - Teams space id or spaces/{id}. messageText - text payload. Returns Teams API JSON.";

	function Execute(string accountKey, string scopePreset, string space, string messageText) : string
	{
		return Office365ServiceHost.SendMessageAsync(			Office365Service.NormalizeOffice365AccountKey(accountKey),
			ToNormalizeOffice365TeamsScopePreset(scopePreset, true),
			ToNormalizeOffice365TeamsSpace(space),
			messageText,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to list office 365 teams messages from account")]
[SemanticProgram.InfinitivePhrase("to receive teams messages from account")]
prototype ToListOffice365TeamsMessagesByAccount : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to teams.read when empty. Teams aliases like teams.read/teams.write are normalized to workspace presets. space - Teams space id or spaces/{id}. pageSize - 1..1000. Returns Teams API JSON page.";

	function Execute(string accountKey, string scopePreset, string space, int pageSize) : string
	{
		return ToListOffice365TeamsMessagesPageByAccount.Execute(accountKey, scopePreset, space, pageSize, "");
	}
}


