[SemanticProgram.InfinitivePhrase("to remove an office 365 account")]
prototype ToRemoveOffice365Account : Office365SkillAction
{
	Description = @"accountKey - stored account key to remove. Returns JSON.";

	function Execute(string accountKey) : string
	{
