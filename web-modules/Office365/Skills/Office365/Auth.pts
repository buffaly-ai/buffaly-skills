[SemanticProgram.InfinitivePhrase("to start office 365 authorization")]
[SemanticProgram.InfinitivePhrase("to get an office 365 authorization redirect url")]
[SemanticProgram.InfinitivePhrase("to get an office 365 authorization token")]
prototype ToStartOffice365Authorization : Office365SkillAction
{
	Description = @"accountKey - account key without spaces (will be prefixed Office365#). scopePreset - scope preset such as mail.read or mail.send calendars.readwrite. returnUrl - optional return URL. forceConsent - true to force consent. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string returnUrl, bool forceConsent) : string
	{
		scopePreset = ToNormalizeOffice365ScopePreset(scopePreset);

		return Office365ServiceHost.StartAuthorization(
			Office365Service.NormalizeOffice365AccountKey(accountKey),
			NormalizeOffice365OperationScopePreset(scopePreset),
			returnUrl,
			forceConsent,
			false);
	}
}

[SemanticProgram.InfinitivePhrase("to complete office 365 authorization")]
[SemanticProgram.InfinitivePhrase("to finalize office 365 oauth authorization")]
prototype ToCompleteOffice365Authorization : Office365SkillAction
{
	Description = @"Backup/fallback completion only. Normal users should complete Office 365 OAuth from the accounts page. state - fresh encoded authorization state from the callback. code - fresh one-time OAuth callback code. Returns JSON.";

	function Execute(string state, string code) : string
	{
		Office365Service.Initialize();

		return Office365ServiceHost.CompleteAuthorizationAsync(
			state,
			code,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to refresh office 365 authorization")]
[SemanticProgram.InfinitivePhrase("to refresh office 365 mail authorization")]
prototype ToRefreshOffice365Authorization : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - scope preset, defaults to mail.read when empty. Returns JSON.";

	function Execute(string accountKey, string scopePreset) : string
	{
		scopePreset = ToNormalizeOffice365ScopePreset(scopePreset);

		return Office365ServiceHost.RefreshAuthorizationAsync(
			Office365Service.NormalizeOffice365AccountKey(accountKey),
			NormalizeOffice365OperationScopePreset(scopePreset),
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to revoke office 365 authorization")]
[SemanticProgram.InfinitivePhrase("to revoke office 365 mail authorization")]
prototype ToRevokeOffice365Authorization : Office365SkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - scope preset. Returns JSON.";

	function Execute(string accountKey, string scopePreset) : string
	{
		scopePreset = ToNormalizeOffice365ScopePreset(scopePreset);

		return Office365ServiceHost.RevokeAuthorizationAsync(
			Office365Service.NormalizeOffice365AccountKey(accountKey),
			NormalizeOffice365OperationScopePreset(scopePreset),
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to list office 365 authorized accounts")]
prototype ToListOffice365Accounts : Office365SkillAction
{
	Description = @"Lists all stored Office 365 accounts. Returns JSON.";

	function Execute() : string
	{
		return Office365ServiceHost.ListAccounts();
	}
}

[SemanticProgram.InfinitivePhrase("to get an office 365 account")]
prototype ToGetOffice365Account : Office365SkillAction
{
	Description = @"accountKey - stored account key to retrieve. Returns JSON.";

	function Execute(string accountKey) : string
	{
		return Office365ServiceHost.GetAccount(Office365Service.NormalizeOffice365AccountKey(accountKey));
	}
}

[SemanticProgram.InfinitivePhrase("to set the default office 365 account")]
prototype ToSetDefaultOffice365Account : Office365SkillAction
{
	Description = @"accountKey - stored account key to set as default. Returns JSON.";

	function Execute(string accountKey) : string
	{
		return Office365ServiceHost.SetDefaultAccount(Office365Service.NormalizeOffice365AccountKey(accountKey));
