import BasicUtilities BasicUtilities.StringUtil StringUtil;

function NormalizeOffice365OperationScopePreset(string scopePreset) : string
{
	if (StringUtil.IsEmpty(scopePreset))
		return "mail.read";

	string normalized = scopePreset.Trim().ToLowerInvariant();

	if (normalized == "mail.read" || normalized == "mail.send" || normalized == "mail.modify" || normalized.Contains("mail"))
		return normalized;

	if (normalized.Contains("calendar") || normalized.Contains("calendars"))
		return normalized;

	if (normalized.Contains("files") || normalized.Contains("onedrive") || normalized.Contains("drive"))
		return normalized;

	if (normalized.Contains("readonly") || normalized.EndsWith(".read"))
		return normalized.Replace(".write", ".read");

	return "mail.read";
}

function ToNormalizeOffice365ScopePreset(string scopePreset) : string
{
	if (StringUtil.IsEmpty(scopePreset))
		return "mail.read";

	string lowered = scopePreset.ToLower();

	if (lowered == "mail.read" || lowered == "mail.send")
		return lowered;

	return scopePreset;
}
