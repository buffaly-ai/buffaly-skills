{
    "LogSettings":  {
                        "Application":  "Buffaly.CodexEmbedded.Web",
                        "DebugPath":  "c:\\logs\\Buffaly",
                        "DebugLevel":  "VERBOSE"
                    },
    "CodexPath":  "codex",
    "WebLaunchUrl":  "http://127.0.0.1:5225/",
    "CodexInstallHelpUrl":  "/help/codex-install",
    "DefaultCwd":  ".",
    "TurnTimeoutSeconds":  1200,
    "TurnSlotWaitTimeoutSeconds":  1200,
    "TurnSlotWaitPollSeconds":  2,
    "RunningRecoveryRefreshSeconds":  5,
    "RunningRecoveryActiveWindowMinutes":  120,
    "RunningRecoveryTailLineLimit":  3000,
    "RunningRecoveryScanMaxSessions":  200,
    "LogRootPath":  "logs/web/sessions",
    "EnableUserHeaderIdentity":  false,
    "TrustedUserHeaderName":  "X-Buffaly-UserId",
    "UserIdentityCookieName":  "buffaly_user_id",
    "WebSocketAuthRequired":  true,
    "WebSocketAuthToken":  "buffaly",
    "PublicExposureEnabled":  false,
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "AllowedHosts":  "*"
}
