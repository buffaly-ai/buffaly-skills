[SemanticProgram.InfinitivePhrase("to replace text in a google docs document")]
prototype ToReplaceTextInGoogleWorkspaceDocument : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to docs.write when empty. documentId/searchText/replaceText required. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string documentId, string searchText, string replaceText) : string
	{
		if (StringUtil.IsEmpty(scopePreset))
			scopePreset = "docs.write";

		string replacementsJson = "{\"" + searchText + "\":\"" + replaceText + "\"}";

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.ReplaceTextAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			documentId,
			replacementsJson,
			false,
			new CancellationToken(false));
	}
}

