[SemanticProgram.InfinitivePhrase("to get a google docs document")]
prototype ToGetGoogleWorkspaceDocument : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to docs.read when empty. documentId required. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string documentId) : string
	{
		if (StringUtil.IsEmpty(scopePreset))
			scopePreset = "docs.read";

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.GetDocumentAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			documentId,
			false,
			false,
			new CancellationToken(false));
	}
}

