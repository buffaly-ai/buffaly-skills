[SemanticProgram.InfinitivePhrase("to list google calendar events")]
prototype ToListGoogleWorkspaceCalendarEvents : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to calendar.readonly when empty. calendarId/timeMinIso/timeMaxIso/maxResults/query control listing. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string calendarId, string timeMinIso, string timeMaxIso, int maxResults, string query) : string
	{
		if (StringUtil.IsEmpty(scopePreset))
			scopePreset = "calendar.readonly";

		return GoogleWorkspaceServiceHost.ListEventsAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			scopePreset,
			calendarId,
			timeMinIso,
			timeMaxIso,
			maxResults,
			query,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to get a google calendar event")]
prototype ToGetGoogleWorkspaceCalendarEvent : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to calendar.readonly when empty. calendarId and eventId required. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string calendarId, string eventId) : string
	{
		if (StringUtil.IsEmpty(scopePreset))
			scopePreset = "calendar.readonly";

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.GetEventAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			eventId,
			calendarId,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to create a google calendar event")]
prototype ToCreateGoogleWorkspaceCalendarEvent : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to calendar when empty. calendarId/summary/startIso/endIso required. timeZone/description/location/attendeesJson optional. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string calendarId, string summary, string startIso, string endIso, string timeZone, string description, string location, string attendeesJson) : string
	{
		if (StringUtil.IsEmpty(scopePreset))
			scopePreset = "calendar";

		string eventJson = "{\"summary\":\"" + summary + "\",\"description\":\"" + description + "\",\"location\":\"" + location + "\",\"start\":{\"dateTime\":\"" + startIso + "\",\"timeZone\":\"" + timeZone + "\"},\"end\":{\"dateTime\":\"" + endIso + "\",\"timeZone\":\"" + timeZone + "\"}}";

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.CreateEventAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			eventJson,
			calendarId,
			false,
			new CancellationToken(false));
	}
}

