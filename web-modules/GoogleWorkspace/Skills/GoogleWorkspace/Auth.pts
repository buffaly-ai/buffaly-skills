function ToNormalizeGoogleWorkspaceScopePreset(string scopePreset) : string
{
	if (StringUtil.IsEmpty(scopePreset))
		return "workspace.write";

	string lowered = scopePreset.ToLower();

	// NOTE (Buffaly): chat scope remap temporarily disabled (kept below as comments).
	// Reason: OAuth consent did not include Google Chat scopes when chat.* was coerced to workspace.*.
	// Confidence is not 100% that old mapping was never needed; preserving original lines for future review.
	// if (lowered == "chat.read")
	// 	return "workspace.read";
	// if (lowered == "chat.write" || lowered == "chat")
	// 	return "workspace.write";

	return scopePreset;
}
[SemanticProgram.InfinitivePhrase("to start google workspace authorization")]
[SemanticProgram.InfinitivePhrase("to get a google workspace authorization redirect url")]
[SemanticProgram.InfinitivePhrase("to get a google workspace authorization token")]
prototype ToStartGoogleWorkspaceAuthorization : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - account key without spaces. scopePreset - scope preset such as gmail.read or chat.read (chat aliases normalize to workspace presets). returnUrl - optional return URL. forceConsent - true to force consent. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string returnUrl, bool forceConsent) : string
	{
		scopePreset = ToNormalizeGoogleWorkspaceScopePreset(scopePreset);

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.StartAuthorization(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			returnUrl,
			forceConsent,
			false);
	}
}

[SemanticProgram.InfinitivePhrase("to complete google workspace authorization")]
[SemanticProgram.InfinitivePhrase("to finalize google oauth authorization")]
prototype ToCompleteGoogleWorkspaceAuthorization : GoogleWorkspaceSkillAction
{
	Description = @"Backup/fallback completion only. Normal users should complete Google Workspace OAuth from /web-modules/GoogleWorkspace/google-workspace-accounts.html. state - fresh encoded authorization state from the callback. code - fresh one-time OAuth callback code. Returns JSON.";

	function Execute(string state, string code) : string
	{
		GoogleWorkspaceService.Initialize();

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.CompleteAuthorizationAsync(			state,
			code,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to refresh google workspace authorization")]
[SemanticProgram.InfinitivePhrase("to refresh gmail authorization")]
prototype ToRefreshGoogleWorkspaceAuthorization : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - scope preset, defaults to gmail.read when empty. Returns JSON.";

	function Execute(string accountKey, string scopePreset) : string
	{
		scopePreset = ToNormalizeGoogleWorkspaceScopePreset(scopePreset);

		// Return facade JSON without reshaping.
