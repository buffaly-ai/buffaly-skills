// Memory.pts
// Context: Google Workspace-specific remembered document and tab entities.

[SemanticEntity("remembered google workspace document")]
[SemanticEntity("google workspace document memory")]
prototype RememberedGoogleWorkspaceDocument : BaseObject
{
	String DocumentId = new String();
	String Title = new String();
	String AccountKey = new String();
	String Notes = new String();
}

[SemanticEntity("remembered google workspace document tab")]
[SemanticEntity("google workspace document tab memory")]
prototype RememberedGoogleWorkspaceDocumentTab : BaseObject
{
	RememberedGoogleWorkspaceDocument Document = null;
	String TabPath = new String();
	Int TabIndex = 0;
	String Summary = new String();
}
