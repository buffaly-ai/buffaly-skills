reference System.Data System.Data;
reference Buffaly.Agent.Tools.SqlServer Buffaly.Agent.Tools.SqlServer;

import Buffaly.GoogleWorkspace Buffaly.GoogleWorkspace.Services.GoogleWorkspaceServiceHost GoogleWorkspaceServiceHost;
import Buffaly.GoogleWorkspace Buffaly.GoogleWorkspace.Storage.GoogleWorkspaceSecretsFeature GoogleWorkspaceSecretsFeature;
import BasicUtilities BasicUtilities.StringUtil StringUtil;
import mscorlib System.Threading.CancellationToken CancellationToken;
import Buffaly.Agent.Tools.SqlServer Buffaly.Agent.Tools.SqlServer.SqlServerOperations SqlServerOperations;
import System.Data System.Data.DataSet DataSet;
import System.Data System.Data.DataTable DataTable;
import System.Data System.Data.DataRow DataRow;
import System.Data System.Data.DataColumn DataColumn;

function NormalizeGoogleWorkspaceOperationScopePreset(string scopePreset) : string
{
	if (StringUtil.IsEmpty(scopePreset))
		return "workspace.write";

	string normalized = scopePreset.Trim().ToLowerInvariant();
	if (normalized == "workspace.read" || normalized == "workspace.write")
		return normalized;

	if (normalized.StartsWith("chat."))
		return normalized;

	if (normalized.Contains("readonly") || normalized.EndsWith(".read"))
		return "workspace.read";

	return "workspace.write";
}
