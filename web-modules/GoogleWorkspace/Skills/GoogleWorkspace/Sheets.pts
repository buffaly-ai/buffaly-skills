[SemanticProgram.InfinitivePhrase("to read a google sheets range")]
prototype ToReadGoogleWorkspaceSheetRange : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to spreadsheets.readonly when empty. spreadsheetId and rangeA1 required. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string spreadsheetId, string rangeA1) : string
	{
		if (StringUtil.IsEmpty(scopePreset))
			scopePreset = "spreadsheets.readonly";

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.ReadRangeAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			spreadsheetId,
			rangeA1,
			false,
			new CancellationToken(false));
	}
}

