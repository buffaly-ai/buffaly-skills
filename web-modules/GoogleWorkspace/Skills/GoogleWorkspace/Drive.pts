	Description = @"Convenience overload with minimal inputs. Uses scopePreset drive.write and defaults fileName/mimeType. accountKey/parentFolderId/localFilePath are required. Returns JSON.";

	function Execute(string accountKey, string parentFolderId, string localFilePath) : string
	{
		return ToUploadGoogleWorkspaceDriveFileFromDisk.Execute(accountKey, "drive.write", parentFolderId, localFilePath, "", "");
	}
}

