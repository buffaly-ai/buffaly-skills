[SemanticProgram.InfinitivePhrase("to upload a local file to google drive")]
prototype ToUploadGoogleWorkspaceDriveFileFromDisk : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to drive.write when empty. parentFolderId/localFilePath/fileName/mimeType are required by schema. Pass empty fileName and/or mimeType to use runtime defaults. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string parentFolderId, string localFilePath, string fileName, string mimeType) : string
	{
		scopePreset = ToNormalizeGoogleWorkspaceDriveScopePreset(scopePreset, "drive.write");

		if (StringUtil.IsEmpty(localFilePath))
			return "localFilePath is required.";

		if (StringUtil.IsEmpty(fileName))
			fileName = Path.GetFileName(localFilePath);

		if (StringUtil.IsEmpty(fileName))
			return "fileName is required.";

		if (StringUtil.IsEmpty(mimeType))
			mimeType = "application/octet-stream";

		string base64Content = Convert.ToBase64String(File.ReadAllBytes(localFilePath));

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.UploadFileBase64Async(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			fileName,
			base64Content,
			parentFolderId,
			mimeType,
			false,
			new CancellationToken(false));
	}
}

[SemanticProgram.InfinitivePhrase("to upload a local file to google drive")]
