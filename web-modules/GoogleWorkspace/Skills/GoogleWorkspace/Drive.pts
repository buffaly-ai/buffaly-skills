	function Execute(string accountKey, string scopePreset, string query, int maxResults) : string
	{
		scopePreset = ToNormalizeGoogleWorkspaceDriveScopePreset(scopePreset, "drive.read");

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.SearchFilesAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			query,
			maxResults,
			false,
