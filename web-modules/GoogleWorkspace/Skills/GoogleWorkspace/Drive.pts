function ToNormalizeGoogleWorkspaceDriveScopePreset(string scopePreset, string fallbackPreset) : string
{
	if (StringUtil.IsEmpty(scopePreset))
		return fallbackPreset;

	string normalized = scopePreset.Trim().ToLowerInvariant();
	if (normalized == "drive.file")
		return "drive.write";
	if (normalized == "drive.readonly")
		return "drive.read";

	return scopePreset;
}

