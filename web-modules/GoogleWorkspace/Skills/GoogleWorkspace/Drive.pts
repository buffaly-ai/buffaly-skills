[SemanticProgram.InfinitivePhrase("to grant a google drive file permission")]
prototype ToGrantGoogleWorkspaceDriveFilePermission : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset defaults to drive.write. fileId/permissionType/role required. user/group requires emailAddress. domain requires domain. Optional allowFileDiscovery/sendNotificationEmail/emailMessage/transferOwnership.";

	function Execute(string accountKey, string scopePreset, string fileId, string permissionType, string role, string emailAddress, string domain, bool allowFileDiscovery, bool sendNotificationEmail, string emailMessage, bool transferOwnership) : string
	{
		scopePreset = ToNormalizeGoogleWorkspaceDriveScopePreset(scopePreset, "drive.write");

		bool sendAllowFileDiscovery = allowFileDiscovery;
		if (StringUtil.EqualNoCase(permissionType, "user") || StringUtil.EqualNoCase(permissionType, "group"))
			sendAllowFileDiscovery = false;

		return GoogleWorkspaceServiceHost.CreatePermissionAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			fileId,
			permissionType,
			role,
			emailAddress,
			domain,
			sendAllowFileDiscovery,
			sendNotificationEmail,
			emailMessage,
			transferOwnership,
			false,
			new CancellationToken(false));
	}
}


