[SemanticProgram.InfinitivePhrase("to search gmail messages")]
prototype ToSearchGoogleWorkspaceMessages : GoogleWorkspaceSkillAction
{
	Description = @"accountKey - authorized account key. scopePreset - defaults to gmail.read when empty. query - Gmail query string. maxResults - 1..500. Returns JSON.";

	function Execute(string accountKey, string scopePreset, string query, int maxResults) : string
	{
		if (StringUtil.IsEmpty(scopePreset))
			scopePreset = "gmail.read";

		// Return facade JSON without reshaping.
		return GoogleWorkspaceServiceHost.SearchMessagesAsync(			GoogleWorkspaceService.NormalizeGoogleWorkspaceAccountKey(accountKey),
			NormalizeGoogleWorkspaceOperationScopePreset(scopePreset),
			query,
			maxResults,
			false,
			new CancellationToken(false));
	}
}

