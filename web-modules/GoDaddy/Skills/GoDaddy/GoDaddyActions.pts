// -- Safe tools (reads, local writes) --

[SemanticProgram.InfinitivePhrase("to inspect godaddy account status")]
prototype ToGetGoDaddyAccountStatus : GoDaddySkillAction
{
	Description = @"Check GoDaddy API connection status, key validity, and domain count. Returns JSON.";
	function Execute() : string
	{
		return GoDaddySkillFacade.GetAccountStatus();
	}
}

[SemanticProgram.InfinitivePhrase("to list godaddy domains")]
prototype ToListGoDaddyDomains : GoDaddySkillAction
{
	Description = @"List all domains in the GoDaddy account. Returns JSON array of domains.";
	function Execute() : string
	{
		return GoDaddySkillFacade.ListDomains();
	}
}

[SemanticProgram.InfinitivePhrase("to get a godaddy domain")]
prototype ToGetGoDaddyDomain : GoDaddySkillAction
{
	Description = @"domain - the domain name. Returns JSON domain object with status, expiry, nameservers.";
	function Execute(string domain) : string
	{
		return GoDaddySkillFacade.GetDomain(domain);
	}
}

[SemanticProgram.InfinitivePhrase("to list godaddy dns records")]
prototype ToListGoDaddyDnsRecords : GoDaddySkillAction
{
	Description = @"domain - the domain name. Returns JSON array of all DNS records.";
	function Execute(string domain) : string
	{
		return GoDaddySkillFacade.ListDnsRecords(domain);
	}
}

[SemanticProgram.InfinitivePhrase("to get godaddy dns records")]
prototype ToGetGoDaddyDnsRecords : GoDaddySkillAction
{
	Description = @"domain - the domain name. type - record type (A, CNAME, MX, TXT, etc.). name - record name. Returns JSON array.";
	function Execute(string domain, string type, string name) : string
	{
		return GoDaddySkillFacade.GetDnsRecords(domain, type, name);
	}
}

// -- High-risk tools (external writes, require confirmation) --

[SemanticProgram.InfinitivePhrase("to add a godaddy dns record")]
prototype ToAddGoDaddyDnsRecord : GoDaddySkillAction
{
	Description = @"domain - the domain name. type - record type. name - record name. data - record value. ttl - time to live in seconds. Adds a DNS record. Requires confirmation.";
	function Execute(string domain, string type, string name, string data, int ttl) : string
	{
		return GoDaddySkillFacade.AddDnsRecord(domain, type, name, data, ttl);
	}
}

[SemanticProgram.InfinitivePhrase("to set a godaddy dns record")]
prototype ToSetGoDaddyDnsRecord : GoDaddySkillAction
{
	Description = @"domain - the domain name. type - record type. name - record name. data - record value. ttl - time to live in seconds. Replaces all records of the given type/name. Requires confirmation.";
	function Execute(string domain, string type, string name, string data, int ttl) : string
	{
		return GoDaddySkillFacade.SetDnsRecord(domain, type, name, data, ttl);
	}
}

[SemanticProgram.InfinitivePhrase("to delete a godaddy dns record")]
prototype ToDeleteGoDaddyDnsRecord : GoDaddySkillAction
{
	Description = @"domain - the domain name. type - record type. name - record name. Destructive. Requires confirmation.";
	function Execute(string domain, string type, string name) : string
	{
		return GoDaddySkillFacade.DeleteDnsRecord(domain, type, name);
	}
}

