// -- Domain transfer tools --

[SemanticProgram.InfinitivePhrase("to get godaddy transfer agreements")]
prototype ToGetGoDaddyTransferAgreements : GoDaddySkillAction
{
	Description = @"domain - the domain name to transfer in. Returns JSON array of legal agreements required by GoDaddy, including agreement keys and text. The user must read and accept these before initiating a transfer.";
	function Execute(string domain) : string
	{
		return GoDaddySkillFacade.GetTransferAgreements(domain);
	}
}

[SemanticProgram.InfinitivePhrase("to initiate a godaddy domain transfer")]
prototype ToInitiateGoDaddyTransfer : GoDaddySkillAction
{
	Description = @"domain - the domain name to transfer in. authCode - the EPP authorization code from the current registrar. agreedAt - ISO timestamp of user consent. agreedBy - user name or identity who agreed to the legal terms. agreementKeys - JSON array of legal agreement keys from ToGetGoDaddyTransferAgreements. period - optional registration period in years (1-10, default 1). Initiates a transfer-in. Requires confirmation and valid agreement keys.";
	function Execute(string domain, string authCode, string agreedAt, string agreedBy, string agreementKeys, int period) : string
	{
		return GoDaddySkillFacade.InitiateTransfer(domain, authCode, agreedAt, agreedBy, agreementKeys, period);
	}
}

[SemanticProgram.InfinitivePhrase("to check a godaddy domain transfer status")]
prototype ToCheckGoDaddyTransferStatus : GoDaddySkillAction
{
	Description = @"domain - the domain name. Returns JSON with transfer status, transfer ID, and timestamps.";
	function Execute(string domain) : string
	{
		return GoDaddySkillFacade.CheckTransferStatus(domain);
	}
}
