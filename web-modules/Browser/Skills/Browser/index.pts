reference Buffaly.Browser.WebHarness Buffaly.Browser.WebHarness;
import BasicUtilities BasicUtilities.StringUtil StringUtil;
import Buffaly.Browser.WebHarness Buffaly.Browser.WebHarness.BrowserWorkbenchServiceHost BrowserWorkbenchServiceHost;

prototype BrowserSkillAction : OpsAction
{
	Description = @"Base action type for Browser web-module tools.";
}

[SemanticEntity("browser web module skill")]
prototype BrowserSkill : SkillEntity
{
	Description = "Run browser LLM tasks through the installed Browser web module and runner.";
	ActionRoot = BrowserSkillAction;
}

prototype BrowserWebModuleService : Service
{
	ServiceName = "BrowserWebModuleService";
	Scope = "singleton";
	Description = @"Installed Browser web-module binding using direct Browser workbench runtime APIs.";

	function Initialize() : string
	{
		return BrowserWorkbenchServiceHost.Initialize("");
	}
}

[SemanticEntity("local browser web module service")]
partial prototype BrowserWebModuleService#Local : BrowserWebModuleService
{
	Description = "Local installed Browser web module binding using direct Browser workbench runtime APIs.";
}


