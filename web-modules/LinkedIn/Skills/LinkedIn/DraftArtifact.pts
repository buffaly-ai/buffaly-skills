[SemanticProgram.InfinitivePhrase("to get a linkedin draft artifact")]
prototype ToGetLinkedInDraftArtifact : LinkedInSkillAction
{
	Description = @"draftId - the LinkedIn draft ID. Returns the current draft artifact state including text, media, variants, and revision history.";

	function Execute(string draftId) : string
	{
		return LinkedInSkillFacade.GetDraftArtifact(draftId);
	}
}

[SemanticProgram.InfinitivePhrase("to update linkedin draft text")]
prototype ToUpdateLinkedInDraftText : LinkedInSkillAction
{
	Description = @"draftId - the LinkedIn draft ID. text - the new post text. summary - optional revision summary. Returns the updated artifact.";

	function Execute(string draftId, string text, string summary) : string
	{
		return LinkedInSkillFacade.UpdateDraftText(draftId, text, summary);
	}
}

[SemanticProgram.InfinitivePhrase("to set linkedin draft media")]
prototype ToSetLinkedInDraftMedia : LinkedInSkillAction
{
	Description = @"draftId - the LinkedIn draft ID. imagePrompt - prompt used to generate the image. imagePath - local file path. imageUrl - public URL. altText - accessibility text. Returns the updated artifact.";

	function Execute(string draftId, string imagePrompt, string imagePath, string imageUrl, string altText) : string
	{
		return LinkedInSkillFacade.SetDraftMedia(draftId, imagePrompt, imagePath, imageUrl, altText);
	}
}

[SemanticProgram.InfinitivePhrase("to set linkedin draft variants")]
prototype ToSetLinkedInDraftVariants : LinkedInSkillAction
{
	Description = @"draftId - the LinkedIn draft ID. variantsJson - JSON array of variant objects with label and text fields. Returns the updated artifact.";

	function Execute(string draftId, string variantsJson) : string
	{
		return LinkedInSkillFacade.SetDraftVariants(draftId, variantsJson);
	}
}

[SemanticProgram.InfinitivePhrase("to apply a linkedin draft variant")]
prototype ToApplyLinkedInDraftVariant : LinkedInSkillAction
{
	Description = @"draftId - the LinkedIn draft ID. variantId - the ID of the variant to apply. Returns the updated artifact with the variant text applied.";

	function Execute(string draftId, string variantId) : string
	{
		return LinkedInSkillFacade.ApplyDraftVariant(draftId, variantId);
	}
}
