prototype LinkedInSkillAction : OpsAction
{
	Description = @"Base action type for LinkedIn skill tools.";
}

[SemanticEntity("linkedin skill")]
prototype LinkedInSkill : SkillEntity
{
	Description = "LinkedIn integration for OAuth, drafts, publishing, brand voice, content intelligence, and engagement.";
	ActionRoot = LinkedInSkillAction;
}

include "DraftArtifact.pts";
include "LinkedInActions.pts";

