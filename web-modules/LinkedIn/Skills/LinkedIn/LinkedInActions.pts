// -- Safe tools (local reads/writes, no external writes) ----------------

[SemanticProgram.InfinitivePhrase("to inspect linkedin account status")]
prototype ToGetLinkedInAccountStatus : LinkedInSkillAction
{
	Description = @"Check LinkedIn connection status, profile, and permissions. Returns JSON.";

	function Execute() : string
	{
		return LinkedInSkillFacade.GetAccountStatus();
	}
}

