reference Buffaly.OpenAI.ComputerUse.WebHarness Buffaly.OpenAI.ComputerUse.WebHarness;
import Buffaly.Agent.Host Buffaly.Agent.Host.OpenAIFeature OpenAIFeature;
import BasicUtilities BasicUtilities.JsonObject JsonObject;
import BasicUtilities BasicUtilities.JsonValue JsonValue;
import BasicUtilities BasicUtilities.StringUtil StringUtil;
import Buffaly.OpenAI.ComputerUse.WebHarness Buffaly.OpenAI.ComputerUse.WebHarness.ComputerUseWorkbenchServiceHost ComputerUseWorkbenchServiceHost;
import Buffaly.OpenAI.ComputerUse.WebHarness Buffaly.OpenAI.ComputerUse.WebHarness.StartComputerUseRunRequest StartComputerUseRunRequest;

prototype ComputerUseSkillAction : OpsAction
{
	Description = @"Base action type for cohesive ComputerUse module tools.";
}

[SemanticEntity("computer use skill")]
prototype ComputerUseSkill : SkillEntity
{
	Description = "Run an end-to-end OpenAI Computer Use task through the installed ComputerUse web module and desktop runner.";
	ActionRoot = ComputerUseSkillAction;
}

prototype ComputerUseWebModuleService : Service
{
	ServiceName = "ComputerUseWebModuleService";
	Scope = "singleton";
	Description = @"Installed ComputerUse web-module binding using direct ComputerUse workbench runtime APIs.";

	function Initialize() : string
	{
		string apiKey = OpenAIFeature.Feature.ApiKey;
		if (StringUtil.IsEmpty(apiKey))
		{
			throw "OpenAI Feature ApiKey is required before using the ComputerUse web module.";
		}

		return ComputerUseWorkbenchServiceHost.Initialize(apiKey);
	}
}

[SemanticEntity("local computer use web module service")]
partial prototype ComputerUseWebModuleService#Local : ComputerUseWebModuleService
{
	Description = "Local installed ComputerUse web module binding using direct ComputerUse workbench runtime APIs.";
}

[SemanticProgram.InfinitivePhrase("to run a computer use task")]
[SemanticProgram.InfinitivePhrase("to use the computer")]
prototype ToRunComputerUseTask : ComputerUseSkillAction
{
	Description = @"instruction, model(optional), maxSteps(optional integer), captureScope(optional), windowTitle(optional). Starts one ComputerUse task through the installed web module and returns the run id/status immediately. Use ToGetComputerUseRunStatus or ToStopComputerUseRun to monitor or control it; use ToRunComputerUseTaskAndWait when a blocking call is desired.";

	ComputerUseWebModuleService Service = ComputerUseWebModuleService#Local;

	function Execute(string instruction, string model, int maxSteps = 40, string captureScope, string windowTitle) : string
	{
		if (StringUtil.IsEmpty(instruction))
		{
			return "Error: instruction is required.";
		}

		StartComputerUseRunRequest request = new StartComputerUseRunRequest();
		request.Direction = instruction;
		if (!StringUtil.IsEmpty(model)) request.Model = model;
		request.MaxSteps = maxSteps;
		if (!StringUtil.IsEmpty(captureScope)) request.CaptureScope = captureScope;
		if (!StringUtil.IsEmpty(windowTitle)) request.WindowTitle = windowTitle;

		return JsonUtil.ToFriendlyJSON(new JsonValue(ComputerUseWorkbenchServiceHost.StartRun(request))).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to get computer use run status")]
[SemanticProgram.InfinitivePhrase("to check computer use progress")]
prototype ToGetComputerUseRunStatus : ComputerUseSkillAction
{
	Description = @"runId. Gets the current ComputerUse run status and recent output through the typed ComputerUse runtime without PowerShell/file polling.";

	ComputerUseWebModuleService Service = ComputerUseWebModuleService#Local;

	function Execute(string runId) : string
	{
		if (StringUtil.IsEmpty(runId))
		{
			return "Error: runId is required.";
		}

		return JsonUtil.ToFriendlyJSON(new JsonValue(ComputerUseWorkbenchServiceHost.GetRun(runId))).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to stop computer use run")]
[SemanticProgram.InfinitivePhrase("to interrupt computer use task")]
prototype ToStopComputerUseRun : ComputerUseSkillAction
{
	Description = @"runId. Requests interruption of a running ComputerUse task and returns the updated run snapshot.";

	ComputerUseWebModuleService Service = ComputerUseWebModuleService#Local;

	function Execute(string runId) : string
	{
		if (StringUtil.IsEmpty(runId))
		{
			return "Error: runId is required.";
		}

		return JsonUtil.ToFriendlyJSON(new JsonValue(ComputerUseWorkbenchServiceHost.StopRun(runId))).ToString();
	}
}

[SemanticProgram.InfinitivePhrase("to run a computer use task and wait")]
[SemanticProgram.InfinitivePhrase("to run computer use until complete")]
prototype ToRunComputerUseTaskAndWait : ComputerUseSkillAction
{
	Description = @"instruction, model(optional), maxSteps(optional integer), captureScope(optional), windowTitle(optional), timeoutSeconds(optional integer), pollIntervalMilliseconds(optional integer), stopOnTimeout(optional bool). Starts a ComputerUse task and waits through the typed runtime until it completes, fails, is interrupted, or the timeout expires.";

	ComputerUseWebModuleService Service = ComputerUseWebModuleService#Local;

	function Execute(string instruction, string model, int maxSteps = 40, string captureScope, string windowTitle, int timeoutSeconds = 300, int pollIntervalMilliseconds = 1000, bool stopOnTimeout = false) : string
	{
		if (StringUtil.IsEmpty(instruction))
		{
			return "Error: instruction is required.";
		}

		StartComputerUseRunRequest request = new StartComputerUseRunRequest();
		request.Direction = instruction;
		if (!StringUtil.IsEmpty(model)) request.Model = model;
		request.MaxSteps = maxSteps;
		if (!StringUtil.IsEmpty(captureScope)) request.CaptureScope = captureScope;
		if (!StringUtil.IsEmpty(windowTitle)) request.WindowTitle = windowTitle;

		return JsonUtil.ToFriendlyJSON(new JsonValue(ComputerUseWorkbenchServiceHost.RunAndWait(request, timeoutSeconds, pollIntervalMilliseconds, stopOnTimeout))).ToString();
	}
}


