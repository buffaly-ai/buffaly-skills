prototype OfflineOntologyCriticPromptAction : OfflineOntologyCriticActionRoot
{
	Description = @"Base prompt action type for offline ontology critic workflows.";
	Bool IsPromptAction = true;
	String SkillKind = new String();
	String PromptPath = new String();
	String SkillVersion = new String();

	function Execute() : string
	{
		if (_opsAgent == null)
			return "Error: _opsAgent runtime is not available.";

		String promptText = _opsAgent.LoadTrustedPromptText(PromptPath);
		String instructionHeader =
			"## Prompt Skill Instructions\n"
			+ "These are instructions to follow to accomplish the task.\n"
			+ "This action returns guidance text, not task results.\n"
			+ "Avoid calling the same prompt action again in this turn unless new context is provided.\n"
			+ "Prompt source: " + PromptPath + "\n\n";

		return instructionHeader + promptText;
	}
}

[SemanticProgram.InfinitivePhrase("to run phase one offline ontology critic review")]
[SemanticProgram.InfinitivePhrase("to review session user language for ontology entrypoints")]
prototype ToRunOfflineOntologyCriticPhase1Skill : OfflineOntologyCriticPromptAction, OfflineOntologyCriticActionRoot
{
	IsPromptAction = true;
	SkillKind = "prompt";
	SkillVersion = "1.0.0";
	PromptPath = @"Skills/OfflineOntologyCritic/Prompts/Phase1EntrypointReview.prompt.md";
	Description = @"Writes the critic Phase 1 artifact by inspecting source session history, collecting user language first, and mapping human entrypoints to grounded meanings without ontology search.";
}

